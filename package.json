{
  "name": "greenpill_v2",
  "version": "1.0.0",
  "description": "Greenpill Network public website — Astro + Keystatic",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:agent": "bun run --cwd packages/agent dev",
    "build": "astro build",
    "preview": "astro preview",
    "start:agent": "bun run --cwd packages/agent start",
    "astro": "astro",
    "db:local:up": "bun run --cwd packages/agent db:local:up",
    "db:local:down": "bun run --cwd packages/agent db:local:down",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/agent-db.migrate.mjs",
    "plans:scaffold": "node scripts/plan-hub.mjs scaffold",
    "plans:validate": "node scripts/plan-hub.mjs validate",
    "test:agent": "node --test scripts/agent-contract.test.mjs",
    "test:chapter-impact": "node --test scripts/chapter-impact-contract.test.mjs",
    "test:map-nodes": "node --test scripts/map-node-contract.test.mjs",
    "test:plans": "node --test scripts/plan-hub.test.mjs"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@greenpill/network-agent": "workspace:*",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.42.0",
    "postcss": "^8.5.8",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@greenpill/network-shared": "workspace:*",
    "@astrojs/tailwind": "^5.1.5",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.48",
    "astro": "^5.18.1",
    "gsap": "^3.14.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
