# Copy this file to .env.local for local agent development.
# Do not commit .env.local or production secrets.

AGENT_HOST=127.0.0.1
AGENT_PORT=8787
PORT=8787

# Local Docker Postgres default from docker-compose.yml.
DATABASE_URL=postgres://greenpill:greenpill@localhost:54329/greenpill_network

# Use the direct Fly Managed Postgres URL for migrations when deploying.
DIRECT_DATABASE_URL=
