# Copy this file to .env.local for local agent development.
# Do not commit .env.local or production secrets.

AGENT_HOST=127.0.0.1
AGENT_PORT=8787
PORT=8787

# Local Docker Postgres default from docker-compose.yml.
DATABASE_URL=postgres://greenpill:greenpill@localhost:54329/greenpill_network

# Use the direct Fly Managed Postgres URL for migrations when deploying.
DIRECT_DATABASE_URL=

# Public chapter impact cache inputs. Keep database credentials on the agent only.
IMPACT_SOURCES_URL=https://greenpill.network/impact-sources.json
GREEN_GOODS_INDEXER_URL=https://indexer.hyperindex.xyz/0bf0e0f/v1/graphql
GREEN_GOODS_CHAIN_ID=42161
IMPACT_CACHE_TTL_SECONDS=21600
KARMA_API_BASE=https://gapapi.karmahq.xyz/v2

# Email magic-link node updates. Keep secrets on the agent service only.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
MAP_NODE_EMAIL_FROM=Greenpill Network <map@mail.greenpill.network>
MAP_NODE_EMAIL_REPLY_TO=Greenpill Network <map@mail.greenpill.network>
MAP_NODE_EDIT_BASE_URL=https://greenpill.network/map/edit
