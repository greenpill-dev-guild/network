{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@greenpill-network/agent": ["packages/agent/src/index.ts"],
      "@greenpill-network/agent/*": ["packages/agent/src/*.ts"],
      "@greenpill-network/shared": ["packages/shared/src/index.ts"],
      "@greenpill-network/shared/*": ["packages/shared/src/*.ts"]
    }
  }
}
