# Optional local Directus overrides. Production values must be Fly secrets.

DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_DB_CONNECTION_STRING=postgres://greenpill:greenpill@host.docker.internal:54329/greenpill_network
DIRECTUS_DB_HEALTHCHECK_THRESHOLD=2000
DIRECTUS_FILES_MAX_UPLOAD_SIZE=25mb
DIRECTUS_MAX_PAYLOAD_SIZE=25mb
DIRECTUS_SECRET=dev-only-directus-secret-change-before-production
DIRECTUS_ADMIN_EMAIL=admin@greenpill.network
DIRECTUS_ADMIN_PASSWORD=directus-local-password
DIRECTUS_CORS_ORIGIN=http://localhost:4321,http://localhost:8055,https://greenpill.network,https://www.greenpill.network,https://network-admin.fly.dev,https://admin.greenpill.network
DIRECTUS_EMAIL_VERIFY_SETUP=false
DIRECTUS_EMAIL_FROM="Greenpill Network <no-reply@mail.greenpill.network>"
DIRECTUS_EMAIL_TRANSPORT=sendmail
DIRECTUS_EMAIL_SMTP_HOST=
DIRECTUS_EMAIL_SMTP_PORT=587
DIRECTUS_EMAIL_SMTP_USER=
DIRECTUS_EMAIL_SMTP_PASSWORD=
DIRECTUS_EMAIL_SMTP_SECURE=false
DIRECTUS_EMAIL_SMTP_POOL=true
