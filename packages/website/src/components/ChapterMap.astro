---
import { PUBLIC_MAP_THEMES } from '@greenpill-network/shared/map-state';

const mapThemes = PUBLIC_MAP_THEMES;
---

<section id="network" class="transition-opacity duration-500 sm:min-h-screen">
  <div class="sm:min-h-screen flex flex-col justify-evenly items-center py-12 px-4 sm:px-8">
    <div class="map-section-copy">
      <h2 class="font-volkhov text-xl lg:text-3xl text-yellow text-center mb-2 xl:mb-4">We're building a CoordiNation across Nations & Cultures.</h2>
      <p class="text-center max-w-md m-auto mb-5 xl:mb-12">CoordiNation (noun): a network-society that exports regenerative digital infrastructure to the world.</p>
    </div>

    <div class="map-layout">
      <div class="map-toolbar" aria-live="polite">
        <span class="map-mode-pill">Moderated map</span>
        <span class="map-mode-copy">Submitted nodes are steward-reviewed before they appear publicly.</span>
      </div>

      <div class="relative flex justify-center w-full mx-auto" id="map-container" data-map-mode="moderated">
        <canvas id="canvas" width="758" height="400" class="map-canvas"></canvas>
        <div class="map-selected-card hidden opacity-0" aria-live="polite">
          <p class="map-selected-kicker">Selected node</p>
          <p class="map-selected-name"></p>
          <p class="map-selected-place"></p>
          <div class="map-selected-themes"></div>
          <a target="_blank" rel="noreferrer" class="map-selected-action hidden">Open profile</a>
        </div>
      </div>

      <div class="map-legend" aria-label="Map legend">
        <span><i class="legend-dot legend-dot-member"></i>Members</span>
        <span><i class="legend-dot legend-dot-chapter"></i>Chapters</span>
        <span><i class="legend-dot legend-dot-steward"></i>Stewards</span>
        <span><i class="legend-line"></i>Shared themes</span>
      </div>

      <details class="map-add-node-panel">
        <summary>Add your node</summary>
        <form id="map-node-form" class="map-node-form" novalidate>
          <div class="map-form-grid">
            <label>
              <span>Name</span>
              <input name="name" autocomplete="name" required placeholder="Your name or project" />
            </label>
            <label>
              <span>City or place</span>
              <input name="place" autocomplete="address-level2" required placeholder="Lagos, Nigeria" />
            </label>
            <label>
              <span>Latitude</span>
              <input name="lat" inputmode="decimal" required type="number" step="0.000001" min="-90" max="90" placeholder="6.5244" />
            </label>
            <label>
              <span>Longitude</span>
              <input name="long" inputmode="decimal" required type="number" step="0.000001" min="-180" max="180" placeholder="3.3792" />
            </label>
          </div>

          <fieldset class="map-theme-fieldset">
            <legend>Themes</legend>
            <div class="map-theme-options">
              {mapThemes.map((theme) => (
                <label class="map-theme-option">
                  <input type="checkbox" name="themes" value={theme.id} />
                  <span>{theme.label}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <label>
            <span>Public note</span>
            <textarea name="publicNote" rows="3" maxlength="280" placeholder="What are you working on with the network?"></textarea>
          </label>

          <label>
            <span>Email for steward follow-up</span>
            <input name="contact" autocomplete="email" type="email" placeholder="you@example.org" />
          </label>

          <div class="map-form-footer">
            <p class="map-form-mode-copy">In moderated mode, your node appears locally while stewards review it.</p>
            <button type="submit" class="map-submit-button">Add node</button>
          </div>
          <p class="map-form-status" role="status"></p>
        </form>
      </details>
    </div>

    <p class="text-center text-sm mt-6">Don't see a chapter in your area? <a class="link !px-0" href="https://bit.ly/greenpill-your-city" target="_blank">Start one.</a></p>
  </div>
</section>

<style>
  .map-section-copy {
    width: min(100%, 42rem);
  }

  .map-layout {
    width: min(100%, 56rem);
    display: grid;
    gap: 0.85rem;
  }

  .map-toolbar,
  .map-legend,
  .map-add-node-panel {
    width: min(100%, 48rem);
    margin-inline: auto;
  }

  .map-toolbar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    flex-wrap: wrap;
    text-align: center;
    font-size: 0.875rem;
  }

  .map-mode-pill {
    min-height: 2rem;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(207, 247, 90, 0.36);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    background: rgba(12, 44, 32, 0.72);
    color: #d4f564;
    font-weight: 700;
    letter-spacing: 0;
  }

  .map-mode-copy,
  .map-form-mode-copy {
    color: rgba(246, 241, 216, 0.8);
  }

  #map-container {
    aspect-ratio: 758 / 400;
    min-height: 13.75rem;
    border: 1px solid rgba(207, 247, 90, 0.16);
    border-radius: 8px;
    overflow: hidden;
    background: #07180f;
    box-shadow: 0 18px 40px rgba(2, 12, 7, 0.28);
  }

  .map-canvas {
    display: block;
    z-index: 10;
    width: 100%;
    height: 100%;
    max-width: 100%;
    cursor: pointer;
  }

  .map-selected-card {
    position: absolute;
    z-index: 30;
    top: 0.75rem;
    left: 0.75rem;
    max-width: min(18rem, calc(100% - 1.5rem));
    border: 1px solid rgba(207, 247, 90, 0.24);
    border-radius: 8px;
    padding: 0.75rem;
    background: rgba(7, 24, 15, 0.92);
    color: #f6f1d8;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(10px);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .map-selected-kicker {
    color: #d4f564;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .map-selected-name {
    margin-top: 0.15rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .map-selected-place {
    margin-top: 0.2rem;
    color: rgba(246, 241, 216, 0.78);
    font-size: 0.875rem;
  }

  .map-selected-themes {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-top: 0.55rem;
  }

  .map-selected-themes span {
    min-height: 1.6rem;
    display: inline-flex;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--theme-color, #d4f564) 64%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.5rem;
    color: #f6f1d8;
    background: color-mix(in srgb, var(--theme-color, #d4f564) 18%, transparent);
    font-size: 0.75rem;
  }

  .map-selected-action {
    display: inline-flex;
    min-height: 2rem;
    align-items: center;
    margin-top: 0.65rem;
    color: #d4f564;
    font-size: 0.875rem;
    text-decoration: underline;
  }

  .map-selected-action.hidden,
  .map-selected-card.hidden {
    display: none;
  }

  .map-legend {
    display: flex;
    justify-content: center;
    gap: 0.5rem 1rem;
    flex-wrap: wrap;
    color: rgba(246, 241, 216, 0.82);
    font-size: 0.8rem;
  }

  .map-legend span {
    min-height: 1.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    display: inline-block;
  }

  .legend-dot-member {
    background: #d4f564;
    box-shadow: 0 0 0 2px rgba(212, 245, 100, 0.25);
  }

  .legend-dot-chapter {
    background: #123f2d;
    box-shadow: 0 0 0 2px #b8e835;
  }

  .legend-dot-steward {
    background: #f0dca0;
    box-shadow: 0 0 0 2px rgba(240, 220, 160, 0.28);
  }

  .legend-line {
    width: 1.8rem;
    height: 0.15rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #d4f564, #60c7bc, #f0dca0);
  }

  .map-add-node-panel {
    border: 1px solid rgba(207, 247, 90, 0.16);
    border-radius: 8px;
    background: rgba(7, 24, 15, 0.62);
  }

  .map-add-node-panel summary {
    min-height: 3rem;
    display: flex;
    align-items: center;
    cursor: pointer;
    padding: 0.8rem 1rem;
    color: #d4f564;
    font-weight: 700;
  }

  .map-node-form {
    display: grid;
    gap: 0.85rem;
    padding: 0 1rem 1rem;
  }

  .map-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .map-node-form label,
  .map-theme-fieldset {
    display: grid;
    gap: 0.35rem;
  }

  .map-node-form label span,
  .map-theme-fieldset legend {
    color: rgba(246, 241, 216, 0.84);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .map-node-form input,
  .map-node-form textarea {
    min-height: 2.85rem;
    border: 1px solid rgba(207, 247, 90, 0.18);
    border-radius: 8px;
    padding: 0.75rem;
    background: rgba(2, 12, 7, 0.72);
    color: #f6f1d8;
    outline: none;
  }

  .map-node-form textarea {
    min-height: 5rem;
    resize: vertical;
  }

  .map-node-form input:focus,
  .map-node-form textarea:focus {
    border-color: rgba(212, 245, 100, 0.78);
    box-shadow: 0 0 0 3px rgba(212, 245, 100, 0.12);
  }

  .map-theme-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .map-theme-option {
    min-height: 2.75rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    border: 1px solid rgba(207, 247, 90, 0.16);
    border-radius: 8px;
    padding: 0.5rem 0.6rem;
    background: rgba(2, 12, 7, 0.36);
    cursor: pointer;
  }

  .map-theme-option input {
    width: 1rem;
    min-height: 1rem;
    border: 0;
    padding: 0;
    background: transparent;
    accent-color: #d4f564;
  }

  .map-theme-option span {
    font-weight: 600;
  }

  .map-form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .map-submit-button {
    min-height: 3rem;
    min-width: 8.5rem;
    border-radius: 999px;
    padding: 0.75rem 1.1rem;
    background: #d4f564;
    color: #07180f;
    font-weight: 800;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .map-submit-button:disabled {
    opacity: 0.64;
  }

  .map-submit-button:not(:disabled):hover {
    transform: translateY(-1px);
  }

  .map-form-status {
    min-height: 1.25rem;
    color: #d4f564;
    font-size: 0.875rem;
  }

  .map-form-status[data-tone='error'] {
    color: #f0dca0;
  }

  .map-form-status[data-tone='success'] {
    color: #d4f564;
  }

  @media (max-width: 640px) {
    .map-layout {
      gap: 0.75rem;
    }

    .map-toolbar {
      align-items: stretch;
      flex-direction: column;
      gap: 0.45rem;
    }

    .map-mode-pill {
      justify-content: center;
    }

    #map-container {
      min-height: 14.5rem;
    }

    .map-selected-card {
      top: auto;
      bottom: 0.65rem;
      left: 0.65rem;
      max-width: calc(100% - 1.3rem);
    }

    .map-form-grid,
    .map-theme-options {
      grid-template-columns: 1fr;
    }

    .map-form-footer {
      align-items: stretch;
      flex-direction: column;
    }

    .map-submit-button {
      width: 100%;
    }
  }
</style>
