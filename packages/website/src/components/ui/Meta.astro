---
interface Props {
  items?: string[];
  accentIndex?: number;
  class?: string;
}

const { items = [], accentIndex, class: className } = Astro.props;
const classes = ['gp-meta-line', className].filter(Boolean).join(' ');

// Each `·`-separated chunk is its own segment so the row can wrap between
// them (DESIGN.md). Splitting here keeps authored "A · B" content from
// collapsing into a single un-wrappable nowrap span that overflows on mobile.
const segments: string[] = [];
let accentSegment = -1;
items.forEach((item, i) => {
  if (i === accentIndex) accentSegment = segments.length;
  for (const part of String(item).split(/\s*·\s*/)) {
    if (part.trim()) segments.push(part.trim());
  }
});
---

<div class={classes}>
  {segments.map((seg, index) => (
    <>
      <span class:list={[{ 'is-accent': index === accentSegment }]}>{seg}</span>
      {index < segments.length - 1 && <span aria-hidden="true" class="gp-meta-sep">&middot;</span>}
    </>
  ))}
</div>

<style>
  .gp-meta-line {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--gp-space-sm);
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .gp-meta-line span:not(.gp-meta-sep) {
    white-space: nowrap;
  }

  .gp-meta-line .is-accent {
    color: var(--gp-primary);
  }

  .gp-meta-sep {
    opacity: 0.5;
  }
</style>
