---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  variant?: 'display' | 'h1' | 'h2' | 'h3' | 'title-lg' | 'title-md' | 'body-lg' | 'body' | 'body-sm' | 'caption' | 'mono';
  class?: string;
}

const { as, variant = 'body', class: className } = Astro.props;

const defaultTags: Record<NonNullable<Props['variant']>, keyof HTMLElementTagNameMap> = {
  display: 'h1',
  h1: 'h1',
  h2: 'h2',
  h3: 'h3',
  'title-lg': 'p',
  'title-md': 'p',
  'body-lg': 'p',
  body: 'p',
  'body-sm': 'p',
  caption: 'span',
  mono: 'span',
};

const Tag = as ?? defaultTags[variant];
const classes = ['gp-text', `is-${variant}`, className].filter(Boolean).join(' ');
---

<Tag class={classes}>
  <slot />
</Tag>

<style>
  .gp-text {
    margin: 0;
  }

  .gp-text.is-display,
  .gp-text.is-h1,
  .gp-text.is-h2,
  .gp-text.is-h3 {
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-weight: 500;
    font-variation-settings: var(--gp-display-vs);
    text-wrap: pretty;
  }

  .gp-text.is-display {
    font-size: var(--gp-display-size);
    line-height: var(--gp-display-lh);
    letter-spacing: var(--gp-display-ls);
  }

  .gp-text.is-h1 {
    font-size: var(--gp-h1-size);
    line-height: var(--gp-h1-lh);
    letter-spacing: var(--gp-h1-ls);
  }

  .gp-text.is-h2 {
    font-size: var(--gp-h2-size);
    line-height: var(--gp-h2-lh);
    letter-spacing: var(--gp-h2-ls);
  }

  .gp-text.is-h3 {
    font-size: var(--gp-h3-size);
    line-height: var(--gp-h3-lh);
    letter-spacing: var(--gp-h3-ls);
  }

  .gp-text.is-title-lg,
  .gp-text.is-title-md,
  .gp-text.is-body-lg,
  .gp-text.is-body,
  .gp-text.is-body-sm,
  .gp-text.is-caption {
    font-family: var(--gp-font-body);
  }

  .gp-text.is-title-lg {
    color: var(--gp-fg);
    font-size: var(--gp-title-lg);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .gp-text.is-title-md {
    color: var(--gp-fg);
    font-size: var(--gp-title-md);
    font-weight: 600;
    line-height: 1.35;
  }

  .gp-text.is-body-lg {
    color: var(--gp-fg);
    font-size: var(--gp-body-lg);
    font-weight: 400;
    line-height: 1.6;
  }

  .gp-text.is-body {
    color: var(--gp-fg);
    font-size: var(--gp-body-md);
    font-weight: 400;
    line-height: 1.6;
  }

  .gp-text.is-body-sm {
    color: var(--gp-fg-muted);
    font-size: var(--gp-body-sm);
    font-weight: 400;
    line-height: 1.55;
    letter-spacing: 0.005em;
  }

  .gp-text.is-caption {
    color: var(--gp-fg-muted);
    font-size: var(--gp-caption);
    font-weight: 400;
    line-height: 1.4;
  }

  .gp-text.is-mono {
    color: var(--gp-fg-muted);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  /* Display/h1/h2 sizes are fluid clamp() tokens (gp-tokens.css) — no
     viewport @media step-down needed. */
</style>
