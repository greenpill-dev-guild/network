---
interface Props {
  tone?: 'primary' | 'secondary';
  size?: 'sm' | 'lg';
  class?: string;
}

const { tone = 'primary', size = 'sm', class: className } = Astro.props;
const classes = ['gp-status-chip', `is-${tone}`, `is-${size}`, className].filter(Boolean).join(' ');
---

<span class={classes}>
  <span aria-hidden="true"></span>
  <slot />
</span>

<style>
  .gp-status-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    border-radius: var(--gp-radius-pill);
    font-family: var(--gp-font-body);
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .gp-status-chip.is-sm {
    min-height: 28px;
    padding: 0 10px;
    font-size: 10px;
  }

  .gp-status-chip.is-lg {
    min-height: 36px;
    padding: 0 12px;
    font-size: 11px;
  }

  .gp-status-chip.is-primary {
    border: 1px solid rgba(184, 232, 53, 0.42);
    background: rgba(184, 232, 53, 0.12);
    color: var(--gp-primary);
  }

  .gp-status-chip.is-secondary {
    border: 1px solid rgba(240, 220, 160, 0.32);
    background: rgba(240, 220, 160, 0.1);
    color: var(--gp-secondary);
  }

  .gp-status-chip span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 6px rgba(184, 232, 53, 0.65);
  }

  .gp-status-chip.is-secondary span {
    box-shadow: none;
  }
</style>
