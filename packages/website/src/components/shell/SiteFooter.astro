---
interface Props {
  showWordmark?: boolean;
}

const { showWordmark = false } = Astro.props;

const columns = [
  {
    heading: 'Network',
    items: [
      { label: 'Chapters', href: '/chapters' },
      { label: 'Guilds', href: '/guilds' },
      { label: 'Projects', href: '/projects' },
      { label: 'Garden', href: '/garden' },
    ],
  },
  {
    heading: 'Get involved',
    items: [
      { label: 'Start a chapter', href: '/join' },
      { label: 'Attend an event', href: '/chapters' },
      { label: 'Add yourself to the map', href: '/join' },
      { label: 'Become a steward', href: '/join' },
    ],
  },
  {
    heading: 'Resources',
    items: [
      { label: 'Library', href: '/library' },
      { label: 'Stories', href: '/stories' },
      { label: 'Onboarding', href: '/learn/onboarding' },
      { label: 'Podcast', href: '/library' },
    ],
  },
  {
    heading: 'Connect',
    items: [
      { label: 'Twitter', href: 'https://twitter.com/greenpillnet' },
      { label: 'Discord', href: '/join' },
      { label: 'Telegram', href: '/join' },
      { label: 'Hub', href: '/join' },
    ],
  },
];
---

<footer class="gp-site-footer">
  {showWordmark && (
    <div class="gp-footer-wordmark is-centered">
      <img src="/images/hifi/green-pill-wordmark.svg" alt="GREEN PILL" />
    </div>
  )}

  <div class="gp-footer-grid">
    {columns.map((column) => (
      <div class="gp-footer-column">
        <div class="gp-footer-heading">{column.heading}</div>
        <nav aria-label={column.heading}>
          {column.items.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    ))}

    {!showWordmark && (
      <div class="gp-footer-wordmark">
        <img src="/images/hifi/green-pill-wordmark.svg" alt="GREEN PILL" />
        <p>A CoordiNation across<br />Nations and Cultures.</p>
      </div>
    )}
  </div>

  <div class="gp-footer-bottom">
    <span>greenpill.network</span>
    <span>2026 Greenpill Network</span>
  </div>
</footer>

<style>
  .gp-site-footer {
    position: relative;
    margin-top: var(--gp-space-4xl);
    padding: var(--gp-space-4xl) clamp(var(--gp-space-lg), 6vw, var(--gp-space-4xl)) var(--gp-space-3xl);
    border-top: 1px solid var(--gp-border-soft);
    background: var(--gp-green-950);
  }

  .gp-footer-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr)) auto;
    gap: var(--gp-space-2xl);
    align-items: start;
    max-width: var(--gp-container-2xl);
    margin-inline: auto;
  }

  .gp-footer-column {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
  }

  .gp-footer-heading {
    color: var(--gp-primary);
    font-family: var(--gp-font-body);
    font-size: var(--gp-overline);
    font-weight: 700;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .gp-footer-column nav {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
  }

  .gp-footer-column a {
    color: var(--gp-fg-muted);
    font-size: var(--gp-body-sm);
    line-height: 1.4;
    text-decoration: none;
    transition: color 180ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gp-footer-column a:hover {
    color: var(--gp-primary);
  }

  .gp-footer-wordmark {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 14px;
    min-width: 128px;
  }

  .gp-footer-wordmark.is-centered {
    align-items: center;
    margin: 0 auto var(--gp-space-3xl);
  }

  .gp-footer-wordmark img {
    width: 132px;
    height: auto;
    color: var(--gp-secondary);
    opacity: 0.88;
  }

  .gp-footer-wordmark.is-centered img {
    width: min(260px, 70vw);
  }

  .gp-footer-wordmark p {
    color: var(--gp-fg-muted);
    font-size: var(--gp-caption);
    line-height: 1.4;
    margin: 0;
    text-align: right;
  }

  .gp-footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--gp-space-lg);
    max-width: var(--gp-container-2xl);
    margin: var(--gp-space-3xl) auto 0;
    padding-top: var(--gp-space-lg);
    border-top: 1px solid var(--gp-border-soft);
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .gp-footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gp-footer-wordmark {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .gp-site-footer {
      padding: var(--gp-space-3xl) var(--gp-space-lg) var(--gp-space-xl);
    }

    .gp-footer-grid {
      gap: var(--gp-space-xl) var(--gp-space-lg);
    }

    .gp-footer-bottom {
      flex-direction: column;
      gap: var(--gp-space-sm);
    }
  }
</style>
