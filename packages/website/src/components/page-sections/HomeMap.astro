---
import { getOperationalChapters } from '../../lib/operational-content';
import { PUBLIC_MAP_THEMES } from '@greenpill-network/shared/map-state';

// Add-node walkthrough theme choices use the canonical public theme list.
const mapThemes = PUBLIC_MAP_THEMES;

// Mirrors artifacts/hifi/hifi/map-themes.jsx labels and hues. Slugs match the
// content/themes/*.json files. Edge color carries theme meaning; node fill
// carries node identity (chapter / steward / member).
const THEME_INFO: Record<string, { label: string; color: string }> = {
  trees: { label: 'Trees & Biodiversity', color: '#7BC74D' },
  food: { label: 'Food & Farms', color: '#A8D24A' },
  water: { label: 'Water & Waste', color: '#3FB6A8' },
  energy: { label: 'Clean Energy', color: '#F5CB45' },
  gov: { label: 'Local Governance', color: '#E8B14B' },
  events: { label: 'Local Events', color: '#E89455' },
  funding: { label: 'Grants & Funding', color: '#E07856' },
  currency: { label: 'Community Currency', color: '#D86A4A' },
  mutual: { label: 'Mutual Aid', color: '#D87B97' },
  stories: { label: 'Storytelling', color: '#E0A6B8' },
  education: { label: 'Education', color: '#F0DCA0' },
  opensrc: { label: 'Open Source', color: '#5CC2D9' },
  desci: { label: 'DeSci', color: '#7DAEE0' },
  ai: { label: 'AI & Automation', color: '#9B8FD9' },
  impact: { label: 'Impact Tracking', color: '#86E0B5' },
  public: { label: 'Public Goods', color: '#C9A4E0' },
  'public-goods': { label: 'Public Goods', color: '#C9A4E0' },
  'local-regeneration': { label: 'Local Regeneration', color: '#7BC74D' },
  'knowledge-commons': { label: 'Knowledge Commons', color: '#F0DCA0' },
  'coordination-tools': { label: 'Coordination Tools', color: '#86E0B5' },
};

// Equirectangular projection. viewBox = 0..200 (x) × 0..100 (y).
const VIEW_W = 200;
const VIEW_H = 100;
const lonToX = (lon: number) => ((lon + 180) / 360) * VIEW_W;
const latToY = (lat: number) => ((90 - lat) / 180) * VIEW_H;

// Hand-simplified continent silhouettes, copied from
// artifacts/hifi/hifi/map-world.jsx. Aimed at instantly-recognizable shapes,
// not geodetic accuracy.
const CONTINENTS: Array<Array<[number, number]>> = [
  [[-167,66],[-160,71],[-148,71],[-133,69],[-110,73],[-95,79],[-83,75],[-75,78],[-70,73],[-62,60],[-65,52],[-66,46],[-71,45],[-77,38],[-82,30],[-92,29],[-97,27],[-104,21],[-110,23],[-117,32],[-124,40],[-124,48],[-130,55],[-138,58],[-148,60],[-160,57],[-167,60],[-167,66]],
  [[-50,82],[-25,82],[-22,78],[-32,68],[-42,60],[-52,62],[-55,72],[-50,82]],
  [[-24,66.5],[-18,66.5],[-15,64],[-22,63.5],[-24,66.5]],
  [[-100,18],[-87,21],[-83,16],[-77,9],[-83,8],[-92,14],[-100,18]],
  [[-77,12],[-66,11],[-58,9],[-50,5],[-35,-6],[-34,-15],[-40,-25],[-50,-30],[-58,-36],[-65,-40],[-68,-50],[-72,-54],[-74,-50],[-73,-42],[-75,-33],[-72,-20],[-77,-8],[-80,-2],[-78,5],[-77,12]],
  [[-8,55],[-3,58],[2,55],[1,51],[-5,50],[-8,52],[-8,55]],
  [[-10,54],[-6,55],[-6,52],[-10,52],[-10,54]],
  [[-10,36],[-5,36],[3,43],[9,44],[12,38],[18,40],[25,35],[28,36],[27,40],[30,46],[35,46],[40,49],[43,55],[35,58],[28,60],[24,65],[22,69],[15,68],[10,63],[5,58],[3,52],[-3,48],[-5,43],[-10,42],[-10,36]],
  [[20,62],[35,60],[45,58],[60,57],[75,57],[95,57],[115,57],[135,57],[155,60],[170,67],[178,68],[178,78],[160,80],[120,80],[80,82],[50,82],[30,78],[22,70],[20,62]],
  [[-17,15],[-14,22],[-10,30],[-2,36],[10,33],[20,32],[32,32],[37,31],[40,22],[46,17],[52,12],[51,4],[44,-2],[42,-10],[40,-15],[38,-22],[33,-30],[24,-34],[18,-34],[14,-25],[10,-12],[8,-2],[7,5],[0,5],[-7,5],[-11,7],[-17,15]],
  [[43,-12],[51,-15],[51,-25],[44,-25],[43,-12]],
  [[35,30],[38,24],[44,18],[53,18],[56,24],[52,28],[44,30],[35,30]],
  [[66,24],[72,28],[78,32],[85,28],[90,25],[92,21],[87,15],[80,8],[76,9],[72,18],[68,22],[66,24]],
  [[75,40],[85,45],[100,50],[120,52],[135,49],[135,42],[130,38],[126,34],[120,30],[118,24],[110,21],[100,22],[95,27],[90,30],[80,32],[75,40]],
  [[95,22],[100,22],[107,18],[110,12],[108,8],[100,8],[97,12],[97,18],[95,22]],
  [[95,5],[102,5],[108,1],[120,-1],[133,-3],[140,-3],[140,-8],[125,-9],[110,-7],[100,-3],[97,2],[95,5]],
  [[109,4],[118,4],[119,-3],[110,-4],[109,4]],
  [[131,-1],[141,-3],[150,-6],[151,-10],[140,-10],[133,-8],[131,-1]],
  [[119,18],[123,18],[126,9],[124,5],[120,6],[119,12],[119,18]],
  [[130,30],[135,33],[141,40],[145,45],[144,44],[140,40],[134,33],[130,30]],
  [[113,-22],[122,-17],[130,-12],[137,-13],[143,-13],[148,-19],[153,-26],[152,-32],[148,-37],[140,-39],[125,-34],[115,-32],[113,-22]],
  [[145,-40],[148,-40],[148,-43],[145,-43],[145,-40]],
  [[166,-37],[175,-39],[178,-46],[170,-47],[166,-44],[166,-37]],
];

function pointInPolygon(lon: number, lat: number, poly: Array<[number, number]>) {
  let inside = false;
  for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
    const [xi, yi] = poly[i];
    const [xj, yj] = poly[j];
    const intersect =
      yi > lat !== yj > lat && lon < ((xj - xi) * (lat - yi)) / (yj - yi + 1e-9) + xi;
    if (intersect) inside = !inside;
  }
  return inside;
}

// Build landmass dot grid once at build time. 120×60 cells → ~7200 candidates,
// ~25% pass the in-continent test, so ~1700 dots in the final SVG.
const COLS = 120;
const ROWS = 60;
const cellW = VIEW_W / COLS;
const cellH = VIEW_H / ROWS;
type LandDot = { cx: number; cy: number };
const landDots: LandDot[] = [];
for (let row = 0; row < ROWS; row++) {
  const lat = 90 - (row + 0.5) * (180 / ROWS);
  for (let col = 0; col < COLS; col++) {
    const lon = -180 + (col + 0.5) * (360 / COLS);
    let inside = false;
    for (const poly of CONTINENTS) {
      if (pointInPolygon(lon, lat, poly)) {
        inside = true;
        break;
      }
    }
    if (inside) {
      landDots.push({
        cx: col * cellW + cellW / 2,
        cy: row * cellH + cellH / 2,
      });
    }
  }
}

type ChapterNode = {
  id: string;
  type: 'chapter';
  name: string;
  city: string;
  region: string;
  themes: string[];
  x: number;
  y: number;
  href: string;
  size: number;
};

const chapters = await getOperationalChapters();

const chapterNodes: ChapterNode[] = chapters
  .filter((c) => typeof c.data.lat === 'number' && typeof c.data.long === 'number')
  .map((c) => {
    const themes = (c.data.themeSlugs || []) as string[];
    const weight = c.data.featuredWeight ?? 0;
    const status = c.data.status || 'active';
    const size = status !== 'active' ? 1.35 : weight >= 70 ? 1.85 : 1.6;
    const chapterNodeId = `chapter:${c.id}`;
    return {
      id: chapterNodeId,
      type: 'chapter' as const,
      name: c.data.name,
      city: c.data.city || '',
      region: c.data.region || '',
      themes,
      x: lonToX(c.data.long),
      y: latToY(c.data.lat),
      href: `/chapters/${c.id}`,
      size,
    };
  });

// Mycelial threads are loaded from the public map-state endpoint. Chapters
// remain SSR anchors; public stewards and members are progressively enhanced
// from /map/state.
type Edge = {
  fromId: string;
  toId: string;
  fromX: number;
  fromY: number;
  toX: number;
  toY: number;
  theme: string;
  d: string;
  delay: number;
};
const edges: Edge[] = [];

const themeColor = (slug: string) => THEME_INFO[slug]?.color ?? '#B8E835';

const chapterCount = chapterNodes.length;
const nodeTypeFilters = [
  { id: 'chapter', label: 'Chapters' },
  { id: 'steward', label: 'Stewards' },
  { id: 'member', label: 'Members' },
] as const;
const statsA11y = `World map of ${chapterCount} active chapters, public stewards, and public-safe member nodes.`;
---

<figure class="gp-home-map" aria-labelledby="gp-home-map-title">
  <figcaption id="gp-home-map-title" class="gp-home-map-sr">{statsA11y}</figcaption>

  <div class="gp-home-map-canvas" data-home-map>
    <div class="gp-home-map-topo" aria-hidden="true"></div>

    <svg
      class="gp-home-map-svg"
      viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
      preserveAspectRatio="xMidYMid meet"
      role="group"
      aria-label={statsA11y}
    >
      {/* graticule — subtle lat/long grid */}
      <g class="gp-home-map-graticule" aria-hidden="true">
        {[15, 30, 45, 60, 75, 85].map((y) => (
          <line x1="0" x2={VIEW_W} y1={y} y2={y} />
        ))}
        {[30, 60, 90, 120, 150, 180].map((x) => (
          <line x1={x} x2={x} y1="0" y2={VIEW_H} />
        ))}
      </g>

      {/* world dot landmass */}
      <g class="gp-home-map-world" aria-hidden="true">
        {landDots.map((d) => (
          <circle cx={d.cx} cy={d.cy} r="0.42" />
        ))}
      </g>

      {/* mycelial threads — theme-tinted relationship edges. pathLength
          normalizes every path so the stroke-dash grow-in lands the same
          duration regardless of arc length. */}
      <g class="gp-home-map-threads" aria-hidden="true">
        {edges.map((edge, idx) => {
          const growDelay = (idx % 12) * 0.12;
          return (
            <path
              class="gp-home-map-thread"
              data-from={edge.fromId}
              data-to={edge.toId}
              data-theme={edge.theme}
              d={edge.d}
              pathLength="1"
              stroke={themeColor(edge.theme)}
              style={`--thread-color: ${themeColor(edge.theme)}; --thread-grow-delay: ${growDelay}s; --thread-pulse-delay: ${edge.delay}s; animation-delay: ${growDelay}s, ${edge.delay + 1.6}s;`}
            />
          );
        })}
      </g>
      <g class="gp-home-map-threads" data-home-map-dynamic-threads aria-hidden="true"></g>

      {/* chapter nodes — dark green anchors */}
      <g class="gp-home-map-chapters">
        {chapterNodes.map((c) => (
          <a
            class="gp-home-map-node-link is-chapter"
            href={c.href}
            data-node-id={c.id}
            data-node-type="chapter"
            data-node-name={c.name}
            data-node-role="Chapter"
            data-node-place={c.city || c.region}
            data-node-themes={c.themes.join(' ')}
          >
            <title>{`${c.name}${c.city ? ` · ${c.city}` : ''}`}</title>
            <circle class="gp-home-map-node-halo" cx={c.x} cy={c.y} r={c.size + 2.6} />
            <circle class="gp-home-map-node-ring" cx={c.x} cy={c.y} r={c.size + 0.6} />
            <circle class="gp-home-map-node-dot" cx={c.x} cy={c.y} r={c.size} />
            <circle class="gp-home-map-node-ripple is-ripple-a" cx={c.x} cy={c.y} r="0" />
            <circle class="gp-home-map-node-ripple is-ripple-b" cx={c.x} cy={c.y} r="0" />
          </a>
        ))}
      </g>

      {/* public people nodes — approved submitted stewards/members and
          local-pending nodes injected client-side from /map/state. Empty at
          build time so the map renders and degrades gracefully when the agent
          is unavailable. */}
      <g class="gp-home-map-members" data-home-map-members></g>
    </svg>

    {/* Count-free legend. The homepage should explain node identity without
        surfacing member/steward counts while real participation is still
        growing. */}
    <div class="gp-home-map-legend" aria-hidden="true">
      {nodeTypeFilters.map((type) => (
        <span class={`gp-home-map-legend-item is-${type.id}`}>
          <span class={`gp-home-map-legend-mark is-${type.id}`} aria-hidden="true"></span>
          <span class="gp-home-map-legend-label">{type.label}</span>
        </span>
      ))}
    </div>

    {/* Focus card — populated by inline script on hover/focus */}
    <div class="gp-home-map-focus" data-home-map-focus role="status" aria-live="polite" aria-hidden="true">
      <span class="gp-home-map-focus-role" data-focus-role></span>
      <span class="gp-home-map-focus-name" data-focus-name></span>
      <span class="gp-home-map-focus-meta" data-focus-meta></span>
      <span class="gp-home-map-focus-themes" data-focus-themes></span>
      <span class="gp-home-map-focus-connections" data-focus-connections></span>
    </div>

    <div class="gp-home-map-controls" data-home-map-controls aria-label="Map controls">
      <div class="gp-home-map-filter-panel" data-filter-panel="type" hidden>
        {nodeTypeFilters.map((type) => (
          <button
            type="button"
            class={`gp-home-map-filter-option is-${type.id}`}
            data-type-filter={type.id}
            aria-pressed="true"
          >
            <span class="gp-home-map-filter-marker" aria-hidden="true"></span>
            <span>{type.label}</span>
          </button>
        ))}
      </div>

      <div class="gp-home-map-filter-panel is-themes" data-filter-panel="theme" hidden>
        {mapThemes.map((theme) => (
          <button
            type="button"
            class="gp-home-map-filter-option is-theme"
            data-theme-filter={theme.id}
            aria-pressed="true"
            style={`--theme-color: ${theme.color};`}
          >
            <span class="gp-home-map-filter-marker" aria-hidden="true"></span>
            <span>{theme.label}</span>
          </button>
        ))}
      </div>

      <div class="gp-home-map-filter-tabs">
        <button type="button" data-filter-toggle="theme" aria-expanded="false">Themes</button>
        <button type="button" data-filter-toggle="type" aria-expanded="false">Types</button>
      </div>
    </div>
  </div>

  {/* Theme labels/colors for client-rendered member chips, so the script does
      not need to import the shared map-state module into the browser bundle. */}
  <script type="application/json" data-home-map-theme-info set:html={JSON.stringify(THEME_INFO)}></script>

  {/* Selected-node panel — opens in-flow when a submitted steward/member node is
      activated. Chapter nodes navigate. The owner-edit affordance appears for
      approved submitted nodes only. */}
  <div class="gp-home-map-selected" data-home-map-selected hidden role="region" aria-label="Selected map node">
    <button type="button" class="gp-home-map-selected-close" data-selected-close aria-label="Close selected node">
      <span aria-hidden="true">×</span>
    </button>
    <p class="gp-home-map-selected-kicker" data-selected-kicker>Network node</p>
    <p class="gp-home-map-selected-name" data-selected-name></p>
    <p class="gp-home-map-selected-place" data-selected-place></p>
    <p class="gp-home-map-selected-bioregion" data-selected-bioregion></p>
    <div class="gp-home-map-selected-themes" data-selected-themes></div>
    <p class="gp-home-map-selected-note" data-selected-note></p>
    <p class="gp-home-map-selected-connections" data-selected-connections></p>

    <div class="gp-home-map-update" data-home-map-update hidden>
      <button type="button" class="gp-home-map-update-trigger" data-update-trigger>Update this node</button>

      <form class="gp-home-map-update-form" data-update-form hidden novalidate>
        <label class="gp-home-map-update-field">
          <span>Owner email</span>
          <input type="email" name="email" inputmode="email" autocomplete="email" required placeholder="you@example.org" />
        </label>
        <div class="gp-home-map-update-actions">
          <button type="button" class="gp-home-map-update-cancel" data-update-cancel>Cancel</button>
          <button type="submit" class="gp-home-map-update-submit">Send edit link</button>
        </div>
        <p class="gp-home-map-update-error" data-update-error role="alert"></p>
      </form>

      <p class="gp-home-map-update-success" data-update-success role="status" hidden>
        If this email matches the node owner, we'll send an edit link.
      </p>
    </div>
  </div>

  {/* Find-your-people walkthrough. The visible trigger lives in the homepage
      hero CTA; local pending state is still written only after server accept. */}
  <dialog class="gp-home-map-addnode-dialog" data-home-map-addnode-dialog aria-labelledby="gp-home-map-addnode-title">
    <div class="gp-home-map-addnode-topo" aria-hidden="true"></div>
    <button type="button" class="gp-home-map-addnode-close" data-addnode-close aria-label="Close find-your-people dialog">
      <span aria-hidden="true">×</span>
    </button>

    <form class="gp-home-map-addnode-form" data-home-map-addnode-form novalidate>
      <section class="gp-home-map-addnode-step is-active" data-walkthrough-step="themes">
        <p class="gp-home-map-addnode-kicker">Step · what you care about</p>
        <h2 id="gp-home-map-addnode-title">What are you here to grow?</h2>
        <p class="gp-home-map-addnode-copy">Pick up to four. These choose the color of your threads on the map and find your people.</p>

        <div class="gp-home-map-addnode-theme-options" data-home-map-themes>
          {mapThemes.map((theme) => (
            <button
              type="button"
              class="gp-home-map-addnode-theme"
              data-theme-choice={theme.id}
              aria-pressed="false"
              style={`--theme-color: ${theme.color};`}
            >
              <span class="gp-home-map-addnode-theme-dot" aria-hidden="true"></span>
              <span>{theme.label}</span>
            </button>
          ))}
        </div>

        <p class="gp-home-map-addnode-theme-count" data-home-map-theme-count aria-live="polite">0 / 4 selected</p>
      </section>

      <section class="gp-home-map-addnode-step" data-walkthrough-step="identity" hidden>
        <p class="gp-home-map-addnode-kicker">Step · who & where</p>
        <h2>Drop your pin.</h2>
        <p class="gp-home-map-addnode-copy">Name yourself, place yourself, and add the private email stewards can use only for future edit links.</p>

        <div class="gp-home-map-addnode-grid">
          <label>
            <span>Display name</span>
            <input name="name" autocomplete="name" required placeholder="What should the network call you?" />
          </label>
          <label>
            <span>Private email</span>
            <input name="contact" autocomplete="email" type="email" required placeholder="you@example.org" />
          </label>
        </div>

        <div class="gp-home-map-addnode-location">
          <div class="gp-home-map-addnode-location-head">
            <span>Your place in the world</span>
            <button type="button" data-location-mode-toggle>or type a city ↗</button>
          </div>

          <div class="gp-home-map-addnode-mini-map" data-location-map>
            <div class="gp-home-map-addnode-mini-topo" aria-hidden="true"></div>
            <svg viewBox={`0 0 ${VIEW_W} ${VIEW_H}`} preserveAspectRatio="xMidYMid meet" aria-label="Click a place on the world map">
              <g aria-hidden="true">
                {landDots.map((d) => (
                  <circle cx={d.cx} cy={d.cy} r="0.42" />
                ))}
              </g>
              <circle data-location-pin cx="100" cy="50" r="2.2" hidden />
            </svg>
            <span data-location-map-hint>· click to place ·</span>
          </div>

          <label class="gp-home-map-addnode-city" data-location-text hidden>
            <span>City search</span>
            <input type="text" name="placeQuery" autocomplete="address-level2" placeholder="Berlin, Bogota, Bali..." />
          </label>

          <input type="hidden" name="place" data-location-place />
          <input type="hidden" name="lat" data-location-lat />
          <input type="hidden" name="long" data-location-long />

          <p class="gp-home-map-addnode-location-status" data-location-status>Click anywhere on the map to drop your pin.</p>
        </div>

        <label class="gp-home-map-addnode-note">
          <span>Public profile intro</span>
          <textarea name="publicNote" rows="3" maxlength="280" placeholder="What are you working on with the network?"></textarea>
        </label>
      </section>

      <section class="gp-home-map-addnode-step" data-walkthrough-step="review" hidden>
        <p class="gp-home-map-addnode-kicker">Step · join the network</p>
        <h2>Look right before you take root.</h2>

        <div class="gp-home-map-addnode-preview">
          <span class="gp-home-map-addnode-preview-dot" aria-hidden="true"></span>
          <div>
            <strong data-review-name>You</strong>
            <span data-review-place>Member · —</span>
          </div>
        </div>

        <div class="gp-home-map-addnode-review">
          <div>
            <span>Themes</span>
            <div data-review-themes></div>
            <button type="button" data-edit-step="themes">Edit</button>
          </div>
          <div>
            <span>Profile intro</span>
            <p data-review-note>None yet</p>
            <button type="button" data-edit-step="identity">Edit</button>
          </div>
          <div>
            <span>Private email</span>
            <p>Saved privately for future edit links.</p>
          </div>
        </div>

        <p class="gp-home-map-addnode-mode" data-home-map-mode-copy>In moderated mode, your node appears on your device while stewards review it. Your email stays private and is used only for future edit links.</p>
        <p class="gp-home-map-addnode-status" data-home-map-addnode-status role="status"></p>
      </section>

      <div class="gp-home-map-addnode-footer">
        <button type="button" class="gp-home-map-addnode-back" data-walkthrough-back hidden>← Back</button>
        <button type="button" class="gp-home-map-addnode-next" data-walkthrough-next disabled>Continue →</button>
        <button type="submit" class="gp-home-map-addnode-submit" data-walkthrough-submit hidden>Plant me on the map →</button>
      </div>
    </form>
  </dialog>
</figure>

<script>
  import {
    PENDING_NODE_UPDATED_EVENT,
    loadLocalPendingNodes,
    reconcileLocalPendingNodes,
    saveLocalPendingNode,
  } from '@greenpill-network/shared/map-nodes';

  type DynamicMapNodeType = 'steward' | 'member';

  type DynamicMapNode = {
    key: string;
    sourceId: string;
    type: DynamicMapNodeType;
    name: string;
    place: string;
    chapterSlug: string;
    bioregion: string;
    publicNote: string;
    themes: string[];
    lat: number;
    long: number;
    approved: boolean;
    pending: boolean;
  };

  (() => {
    const root = document.querySelector('[data-home-map]') as HTMLElement | null;
    if (!root) return;
    // root is the canvas (its .is-focused class drives the SVG focus styles).
    // The controls, selected panel, update form, and add-node form live in the
    // surrounding <figure>, so query those from the figure scope, not root.
    const scope: ParentNode = root.closest('.gp-home-map') ?? document;
    // Astro scopes component <style> via a generated attribute. Elements created
    // in JS must carry the same attribute, or the scoped node/chip styles (fill,
    // halo, ring, theme chips) will not apply and nodes render unstyled.
    const astroCidAttr = root.getAttributeNames().find((n) => n.startsWith('data-astro-cid-')) ?? '';
    const applyScope = (el: Element) => { if (astroCidAttr) el.setAttribute(astroCidAttr, ''); };

    // Equirectangular projection — must match the build-time SSR projection
    // (viewBox 0..200 x 0..100) so injected nodes land on the same grid.
    const VIEW_W = 200;
    const VIEW_H = 100;
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const lonToX = (lon: number) => ((lon + 180) / 360) * VIEW_W;
    const latToY = (lat: number) => ((90 - lat) / 180) * VIEW_H;

    const isLocalHost = ['localhost', '127.0.0.1', '0.0.0.0', '::1'].includes(window.location.hostname);
    const agentBaseUrl = isLocalHost ? 'http://127.0.0.1:8787' : 'https://agent.greenpill.network';

    const membersGroup = root.querySelector('[data-home-map-members]') as SVGGElement | null;
    const dynamicThreadsGroup = root.querySelector('[data-home-map-dynamic-threads]') as SVGGElement | null;
    const focusEl = root.querySelector('[data-home-map-focus]') as HTMLElement | null;
    const focusRole = root.querySelector('[data-focus-role]') as HTMLElement | null;
    const focusName = root.querySelector('[data-focus-name]') as HTMLElement | null;
    const focusMeta = root.querySelector('[data-focus-meta]') as HTMLElement | null;
    const focusThemes = root.querySelector('[data-focus-themes]') as HTMLElement | null;
    const focusConnections = root.querySelector('[data-focus-connections]') as HTMLElement | null;

    // Theme labels/colors for member chips, serialized from SSR.
    const themeInfo: Record<string, { label: string; color: string }> = (() => {
      const node = document.querySelector('[data-home-map-theme-info]');
      try {
        return node?.textContent ? JSON.parse(node.textContent) : {};
      } catch {
        return {};
      }
    })();
    const themeLabel = (slug: string) => themeInfo[slug]?.label ?? slug.replace(/-/g, ' ');
    const themeColor = (slug: string) => themeInfo[slug]?.color ?? '#B8E835';
    const clean = (value: unknown) => (typeof value === 'string' ? value.trim() : '');
    const publicBioregion = (value: unknown) => clean(value);

    const typeFilterButtons = Array.from(scope.querySelectorAll('[data-type-filter]')) as HTMLButtonElement[];
    const themeFilterButtons = Array.from(scope.querySelectorAll('[data-theme-filter]')) as HTMLButtonElement[];
    const filterToggleButtons = Array.from(scope.querySelectorAll('[data-filter-toggle]')) as HTMLButtonElement[];
    const filterPanels = Array.from(scope.querySelectorAll('[data-filter-panel]')) as HTMLElement[];
    const activeTypes = new Set(['chapter', 'steward', 'member']);
    const activeThemes = new Set(themeFilterButtons.map((button) => clean(button.dataset.themeFilter)).filter(Boolean));
    const allThemeCount = activeThemes.size;
    let openFilterPanel = '';
    let applyMapFilters = () => {};

    const filterTypeFor = (value: unknown): 'chapter' | 'steward' | 'member' => {
      const type = clean(value).toLowerCase();
      if (type === 'chapter') return 'chapter';
      if (type === 'steward') return 'steward';
      return 'member';
    };

    const nodeThemes = (node: Element): string[] => (
      clean((node as HTMLElement).dataset.nodeThemes || node.getAttribute('data-node-themes'))
        .split(/\s+/)
        .filter(Boolean)
    );

    const themeIsActive = (theme: string) => (
      !allThemeCount || activeThemes.size === allThemeCount || activeThemes.has(theme)
    );

    const toFiniteNumber = (value: unknown) => {
      const num = typeof value === 'number' ? value : Number(value);
      return Number.isFinite(num) ? num : null;
    };

    const seedForEdge = (value: string) => Array.from(value).reduce((acc, char) => (
      ((acc * 31) + char.charCodeAt(0)) % 100000
    ), 17);

    const edgeRand = (seed: number) => {
      let state = seed || 1;
      return () => {
        state = (state * 9301 + 49297) % 233280;
        return state / 233280;
      };
    };

    const buildMycelialPath = (
      a: { x: number; y: number },
      b: { x: number; y: number },
      seed: number
    ) => {
      const dx = b.x - a.x;
      const dy = b.y - a.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 0.1) return `M ${a.x.toFixed(2)} ${a.y.toFixed(2)}`;
      const rand = edgeRand(seed);
      const nx = -dy / dist;
      const ny = dx / dist;
      const segments = Math.max(4, Math.min(12, Math.round(dist / 9)));
      const points: Array<[number, number]> = [];
      for (let i = 0; i <= segments; i += 1) {
        const t = i / segments;
        const taper = Math.sin(t * Math.PI);
        const wobble = (rand() - 0.5) * Math.min(8, dist * 0.16) * taper;
        points.push([
          a.x + dx * t + nx * wobble,
          a.y + dy * t + ny * wobble,
        ]);
      }

      let d = `M ${points[0][0].toFixed(2)} ${points[0][1].toFixed(2)}`;
      for (let i = 0; i < points.length - 1; i += 1) {
        const p0 = points[Math.max(0, i - 1)];
        const p1 = points[i];
        const p2 = points[i + 1];
        const p3 = points[Math.min(points.length - 1, i + 2)];
        const k = 0.2;
        const c1x = p1[0] + (p2[0] - p0[0]) * k;
        const c1y = p1[1] + (p2[1] - p0[1]) * k;
        const c2x = p2[0] - (p3[0] - p1[0]) * k;
        const c2y = p2[1] - (p3[1] - p1[1]) * k;
        d += ` C ${c1x.toFixed(2)} ${c1y.toFixed(2)} ${c2x.toFixed(2)} ${c2y.toFixed(2)} ${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;
      }
      return d;
    };

    // ---- Hover / focus card (lightweight, pointer-events:none) -------------
    const clearFocus = () => {
      root.classList.remove('is-focused');
      root.querySelectorAll('.gp-home-map-thread').forEach((t) => t.classList.remove('is-adj', 'is-dim'));
      root.querySelectorAll('.gp-home-map-node-link').forEach((l) => l.classList.remove('is-adj', 'is-dim'));
      if (focusEl) focusEl.setAttribute('aria-hidden', 'true');
    };

    const relationshipSummary = (nodeId: string) => {
      let chapterConnections = 0;
      let stewardConnections = 0;
      let memberConnections = 0;
      root.querySelectorAll<SVGPathElement>('.gp-home-map-thread').forEach((thread) => {
        const from = thread.getAttribute('data-from');
        const to = thread.getAttribute('data-to');
        if (from !== nodeId && to !== nodeId) return;
        const adjacentId = from === nodeId ? to : from;
        if (!adjacentId) return;
        const adjacent = root.querySelector(`[data-node-id="${CSS.escape(adjacentId)}"]`);
        if (!adjacent) return;
        const adjacentType = filterTypeFor(adjacent.getAttribute('data-node-type'));
        if (adjacentType === 'chapter') chapterConnections += 1;
        if (adjacentType === 'steward') stewardConnections += 1;
        if (adjacentType === 'member') memberConnections += 1;
      });
      const pieces = [];
      if (chapterConnections) pieces.push(`${chapterConnections} chapter${chapterConnections === 1 ? '' : 's'}`);
      if (stewardConnections) pieces.push(`${stewardConnections} steward${stewardConnections === 1 ? '' : 's'}`);
      if (memberConnections) pieces.push(`${memberConnections} member${memberConnections === 1 ? '' : 's'}`);
      return pieces.length ? `Connected to ${pieces.join(' · ')}` : 'No public connections yet';
    };

    const setFocus = (target: Element) => {
      const id = target.getAttribute('data-node-id');
      const type = target.getAttribute('data-node-type');
      if (!id || !type) return;

      root.classList.add('is-focused');

      const adjacentIds = new Set<string>([id]);
      root.querySelectorAll<SVGPathElement>('.gp-home-map-thread').forEach((t) => {
        const from = t.getAttribute('data-from');
        const to = t.getAttribute('data-to');
        if (from === id || to === id) {
          t.classList.add('is-adj');
          t.classList.remove('is-dim');
          if (from && from !== id) adjacentIds.add(from);
          if (to && to !== id) adjacentIds.add(to);
        } else {
          t.classList.remove('is-adj');
          t.classList.add('is-dim');
        }
      });

      root.querySelectorAll('.gp-home-map-node-link').forEach((l) => {
        const lid = l.getAttribute('data-node-id');
        if (!lid) return;
        l.classList.toggle('is-adj', adjacentIds.has(lid));
        l.classList.toggle('is-dim', !adjacentIds.has(lid));
      });

      if (focusEl && focusRole && focusName && focusMeta) {
        const raw = target.querySelector('title')?.textContent || '';
        const parts = raw.split('·').map((s) => s.trim());
        const targetEl = target as HTMLElement;
        focusName.textContent = clean(targetEl.dataset.nodeName) || parts[0] || '';
        const focusType = filterTypeFor(type);
        const roleLabel = clean(targetEl.dataset.nodeRole) || focusType.charAt(0).toUpperCase() + focusType.slice(1);
        const placeLabel = clean(targetEl.dataset.nodePlace) || parts.slice(1).join(' · ');
        focusRole.textContent = placeLabel ? `${roleLabel} · ${placeLabel}` : roleLabel;
        const bioregion = publicBioregion(targetEl.dataset.nodeBioregion);
        const note = clean(targetEl.dataset.nodePublicNote);
        focusMeta.textContent = focusType === 'chapter'
          ? ''
          : bioregion && note
            ? `${bioregion} · ${note}`
            : bioregion || note;
        if (focusThemes) {
          focusThemes.textContent = '';
          nodeThemes(target).slice(0, 4).forEach((slug) => {
            const chip = document.createElement('span');
            applyScope(chip);
            chip.textContent = themeLabel(slug);
            chip.style.setProperty('--chip-color', themeColor(slug));
            focusThemes.append(chip);
          });
        }
        if (focusConnections) {
          focusConnections.textContent = relationshipSummary(id);
        }
        const dot = target.querySelector('.gp-home-map-node-dot') as SVGCircleElement | null;
        const cx = Number(dot?.getAttribute('cx'));
        const cy = Number(dot?.getAttribute('cy'));
        if (Number.isFinite(cx) && Number.isFinite(cy)) {
          const xPct = (cx / VIEW_W) * 100;
          const yPct = (cy / VIEW_H) * 100;
          focusEl.style.left = `${xPct}%`;
          focusEl.style.top = `${yPct}%`;
          focusEl.style.transform = `translate(${xPct < 60 ? '22px' : 'calc(-100% - 22px)'}, ${yPct < 50 ? '22px' : 'calc(-100% - 22px)'})`;
        }
        focusEl.dataset.nodeType = focusType;
        focusEl.setAttribute('aria-hidden', 'false');
      }
    };

    // SVG hit targets can be visually small. Track the nearest visible node
    // from the map surface as well so chapter focus cards appear where users
    // expect them, even when the pointer lands just outside the painted dot.
    let pointerFocusTarget: Element | null = null;
    const svgEl = root.querySelector('.gp-home-map-svg') as SVGSVGElement | null;
    const nodeAtPointer = (event: PointerEvent): Element | null => {
      if (!svgEl) return null;
      const rect = svgEl.getBoundingClientRect();
      const scale = Math.min(rect.width / VIEW_W, rect.height / VIEW_H);
      if (!Number.isFinite(scale) || scale <= 0) return null;
      const offsetX = (rect.width - VIEW_W * scale) / 2;
      const offsetY = (rect.height - VIEW_H * scale) / 2;
      const x = (event.clientX - rect.left - offsetX) / scale;
      const y = (event.clientY - rect.top - offsetY) / scale;
      if (x < 0 || x > VIEW_W || y < 0 || y > VIEW_H) return null;

      let nearest: { node: Element; distance: number } | null = null;
      root.querySelectorAll('.gp-home-map-node-link:not(.is-filtered-out)').forEach((node) => {
        const dot = node.querySelector('.gp-home-map-node-dot') as SVGCircleElement | null;
        const cx = Number(dot?.getAttribute('cx'));
        const cy = Number(dot?.getAttribute('cy'));
        const r = Number(dot?.getAttribute('r')) || 1.4;
        if (!Number.isFinite(cx) || !Number.isFinite(cy)) return;
        const distance = Math.hypot(x - cx, y - cy);
        const hitRadius = Math.max(3.8, r + 3.2);
        if (distance > hitRadius) return;
        if (!nearest || distance < nearest.distance) nearest = { node, distance };
      });
      return nearest?.node ?? null;
    };

    root.addEventListener('pointermove', (event) => {
      const target = nodeAtPointer(event);
      if (!target) {
        if (pointerFocusTarget) {
          pointerFocusTarget = null;
          clearFocus();
        }
        return;
      }
      if (target === pointerFocusTarget) return;
      pointerFocusTarget = target;
      setFocus(target);
    });

    // ---- Selected-node panel + owner edit-link request ---------------------
    const selectedEl = scope.querySelector('[data-home-map-selected]') as HTMLElement | null;
    const selectedKicker = scope.querySelector('[data-selected-kicker]') as HTMLElement | null;
    const selectedName = scope.querySelector('[data-selected-name]') as HTMLElement | null;
    const selectedPlace = scope.querySelector('[data-selected-place]') as HTMLElement | null;
    const selectedBioregion = scope.querySelector('[data-selected-bioregion]') as HTMLElement | null;
    const selectedThemesEl = scope.querySelector('[data-selected-themes]') as HTMLElement | null;
    const selectedNote = scope.querySelector('[data-selected-note]') as HTMLElement | null;
    const selectedConnections = scope.querySelector('[data-selected-connections]') as HTMLElement | null;
    const selectedClose = scope.querySelector('[data-selected-close]') as HTMLButtonElement | null;
    const updateWrap = scope.querySelector('[data-home-map-update]') as HTMLElement | null;
    const updateTrigger = scope.querySelector('[data-update-trigger]') as HTMLButtonElement | null;
    const updateForm = scope.querySelector('[data-update-form]') as HTMLFormElement | null;
    const updateCancel = scope.querySelector('[data-update-cancel]') as HTMLButtonElement | null;
    const updateError = scope.querySelector('[data-update-error]') as HTMLElement | null;
    const updateSuccess = scope.querySelector('[data-update-success]') as HTMLElement | null;
    const updateEmail = updateForm?.elements.namedItem('email') as HTMLInputElement | null;

    let activeSourceId = '';

    const resetUpdateState = () => {
      activeSourceId = '';
      if (updateForm) {
        updateForm.hidden = true;
        if (updateEmail) updateEmail.value = '';
      }
      if (updateError) updateError.textContent = '';
      if (updateSuccess) updateSuccess.hidden = true;
      if (updateTrigger) updateTrigger.hidden = false;
    };

    const closeSelected = () => {
      if (selectedEl) selectedEl.hidden = true;
      resetUpdateState();
      root.querySelectorAll('.gp-home-map-node-link.is-selected').forEach((l) => l.classList.remove('is-selected'));
    };

    const openSelected = (member: DynamicMapNode, link: Element) => {
      if (!selectedEl) return;
      resetUpdateState();
      root.querySelectorAll('.gp-home-map-node-link.is-selected').forEach((l) => l.classList.remove('is-selected'));
      link.classList.add('is-selected');

      if (selectedKicker) {
        const typeLabel = member.type.charAt(0).toUpperCase() + member.type.slice(1);
        selectedKicker.textContent = member.pending ? `Pending ${member.type} node` : `${typeLabel} node`;
      }
      if (selectedName) selectedName.textContent = member.name;
      if (selectedPlace) selectedPlace.textContent = member.place;
      if (selectedBioregion) {
        const bioregion = publicBioregion(member.bioregion);
        selectedBioregion.textContent = bioregion;
        selectedBioregion.hidden = !bioregion;
      }
      if (selectedThemesEl) {
        selectedThemesEl.textContent = '';
        member.themes.slice(0, 4).forEach((slug) => {
          const chip = document.createElement('span');
          applyScope(chip);
          chip.textContent = themeLabel(slug);
          chip.style.setProperty('--chip-color', themeColor(slug));
          selectedThemesEl.append(chip);
        });
      }
      if (selectedNote) {
        selectedNote.textContent = member.publicNote;
        selectedNote.hidden = !member.publicNote;
      }
      if (selectedConnections) selectedConnections.textContent = relationshipSummary(member.key);

      // Owner edit-link is offered for approved submitted nodes only.
      if (updateWrap) updateWrap.hidden = !member.approved;
      activeSourceId = member.approved ? member.sourceId : '';

      selectedEl.hidden = false;
      selectedEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };

    // ---- Embedded map filters ---------------------------------------------
    const setFilterPanel = (panelName: string) => {
      openFilterPanel = openFilterPanel === panelName ? '' : panelName;
      filterPanels.forEach((panel) => {
        panel.hidden = panel.dataset.filterPanel !== openFilterPanel;
      });
      filterToggleButtons.forEach((button) => {
        const expanded = button.dataset.filterToggle === openFilterPanel;
        button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        button.classList.toggle('is-active', expanded);
      });
    };

    const nodeMatchesFilters = (node: Element) => {
      const type = filterTypeFor(node.getAttribute('data-node-type'));
      if (!activeTypes.has(type)) return false;
      if (!allThemeCount || activeThemes.size === allThemeCount) return true;
      return nodeThemes(node).some((theme) => activeThemes.has(theme));
    };

    const setNodeVisibility = (node: Element, visible: boolean) => {
      node.classList.toggle('is-filtered-out', !visible);
      node.setAttribute('aria-hidden', visible ? 'false' : 'true');
      const type = filterTypeFor(node.getAttribute('data-node-type'));
      if (!visible) {
        node.setAttribute('tabindex', '-1');
      } else if (type === 'chapter') {
        node.removeAttribute('tabindex');
      } else {
        node.setAttribute('tabindex', '0');
      }
    };

    applyMapFilters = () => {
      const visibleNodeIds = new Set<string>();
      root.querySelectorAll('.gp-home-map-node-link').forEach((node) => {
        const visible = nodeMatchesFilters(node);
        setNodeVisibility(node, visible);
        const id = node.getAttribute('data-node-id');
        if (visible && id) visibleNodeIds.add(id);
      });

      root.querySelectorAll<SVGPathElement>('.gp-home-map-thread').forEach((thread) => {
        const from = thread.getAttribute('data-from') || '';
        const to = thread.getAttribute('data-to') || '';
        const theme = thread.getAttribute('data-theme') || '';
        const visible = visibleNodeIds.has(from) && visibleNodeIds.has(to) && themeIsActive(theme);
        thread.classList.toggle('is-filtered-out', !visible);
      });

      const selectedNode = root.querySelector('.gp-home-map-node-link.is-selected');
      if (selectedNode?.classList.contains('is-filtered-out')) closeSelected();
      const focusedNode = root.querySelector('.gp-home-map-node-link.is-adj.is-filtered-out');
      if (focusedNode) clearFocus();
    };

    filterToggleButtons.forEach((button) => {
      button.addEventListener('click', () => setFilterPanel(button.dataset.filterToggle || ''));
    });

    typeFilterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const type = filterTypeFor(button.dataset.typeFilter);
        if (activeTypes.has(type)) activeTypes.delete(type);
        else activeTypes.add(type);
        button.setAttribute('aria-pressed', activeTypes.has(type) ? 'true' : 'false');
        applyMapFilters();
      });
    });

    themeFilterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const theme = clean(button.dataset.themeFilter);
        if (!theme) return;
        if (activeThemes.has(theme)) activeThemes.delete(theme);
        else activeThemes.add(theme);
        button.setAttribute('aria-pressed', activeThemes.has(theme) ? 'true' : 'false');
        applyMapFilters();
      });
    });

    // Fire-and-forget. The public response is intentionally neutral, so the UI
    // shows the same copy whether or not the email/node match — and even if the
    // network request fails — to avoid leaking ownership signal.
    const requestEditLink = (sourceId: string, email: string) => {
      if (!sourceId) return;
      void fetch(`${agentBaseUrl}/map-nodes/${encodeURIComponent(sourceId)}/edit-link`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      }).catch(() => {});
    };

    updateTrigger?.addEventListener('click', () => {
      if (!updateForm) return;
      updateTrigger.hidden = true;
      updateForm.hidden = false;
      if (updateError) updateError.textContent = '';
      updateEmail?.focus();
    });

    updateCancel?.addEventListener('click', () => {
      if (updateForm) updateForm.hidden = true;
      if (updateError) updateError.textContent = '';
      if (updateEmail) updateEmail.value = '';
      if (updateTrigger) updateTrigger.hidden = false;
    });

    updateForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      const email = clean(updateEmail?.value).toLowerCase();
      if (updateEmail) updateEmail.value = email;
      if (!email || !updateEmail?.checkValidity()) {
        if (updateError) updateError.textContent = 'Enter a valid email address.';
        return;
      }

      const sourceId = activeSourceId;
      // Terminal, neutral UI first; clear the input so no email lingers in the DOM.
      updateForm.hidden = true;
      if (updateEmail) updateEmail.value = '';
      if (updateTrigger) updateTrigger.hidden = true;
      if (updateError) updateError.textContent = '';
      if (updateSuccess) updateSuccess.hidden = false;

      requestEditLink(sourceId, email);
    });

    selectedClose?.addEventListener('click', closeSelected);
    // Escape closes the selected-node panel from anywhere (keyboard + a11y).
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && selectedEl && !selectedEl.hidden) {
        closeSelected();
      }
    });

    // ---- Public person node injection --------------------------------------
    const injectedKeys = new Set<string>();
    const memberByKey = new Map<string, DynamicMapNode>();

    const makeCircle = (cls: string, cx: number, cy: number, r: number) => {
      const circle = document.createElementNS(SVG_NS, 'circle');
      circle.setAttribute('class', cls);
      circle.setAttribute('cx', cx.toFixed(2));
      circle.setAttribute('cy', cy.toFixed(2));
      circle.setAttribute('r', String(r));
      applyScope(circle);
      return circle;
    };

    const registerNode = (link: Element) => {
      link.addEventListener('mouseenter', () => setFocus(link));
      link.addEventListener('focus', () => setFocus(link));
      link.addEventListener('mouseleave', clearFocus);
      link.addEventListener('blur', clearFocus);
      const memberKey = (link as HTMLElement).dataset.memberKey;
      if (!memberKey) {
        // Chapter nodes are <a> and navigate on click. Any other static nodes
        // just highlight themselves and their adjacent threads.
        if (!link.hasAttribute('href')) {
          const activate = () => setFocus(link);
          link.addEventListener('click', activate);
          link.addEventListener('keydown', (event) => {
            const key = (event as KeyboardEvent).key;
            if (key === 'Enter' || key === ' ') {
              event.preventDefault();
              activate();
            }
          });
        }
        return;
      }
      const open = () => {
        const member = memberByKey.get(memberKey);
        if (member) openSelected(member, link);
      };
      link.addEventListener('click', open);
      link.addEventListener('keydown', (event) => {
        const key = (event as KeyboardEvent).key;
        if (key === 'Enter' || key === ' ') {
          event.preventDefault();
          open();
        }
      });
    };

    const injectMember = (member: DynamicMapNode) => {
      if (!membersGroup || injectedKeys.has(member.key)) return;
      injectedKeys.add(member.key);
      memberByKey.set(member.key, member);

      const x = lonToX(member.long);
      const y = latToY(member.lat);
      const group = document.createElementNS(SVG_NS, 'g');
      applyScope(group);
      group.setAttribute(
        'class',
        `gp-home-map-node-link is-${member.type}${member.pending ? ' is-pending' : ''}`
      );
      group.setAttribute('tabindex', '0');
      group.setAttribute('role', 'button');
      group.setAttribute('data-node-id', member.key);
      group.setAttribute('data-node-type', member.type);
      group.setAttribute('data-node-name', member.name);
      group.setAttribute(
        'data-node-role',
        member.pending ? `Pending ${member.type}` : member.type.charAt(0).toUpperCase() + member.type.slice(1)
      );
      group.setAttribute('data-node-place', member.place);
      if (member.chapterSlug) group.setAttribute('data-node-chapter-slug', member.chapterSlug);
      group.setAttribute('data-node-bioregion', publicBioregion(member.bioregion));
      group.setAttribute('data-node-public-note', member.publicNote);
      group.setAttribute('data-node-themes', member.themes.join(' '));
      group.dataset.memberKey = member.key;
      const roleWord = member.pending ? `Pending ${member.type} node` : `${member.type} node`;
      group.setAttribute('aria-label', `${member.name}, ${roleWord}${member.place ? `, ${member.place}` : ''}`);

      const title = document.createElementNS(SVG_NS, 'title');
      const titleType = member.type.charAt(0).toUpperCase() + member.type.slice(1);
      title.textContent = `${member.name} · ${titleType}${member.place ? ` · ${member.place}` : ''}`;
      group.append(title);
      const size = member.type === 'steward' ? 2.05 : 1.6;
      group.append(makeCircle('gp-home-map-node-halo', x, y, member.type === 'steward' ? 3.4 : 4));
      group.append(makeCircle('gp-home-map-node-ring', x, y, member.type === 'steward' ? 2 : 2.3));
      group.append(makeCircle('gp-home-map-node-dot', x, y, size));
      group.append(makeCircle('gp-home-map-node-ripple is-ripple-a', x, y, 0));
      group.append(makeCircle('gp-home-map-node-ripple is-ripple-b', x, y, 0));

      membersGroup.append(group);
      registerNode(group);
      applyMapFilters();
    };

    // Reconciliation: once a locally-stored pending node resurfaces as an
    // approved public node, remove the optimistic copy so the map never shows a
    // duplicate. Closes the selected panel if it was open on the removed node.
    const removeInjectedMember = (key: string) => {
      if (!injectedKeys.has(key)) return;
      injectedKeys.delete(key);
      memberByKey.delete(key);
      const node = membersGroup?.querySelector(`[data-node-id="${CSS.escape(key)}"]`);
      if (node) {
        if (node.classList.contains('is-selected')) closeSelected();
        node.remove();
      }
      applyMapFilters();
    };

    const toMember = (
      raw: Record<string, any>,
      kind: 'approved-submission' | 'local-pending'
    ): DynamicMapNode | null => {
      const lat = toFiniteNumber(raw.lat ?? raw.latitude);
      const long = toFiniteNumber(raw.long ?? raw.longitude);
      if (lat === null || long === null) return null;
      const rawType = clean(raw.type || raw.nodeType || raw.role);
      const type = filterTypeFor(rawType);
      if (type === 'chapter') return null;
      const name = clean(raw.name || raw.displayName);
      if (!name) return null;
      const rawId = clean(raw.id) || `${lat},${long}`;
      const sourceId = clean(raw.sourceId || raw.id).replace(/^submission:/, '');
      const themes = Array.isArray(raw.themes) ? raw.themes.map(clean).filter(Boolean) : [];
      const place = clean(raw.place || raw.placeName || raw.city);
      const approved = kind === 'approved-submission';
      return {
        key: approved ? (rawId.startsWith('submission:') ? rawId : `submission:${sourceId}`) : `local:${clean(raw.id) || `${lat},${long}`}`,
        sourceId: approved ? sourceId : '',
        type,
        name,
        place,
        chapterSlug: clean(raw.chapterSlug || raw.chapter_slug),
        bioregion: publicBioregion(raw.bioregion),
        publicNote: clean(raw.publicNote || raw.public_note),
        themes,
        lat,
        long,
        approved,
        pending: kind === 'local-pending',
      };
    };

    const renderDynamicThreads = (
      rawNodes: Array<Record<string, any>>,
      rawEdges: Array<Record<string, any>>
    ) => {
      if (!dynamicThreadsGroup) return;
      dynamicThreadsGroup.textContent = '';
      const nodeById = new Map<string, { x: number; y: number; type: 'chapter' | 'steward' | 'member' }>();
      root.querySelectorAll('.gp-home-map-node-link').forEach((node) => {
        const id = clean(node.getAttribute('data-node-id'));
        const dot = node.querySelector('.gp-home-map-node-dot') as SVGCircleElement | null;
        const x = toFiniteNumber(dot?.getAttribute('cx'));
        const y = toFiniteNumber(dot?.getAttribute('cy'));
        if (!id || x === null || y === null) return;
        nodeById.set(id, { x, y, type: filterTypeFor(node.getAttribute('data-node-type')) });
      });
      rawNodes.forEach((node) => {
        const id = clean(node?.id);
        const lat = toFiniteNumber(node?.lat);
        const long = toFiniteNumber(node?.long);
        const type = filterTypeFor(node?.type);
        if (!id || lat === null || long === null) return;
        nodeById.set(id, { x: lonToX(long), y: latToY(lat), type });
      });

      rawEdges.forEach((edge, idx) => {
        const from = clean(edge?.from);
        const to = clean(edge?.to);
        const a = nodeById.get(from);
        const b = nodeById.get(to);
        if (!from || !to || !a || !b) return;

        const theme = clean(edge?.theme);
        const color = themeColor(theme);
        const path = document.createElementNS(SVG_NS, 'path');
        applyScope(path);
        path.setAttribute('class', 'gp-home-map-thread');
        path.setAttribute('data-from', from);
        path.setAttribute('data-to', to);
        path.setAttribute('data-theme', theme);
        path.setAttribute('d', buildMycelialPath(a, b, seedForEdge(`${from}:${to}:${theme}`)));
        path.setAttribute('pathLength', '1');
        path.setAttribute('stroke', color);
        const growDelay = (idx % 12) * 0.12;
        const pulseDelay = (idx % 9) * 0.45;
        path.setAttribute(
          'style',
          `--thread-color: ${color}; --thread-grow-delay: ${growDelay}s; --thread-pulse-delay: ${pulseDelay}s; animation-delay: ${growDelay}s, ${pulseDelay + 1.6}s;`
        );
        dynamicThreadsGroup.append(path);
      });
      applyMapFilters();
    };

    const renderLocalPending = () => {
      loadLocalPendingNodes(window.localStorage).forEach((node) => {
        const member = toMember(node as Record<string, any>, 'local-pending');
        if (member) injectMember(member);
      });
    };

    // ---- Add-node intake mode copy -----------------------------------------
    const modeCopyEl = scope.querySelector('[data-home-map-mode-copy]') as HTMLElement | null;
    const setModeCopy = (mode: string) => {
      if (!modeCopyEl) return;
      modeCopyEl.textContent = mode === 'live'
        ? 'Live onboarding is on — your node appears on the public map right after you submit, and the map keeps refreshing as others join. Your email stays private and is used only for future edit links.'
        : 'In moderated mode, your node appears on your device while stewards review it. Your email stays private and is used only for future edit links.';
    };

    let intakeMode: 'moderated' | 'live' = 'moderated';

    // ---- /map/state fetch + live growth ------------------------------------
    // Fetched on load, again after every successful submit, and — while live
    // onboarding is on — on a gentle visible-page poll so already-open browsers
    // watch the relationship web grow as more people join.
    const POLL_INTERVAL_MS = 2000;
    let pollTimer: number | null = null;

    const stopPolling = () => {
      if (pollTimer !== null) {
        window.clearInterval(pollTimer);
        pollTimer = null;
      }
    };

    const startPolling = () => {
      if (pollTimer !== null || intakeMode !== 'live') return;
      pollTimer = window.setInterval(() => {
        if (document.visibilityState === 'visible') void loadMapState();
      }, POLL_INTERVAL_MS);
    };

    const loadMapState = async () => {
      try {
        const response = await fetch(`${agentBaseUrl}/map/state`, { cache: 'no-store' });
        if (!response.ok) return;
        const state = await response.json();
        intakeMode = state?.intakeMode === 'live' ? 'live' : 'moderated';
        setModeCopy(intakeMode);

        const nodes = Array.isArray(state?.nodes) ? state.nodes : [];
        const approved = nodes.filter(
          (node: Record<string, any>) => node?.source === 'approved-submission'
        );
        approved.forEach((node: Record<string, any>) => {
          const member = toMember(node, 'approved-submission');
          if (member) injectMember(member);
        });

        // Reconcile: drop optimistic local nodes that are now approved server-side
        // so an approved submission never renders twice on the same device.
        const { removed } = reconcileLocalPendingNodes(window.localStorage, approved);
        if (removed.length > 0) {
          removed.forEach((node) => removeInjectedMember(`local:${node.id}`));
          window.dispatchEvent(new Event(PENDING_NODE_UPDATED_EVENT));
        }

        renderDynamicThreads(
          nodes as Array<Record<string, any>>,
          Array.isArray(state?.edges) ? state.edges : []
        );

        if (intakeMode === 'live') startPolling();
        else stopPolling();
      } catch {
        // Agent unavailable: keep the SSR baseline map. No-op.
      }
    };

    // Catch up immediately when a backgrounded tab returns to the foreground.
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible' && intakeMode === 'live') {
        void loadMapState();
      }
    });

    // ---- Find-your-people walkthrough submission ----------------------------
    const addForm = scope.querySelector('[data-home-map-addnode-form]') as HTMLFormElement | null;
    const addStatus = scope.querySelector('[data-home-map-addnode-status]') as HTMLElement | null;
    const addDialog = scope.querySelector('[data-home-map-addnode-dialog]') as HTMLDialogElement | null;
    const addTriggers = Array.from(document.querySelectorAll('[data-home-map-open]')) as HTMLButtonElement[];
    const addClose = scope.querySelector('[data-addnode-close]') as HTMLButtonElement | null;
    const stepEls = Array.from(scope.querySelectorAll('[data-walkthrough-step]')) as HTMLElement[];
    const progressEls = Array.from(scope.querySelectorAll('[data-walkthrough-progress]')) as HTMLElement[];
    const backButton = scope.querySelector('[data-walkthrough-back]') as HTMLButtonElement | null;
    const nextButton = scope.querySelector('[data-walkthrough-next]') as HTMLButtonElement | null;
    const submitButton = scope.querySelector('[data-walkthrough-submit]') as HTMLButtonElement | null;
    const themeChoiceButtons = Array.from(scope.querySelectorAll('[data-theme-choice]')) as HTMLButtonElement[];
    const themeCountEl = scope.querySelector('[data-home-map-theme-count]') as HTMLElement | null;
    const locationMap = scope.querySelector('[data-location-map]') as HTMLElement | null;
    const locationSvg = locationMap?.querySelector('svg') as SVGSVGElement | null;
    const locationPin = scope.querySelector('[data-location-pin]') as SVGCircleElement | null;
    const locationModeToggle = scope.querySelector('[data-location-mode-toggle]') as HTMLButtonElement | null;
    const locationText = scope.querySelector('[data-location-text]') as HTMLElement | null;
    const locationQuery = scope.querySelector('input[name="placeQuery"]') as HTMLInputElement | null;
    const placeInput = scope.querySelector('[data-location-place]') as HTMLInputElement | null;
    const latInput = scope.querySelector('[data-location-lat]') as HTMLInputElement | null;
    const longInput = scope.querySelector('[data-location-long]') as HTMLInputElement | null;
    const locationStatus = scope.querySelector('[data-location-status]') as HTMLElement | null;
    const reviewName = scope.querySelector('[data-review-name]') as HTMLElement | null;
    const reviewPlace = scope.querySelector('[data-review-place]') as HTMLElement | null;
    const reviewThemes = scope.querySelector('[data-review-themes]') as HTMLElement | null;
    const reviewNote = scope.querySelector('[data-review-note]') as HTMLElement | null;
    const editStepButtons = Array.from(scope.querySelectorAll('[data-edit-step]')) as HTMLButtonElement[];

    const MAX_THEME_COUNT = 4;
    const walkthroughSteps = ['themes', 'identity', 'review'];
    const selectedThemes = new Set<string>();
    let currentStep = 0;
    let lastAddTrigger: HTMLElement | null = null;
    let locationMode: 'map' | 'text' = 'map';

    const xToLon = (x: number) => (x / VIEW_W) * 360 - 180;
    const yToLat = (y: number) => 90 - (y / VIEW_H) * 180;
    const placeIndex = [
      ...Array.from(root.querySelectorAll('[data-node-type="chapter"]')).map((node) => {
        const dot = node.querySelector('.gp-home-map-node-dot') as SVGCircleElement | null;
        const x = Number(dot?.getAttribute('cx'));
        const y = Number(dot?.getAttribute('cy'));
        return {
          label: clean((node as HTMLElement).dataset.nodeName) || 'Greenpill chapter',
          lat: yToLat(y),
          long: xToLon(x),
        };
      }).filter((place) => Number.isFinite(place.lat) && Number.isFinite(place.long)),
      { label: 'Lagos', lat: 6.5244, long: 3.3792 },
      { label: 'Berlin', lat: 52.52, long: 13.405 },
      { label: 'Bogota', lat: 4.711, long: -74.0721 },
      { label: 'Bali', lat: -8.3405, long: 115.092 },
      { label: 'Toronto', lat: 43.6532, long: -79.3832 },
      { label: 'New York City', lat: 40.7128, long: -74.006 },
      { label: 'Nairobi', lat: -1.2864, long: 36.8172 },
      { label: 'Cape Town', lat: -33.9249, long: 18.4241 },
      { label: 'Sao Paulo', lat: -23.5505, long: -46.6333 },
      { label: 'Tokyo', lat: 35.6762, long: 139.6503 },
    ];

    const nearestPlace = (lat: number, long: number) => (
      placeIndex
        .map((place) => ({
          ...place,
          distance: Math.hypot(
            place.lat - lat,
            (place.long - long) * Math.cos(((place.lat + lat) / 2) * Math.PI / 180)
          ),
        }))
        .sort((a, b) => a.distance - b.distance)[0]
    );

    const setAddStatus = (message: string, tone: 'idle' | 'success' | 'error' = 'idle') => {
      if (!addStatus) return;
      addStatus.textContent = message;
      if (tone === 'idle') addStatus.removeAttribute('data-tone');
      else addStatus.dataset.tone = tone;
    };

    const createLocalId = () => (
      'randomUUID' in crypto
        ? `local-${crypto.randomUUID()}`
        : `local-${Date.now()}-${Math.round(Math.random() * 1e5)}`
    );

    const selectedThemeIds = () => Array.from(selectedThemes);

    const setLocation = (lat: number, long: number, label: string) => {
      if (!placeInput || !latInput || !longInput) return;
      placeInput.value = label;
      latInput.value = lat.toFixed(6);
      longInput.value = long.toFixed(6);
      if (locationStatus) locationStatus.textContent = `Pinning near ${label}`;
      if (locationPin) {
        locationPin.setAttribute('cx', lonToX(long).toFixed(2));
        locationPin.setAttribute('cy', latToY(lat).toFixed(2));
        locationPin.hidden = false;
      }
      syncWalkthroughState();
    };

    const syncReview = () => {
      if (!addForm) return;
      const data = new FormData(addForm);
      const name = clean(data.get('name')) || 'You';
      const place = clean(data.get('place'));
      const publicNote = clean(data.get('publicNote'));
      if (reviewName) reviewName.textContent = name;
      if (reviewPlace) reviewPlace.textContent = `Member · ${place || '—'}`;
      if (reviewNote) reviewNote.textContent = publicNote || 'None yet';
      if (reviewThemes) {
        reviewThemes.textContent = '';
        selectedThemeIds().forEach((slug) => {
          const chip = document.createElement('span');
          applyScope(chip);
          chip.textContent = themeLabel(slug);
          chip.style.setProperty('--chip-color', themeColor(slug));
          reviewThemes.append(chip);
        });
      }
    };

    function canAdvanceCurrentStep() {
      if (!addForm) return false;
      if (walkthroughSteps[currentStep] === 'themes') return selectedThemes.size > 0 && selectedThemes.size <= MAX_THEME_COUNT;
      if (walkthroughSteps[currentStep] !== 'identity') return true;
      const data = new FormData(addForm);
      const emailInput = addForm.elements.namedItem('contact') as HTMLInputElement | null;
      return Boolean(
        clean(data.get('name')) &&
        clean(data.get('place')) &&
        toFiniteNumber(data.get('lat')) !== null &&
        toFiniteNumber(data.get('long')) !== null &&
        emailInput?.checkValidity()
      );
    }

    function syncWalkthroughState() {
      const activeStep = walkthroughSteps[currentStep];
      stepEls.forEach((step) => {
        const active = step.dataset.walkthroughStep === activeStep;
        step.hidden = !active;
        step.classList.toggle('is-active', active);
      });
      progressEls.forEach((dot, index) => {
        dot.classList.toggle('is-active', index <= currentStep);
      });
      themeChoiceButtons.forEach((button) => {
        const theme = clean(button.dataset.themeChoice);
        const on = selectedThemes.has(theme);
        button.setAttribute('aria-pressed', on ? 'true' : 'false');
        button.disabled = !on && selectedThemes.size >= MAX_THEME_COUNT;
      });
      if (themeCountEl) themeCountEl.textContent = `${selectedThemes.size} / ${MAX_THEME_COUNT} selected`;
      if (backButton) backButton.hidden = currentStep === 0;
      if (nextButton) {
        nextButton.hidden = currentStep === walkthroughSteps.length - 1;
        nextButton.disabled = !canAdvanceCurrentStep();
        nextButton.textContent = currentStep === walkthroughSteps.length - 2 ? 'Review →' : 'Continue →';
      }
      if (submitButton) submitButton.hidden = currentStep !== walkthroughSteps.length - 1;
      syncReview();
    }

    const setWalkthroughStep = (stepName: string) => {
      const index = walkthroughSteps.indexOf(stepName);
      if (index < 0) return;
      currentStep = index;
      syncWalkthroughState();
      const firstField = stepEls[index]?.querySelector('button, input, textarea') as HTMLElement | null;
      firstField?.focus();
    };

    const resetWalkthrough = () => {
      addForm?.reset();
      selectedThemes.clear();
      currentStep = 0;
      locationMode = 'map';
      if (placeInput) placeInput.value = '';
      if (latInput) latInput.value = '';
      if (longInput) longInput.value = '';
      if (locationPin) locationPin.hidden = true;
      if (locationStatus) locationStatus.textContent = 'Click anywhere on the map to drop your pin.';
      if (locationText) locationText.hidden = true;
      locationMap?.removeAttribute('hidden');
      if (locationModeToggle) locationModeToggle.textContent = 'or type a city ↗';
      setAddStatus('');
      syncWalkthroughState();
    };

    const openAddDialog = (trigger?: HTMLElement) => {
      if (!addDialog) return;
      lastAddTrigger = trigger ?? null;
      resetWalkthrough();
      if (typeof addDialog.showModal === 'function') addDialog.showModal();
      else addDialog.setAttribute('open', '');
      window.requestAnimationFrame(() => {
        const firstField = addDialog.querySelector('[data-theme-choice]') as HTMLElement | null;
        firstField?.focus();
      });
    };

    const closeAddDialog = () => {
      if (!addDialog) return;
      if (addDialog.open && typeof addDialog.close === 'function') addDialog.close();
      else addDialog.removeAttribute('open');
    };

    addTriggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        openAddDialog(trigger);
      });
    });
    addClose?.addEventListener('click', closeAddDialog);
    addDialog?.addEventListener('close', () => lastAddTrigger?.focus());
    addDialog?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeAddDialog();
    });
    const closeAddDialogOnEscape = (event: KeyboardEvent) => {
      if (!addDialog?.open) return;
      if (event.key !== 'Escape' && event.key !== 'Esc' && event.code !== 'Escape') return;
      event.preventDefault();
      closeAddDialog();
    };
    addDialog?.addEventListener('keydown', closeAddDialogOnEscape);
    window.addEventListener('keydown', closeAddDialogOnEscape, true);
    addDialog?.addEventListener('click', (event) => {
      if (event.target === addDialog) closeAddDialog();
    });

    themeChoiceButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const theme = clean(button.dataset.themeChoice);
        if (!theme) return;
        if (selectedThemes.has(theme)) selectedThemes.delete(theme);
        else if (selectedThemes.size < MAX_THEME_COUNT) selectedThemes.add(theme);
        syncWalkthroughState();
      });
    });

    nextButton?.addEventListener('click', () => {
      if (!canAdvanceCurrentStep()) return;
      currentStep = Math.min(walkthroughSteps.length - 1, currentStep + 1);
      syncWalkthroughState();
    });
    backButton?.addEventListener('click', () => {
      currentStep = Math.max(0, currentStep - 1);
      syncWalkthroughState();
    });
    editStepButtons.forEach((button) => {
      button.addEventListener('click', () => setWalkthroughStep(button.dataset.editStep || ''));
    });

    addForm?.addEventListener('input', syncWalkthroughState);
    locationModeToggle?.addEventListener('click', () => {
      locationMode = locationMode === 'map' ? 'text' : 'map';
      const textMode = locationMode === 'text';
      if (locationText) locationText.hidden = !textMode;
      if (locationMap) locationMap.hidden = textMode;
      if (locationModeToggle) locationModeToggle.textContent = textMode ? '← back to map' : 'or type a city ↗';
      if (textMode) locationQuery?.focus();
    });
    locationSvg?.addEventListener('click', (event) => {
      const rect = locationSvg.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * VIEW_W;
      const y = ((event.clientY - rect.top) / rect.height) * VIEW_H;
      const lat = yToLat(y);
      const long = xToLon(x);
      const place = nearestPlace(lat, long);
      setLocation(lat, long, place?.label || 'your place');
    });
    locationQuery?.addEventListener('input', () => {
      const query = clean(locationQuery.value).toLowerCase();
      if (query.length < 2) {
        if (locationStatus) locationStatus.textContent = 'Type at least two letters to match a known city.';
        return;
      }
      const match = placeIndex.find((place) => place.label.toLowerCase().startsWith(query))
        || placeIndex.find((place) => place.label.toLowerCase().includes(query));
      if (!match) {
        if (locationStatus) locationStatus.textContent = 'No match yet — try a major city or chapter.';
        return;
      }
      setLocation(match.lat, match.long, match.label);
    });

    addForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(addForm);
      const name = clean(data.get('name'));
      const place = clean(data.get('place'));
      const lat = toFiniteNumber(data.get('lat'));
      const long = toFiniteNumber(data.get('long'));
      const themes = selectedThemeIds();
      const publicNote = clean(data.get('publicNote'));
      const emailInput = addForm.elements.namedItem('contact') as HTMLInputElement | null;
      const email = clean(data.get('contact')).toLowerCase();
      if (emailInput) emailInput.value = email;

      if (!name || !place || lat === null || long === null || !emailInput?.checkValidity()) {
        setWalkthroughStep('identity');
        setAddStatus('Add a name, place, and valid private email before submitting.', 'error');
        return;
      }
      if (themes.length < 1 || themes.length > MAX_THEME_COUNT) {
        setWalkthroughStep('themes');
        setAddStatus('Pick one to four themes before submitting.', 'error');
        return;
      }

      setAddStatus('Connecting threads...', 'idle');
      if (submitButton) submitButton.disabled = true;
      try {
        const response = await fetch(`${agentBaseUrl}/map-nodes`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            displayName: name,
            placeName: place,
            lat,
            long,
            role: 'member',
            themes,
            publicNote,
            email,
            contactConsent: true,
          }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload?.error?.message || 'Submission failed.');
        }

        const node = payload?.node || payload;
        if (node?.status === 'approved') {
          const member = toMember({ ...node, sourceId: node.id }, 'approved-submission');
          if (member) injectMember(member);
          setAddStatus('Your node is approved and visible on the public map.', 'success');
        } else {
          saveLocalPendingNode(window.localStorage, {
            id: createLocalId(),
            name,
            place,
            lat,
            long,
            role: 'member',
            themes,
            publicNote,
          });
          window.dispatchEvent(new Event(PENDING_NODE_UPDATED_EVENT));
          renderLocalPending();
          setAddStatus('Saved on this device and submitted for steward review.', 'success');
        }
        void loadMapState();
        window.setTimeout(closeAddDialog, 700);
      } catch (error) {
        const message = error instanceof Error && error.name !== 'TypeError'
          ? error.message
          : 'We could not reach the network right now. Please try again.';
        setAddStatus(message, 'error');
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });

    // ---- Init ---------------------------------------------------------------
    root.querySelectorAll('.gp-home-map-node-link').forEach(registerNode);
    root.addEventListener('mouseleave', clearFocus);
    window.addEventListener(PENDING_NODE_UPDATED_EVENT, renderLocalPending);

    applyMapFilters();
    renderLocalPending();
