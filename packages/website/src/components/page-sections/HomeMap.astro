---
import { getOperationalChapters } from '../../lib/operational-content';
import { PUBLIC_MAP_THEMES } from '@greenpill-network/shared/map-state';

// Add-node theme checkboxes use the canonical public theme list.
const mapThemes = PUBLIC_MAP_THEMES;

// Mirrors artifacts/hifi/hifi/map-themes.jsx labels and hues. Slugs match the
// content/themes/*.json files. Edge color carries theme meaning; node fill
// carries node identity (chapter / steward / member).
const THEME_INFO: Record<string, { label: string; color: string }> = {
  trees: { label: 'Trees & Biodiversity', color: '#7BC74D' },
  food: { label: 'Food & Farms', color: '#A8D24A' },
  water: { label: 'Water & Waste', color: '#3FB6A8' },
  energy: { label: 'Clean Energy', color: '#F5CB45' },
  gov: { label: 'Local Governance', color: '#E8B14B' },
  events: { label: 'Local Events', color: '#E89455' },
  funding: { label: 'Grants & Funding', color: '#E07856' },
  currency: { label: 'Community Currency', color: '#D86A4A' },
  mutual: { label: 'Mutual Aid', color: '#D87B97' },
  stories: { label: 'Storytelling', color: '#E0A6B8' },
  education: { label: 'Education', color: '#F0DCA0' },
  opensrc: { label: 'Open Source', color: '#5CC2D9' },
  desci: { label: 'DeSci', color: '#7DAEE0' },
  ai: { label: 'AI & Automation', color: '#9B8FD9' },
  impact: { label: 'Impact Tracking', color: '#86E0B5' },
  public: { label: 'Public Goods', color: '#C9A4E0' },
  'public-goods': { label: 'Public Goods', color: '#C9A4E0' },
  'local-regeneration': { label: 'Local Regeneration', color: '#7BC74D' },
  'knowledge-commons': { label: 'Knowledge Commons', color: '#F0DCA0' },
  'coordination-tools': { label: 'Coordination Tools', color: '#86E0B5' },
};

// Equirectangular projection. viewBox = 0..200 (x) × 0..100 (y).
const VIEW_W = 200;
const VIEW_H = 100;
const lonToX = (lon: number) => ((lon + 180) / 360) * VIEW_W;
const latToY = (lat: number) => ((90 - lat) / 180) * VIEW_H;

// Hand-simplified continent silhouettes, copied from
// artifacts/hifi/hifi/map-world.jsx. Aimed at instantly-recognizable shapes,
// not geodetic accuracy.
const CONTINENTS: Array<Array<[number, number]>> = [
  [[-167,66],[-160,71],[-148,71],[-133,69],[-110,73],[-95,79],[-83,75],[-75,78],[-70,73],[-62,60],[-65,52],[-66,46],[-71,45],[-77,38],[-82,30],[-92,29],[-97,27],[-104,21],[-110,23],[-117,32],[-124,40],[-124,48],[-130,55],[-138,58],[-148,60],[-160,57],[-167,60],[-167,66]],
  [[-50,82],[-25,82],[-22,78],[-32,68],[-42,60],[-52,62],[-55,72],[-50,82]],
  [[-24,66.5],[-18,66.5],[-15,64],[-22,63.5],[-24,66.5]],
  [[-100,18],[-87,21],[-83,16],[-77,9],[-83,8],[-92,14],[-100,18]],
  [[-77,12],[-66,11],[-58,9],[-50,5],[-35,-6],[-34,-15],[-40,-25],[-50,-30],[-58,-36],[-65,-40],[-68,-50],[-72,-54],[-74,-50],[-73,-42],[-75,-33],[-72,-20],[-77,-8],[-80,-2],[-78,5],[-77,12]],
  [[-8,55],[-3,58],[2,55],[1,51],[-5,50],[-8,52],[-8,55]],
  [[-10,54],[-6,55],[-6,52],[-10,52],[-10,54]],
  [[-10,36],[-5,36],[3,43],[9,44],[12,38],[18,40],[25,35],[28,36],[27,40],[30,46],[35,46],[40,49],[43,55],[35,58],[28,60],[24,65],[22,69],[15,68],[10,63],[5,58],[3,52],[-3,48],[-5,43],[-10,42],[-10,36]],
  [[20,62],[35,60],[45,58],[60,57],[75,57],[95,57],[115,57],[135,57],[155,60],[170,67],[178,68],[178,78],[160,80],[120,80],[80,82],[50,82],[30,78],[22,70],[20,62]],
  [[-17,15],[-14,22],[-10,30],[-2,36],[10,33],[20,32],[32,32],[37,31],[40,22],[46,17],[52,12],[51,4],[44,-2],[42,-10],[40,-15],[38,-22],[33,-30],[24,-34],[18,-34],[14,-25],[10,-12],[8,-2],[7,5],[0,5],[-7,5],[-11,7],[-17,15]],
  [[43,-12],[51,-15],[51,-25],[44,-25],[43,-12]],
  [[35,30],[38,24],[44,18],[53,18],[56,24],[52,28],[44,30],[35,30]],
  [[66,24],[72,28],[78,32],[85,28],[90,25],[92,21],[87,15],[80,8],[76,9],[72,18],[68,22],[66,24]],
  [[75,40],[85,45],[100,50],[120,52],[135,49],[135,42],[130,38],[126,34],[120,30],[118,24],[110,21],[100,22],[95,27],[90,30],[80,32],[75,40]],
  [[95,22],[100,22],[107,18],[110,12],[108,8],[100,8],[97,12],[97,18],[95,22]],
  [[95,5],[102,5],[108,1],[120,-1],[133,-3],[140,-3],[140,-8],[125,-9],[110,-7],[100,-3],[97,2],[95,5]],
  [[109,4],[118,4],[119,-3],[110,-4],[109,4]],
  [[131,-1],[141,-3],[150,-6],[151,-10],[140,-10],[133,-8],[131,-1]],
  [[119,18],[123,18],[126,9],[124,5],[120,6],[119,12],[119,18]],
  [[130,30],[135,33],[141,40],[145,45],[144,44],[140,40],[134,33],[130,30]],
  [[113,-22],[122,-17],[130,-12],[137,-13],[143,-13],[148,-19],[153,-26],[152,-32],[148,-37],[140,-39],[125,-34],[115,-32],[113,-22]],
  [[145,-40],[148,-40],[148,-43],[145,-43],[145,-40]],
  [[166,-37],[175,-39],[178,-46],[170,-47],[166,-44],[166,-37]],
];

function pointInPolygon(lon: number, lat: number, poly: Array<[number, number]>) {
  let inside = false;
  for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
    const [xi, yi] = poly[i];
    const [xj, yj] = poly[j];
    const intersect =
      yi > lat !== yj > lat && lon < ((xj - xi) * (lat - yi)) / (yj - yi + 1e-9) + xi;
    if (intersect) inside = !inside;
  }
  return inside;
}

// Build landmass dot grid once at build time. 120×60 cells → ~7200 candidates,
// ~25% pass the in-continent test, so ~1700 dots in the final SVG.
const COLS = 120;
const ROWS = 60;
const cellW = VIEW_W / COLS;
const cellH = VIEW_H / ROWS;
type LandDot = { cx: number; cy: number };
const landDots: LandDot[] = [];
for (let row = 0; row < ROWS; row++) {
  const lat = 90 - (row + 0.5) * (180 / ROWS);
  for (let col = 0; col < COLS; col++) {
    const lon = -180 + (col + 0.5) * (360 / COLS);
    let inside = false;
    for (const poly of CONTINENTS) {
      if (pointInPolygon(lon, lat, poly)) {
        inside = true;
        break;
      }
    }
    if (inside) {
      landDots.push({
        cx: col * cellW + cellW / 2,
        cy: row * cellH + cellH / 2,
      });
    }
  }
}

type ChapterNode = {
  id: string;
  type: 'chapter';
  name: string;
  city: string;
  region: string;
  themes: string[];
  x: number;
  y: number;
  href: string;
  size: number;
};

type StewardNode = {
  id: string;
  type: 'steward';
  name: string;
  role: string;
  chapterId: string;
  chapterName: string;
  themes: string[];
  x: number;
  y: number;
};

type AnyNode = ChapterNode | StewardNode;

const chapters = await getOperationalChapters();

const chapterNodes: ChapterNode[] = chapters
  .filter((c) => typeof c.data.lat === 'number' && typeof c.data.long === 'number')
  .map((c) => {
    const themes = (c.data.themeSlugs || []) as string[];
    const weight = c.data.featuredWeight ?? 0;
    const status = c.data.status || 'active';
    const size = status !== 'active' ? 1.8 : weight >= 70 ? 2.4 : 2.1;
    const chapterNodeId = `chapter:${c.id}`;
    return {
      id: chapterNodeId,
      type: 'chapter' as const,
      name: c.data.name,
      city: c.data.city || '',
      region: c.data.region || '',
      themes,
      x: lonToX(c.data.long),
      y: latToY(c.data.lat),
      href: `/chapters/${c.id}`,
      size,
    };
  });

const stewardNodes: StewardNode[] = [];
for (const c of chapters) {
  if (typeof c.data.lat !== 'number' || typeof c.data.long !== 'number') continue;
  const stewards = (c.data.stewards || []) as Array<Record<string, any>>;
  stewards.forEach((s, i) => {
    if (!s?.name) return;
    // Deterministic small offset so stewards visually sit beside the chapter
    // without overlapping; honest to the real source association.
    const angle = (i + 1) * 1.7;
    const radius = 2.4;
    stewardNodes.push({
      id: `steward-${c.id}-${i}`,
      type: 'steward' as const,
      name: s.name,
      role: s.role || 'Steward',
      chapterId: `chapter:${c.id}`,
      chapterName: c.data.name,
      themes: (c.data.themeSlugs || []) as string[],
      x: lonToX(c.data.long) + Math.cos(angle) * radius,
      y: latToY(c.data.lat) + Math.sin(angle) * radius,
    });
  });
}

const allNodes: AnyNode[] = [...chapterNodes, ...stewardNodes];

// Mycelial threads start with people/stewards. Chapter anchors only receive a
// fallback thread when a sparse data set has no person-to-person relationship
// yet, so the visual model stays centered on members rather than chapters.
type Edge = {
  fromId: string;
  toId: string;
  fromX: number;
  fromY: number;
  toX: number;
  toY: number;
  theme: string;
  d: string;
  delay: number;
};
const edges: Edge[] = [];
const seen = new Set<string>();

const seedForEdge = (value: string) => Array.from(value).reduce((acc, char) => (
  ((acc * 31) + char.charCodeAt(0)) % 100000
), 17);

const edgeRand = (seed: number) => {
  let state = seed || 1;
  return () => {
    state = (state * 9301 + 49297) % 233280;
    return state / 233280;
  };
};

const mycelialPath = (a: { x: number; y: number }, b: { x: number; y: number }, seed: number) => {
  const dx = b.x - a.x;
  const dy = b.y - a.y;
  const dist = Math.sqrt(dx * dx + dy * dy);
  if (dist < 0.1) return `M ${a.x.toFixed(2)} ${a.y.toFixed(2)}`;
  const rand = edgeRand(seed);
  const nx = -dy / dist;
  const ny = dx / dist;
  const segments = Math.max(4, Math.min(12, Math.round(dist / 9)));
  const points: Array<[number, number]> = [];
  for (let i = 0; i <= segments; i++) {
    const t = i / segments;
    const taper = Math.sin(t * Math.PI);
    const wobble = (rand() - 0.5) * Math.min(8, dist * 0.16) * taper;
    points.push([
      a.x + dx * t + nx * wobble,
      a.y + dy * t + ny * wobble,
    ]);
  }

  let d = `M ${points[0][0].toFixed(2)} ${points[0][1].toFixed(2)}`;
  for (let i = 0; i < points.length - 1; i++) {
    const p0 = points[Math.max(0, i - 1)];
    const p1 = points[i];
    const p2 = points[i + 1];
    const p3 = points[Math.min(points.length - 1, i + 2)];
    const k = 0.2;
    const c1x = p1[0] + (p2[0] - p0[0]) * k;
    const c1y = p1[1] + (p2[1] - p0[1]) * k;
    const c2x = p2[0] - (p3[0] - p1[0]) * k;
    const c2y = p2[1] - (p3[1] - p1[1]) * k;
    d += ` C ${c1x.toFixed(2)} ${c1y.toFixed(2)} ${c2x.toFixed(2)} ${c2y.toFixed(2)} ${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;
  }
  return d;
};

const addEdge = (a: AnyNode, b: AnyNode, theme: string) => {
  const key = [a.id, b.id].sort().join(':');
  if (!theme || seen.has(key)) return;
  seen.add(key);
  edges.push({
    fromId: a.id,
    toId: b.id,
    fromX: a.x,
    fromY: a.y,
    toX: b.x,
    toY: b.y,
    theme,
    d: mycelialPath(a, b, seedForEdge(key)),
    delay: (edges.length % 9) * 0.45,
  });
};

for (let i = 0; i < stewardNodes.length; i++) {
  for (let j = i + 1; j < stewardNodes.length; j++) {
    const a = stewardNodes[i];
    const b = stewardNodes[j];
    const shared = a.themes.find((t) => b.themes.includes(t));
    if (shared) addEdge(a, b, shared);
  }
}

for (const steward of stewardNodes) {
  if (edges.some((edge) => edge.fromId === steward.id || edge.toId === steward.id)) continue;
  const chapter = chapterNodes.find((node) => node.id === steward.chapterId);
  const shared = chapter?.themes.find((theme) => steward.themes.includes(theme));
  if (chapter && shared) addEdge(steward, chapter, shared);
}

const themeColor = (slug: string) => THEME_INFO[slug]?.color ?? '#B8E835';
const themeLabel = (slug: string) => THEME_INFO[slug]?.label ?? slug.replace(/-/g, ' ');

// Legend: themes used by visible chapters, sorted by count, plain-language labels.
const themeUsage = new Map<string, number>();
for (const node of chapterNodes) {
  for (const slug of node.themes) {
    if (!THEME_INFO[slug]) continue;
    themeUsage.set(slug, (themeUsage.get(slug) ?? 0) + 1);
  }
}
const legendThemes = Array.from(themeUsage.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([slug, count]) => ({
    slug,
    label: themeLabel(slug),
    color: themeColor(slug),
    count,
  }));

const chapterCount = chapterNodes.length;
const statsA11y = `World map of ${chapterCount} active chapters connected by shared themes.`;
---

<figure class="gp-home-map" aria-labelledby="gp-home-map-title">
  <figcaption id="gp-home-map-title" class="gp-home-map-sr">{statsA11y}</figcaption>

  <div class="gp-home-map-canvas" data-home-map>
    <div class="gp-home-map-topo" aria-hidden="true"></div>

    <svg
      class="gp-home-map-svg"
      viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-label={statsA11y}
    >
      {/* graticule — subtle lat/long grid */}
      <g class="gp-home-map-graticule" aria-hidden="true">
        {[15, 30, 45, 60, 75, 85].map((y) => (
          <line x1="0" x2={VIEW_W} y1={y} y2={y} />
        ))}
        {[30, 60, 90, 120, 150, 180].map((x) => (
          <line x1={x} x2={x} y1="0" y2={VIEW_H} />
        ))}
      </g>

      {/* world dot landmass */}
      <g class="gp-home-map-world" aria-hidden="true">
        {landDots.map((d) => (
          <circle cx={d.cx} cy={d.cy} r="0.42" />
        ))}
      </g>

      {/* mycelial threads — theme-tinted relationship edges. pathLength
          normalizes every path so the stroke-dash grow-in lands the same
          duration regardless of arc length. */}
      <g class="gp-home-map-threads" aria-hidden="true">
        {edges.map((edge, idx) => {
          const growDelay = (idx % 12) * 0.12;
          return (
            <path
              class="gp-home-map-thread"
              data-from={edge.fromId}
              data-to={edge.toId}
              d={edge.d}
              pathLength="1"
              stroke={themeColor(edge.theme)}
              style={`--thread-color: ${themeColor(edge.theme)}; --thread-grow-delay: ${growDelay}s; --thread-pulse-delay: ${edge.delay}s; animation-delay: ${growDelay}s, ${edge.delay + 1.6}s;`}
            />
          );
        })}
      </g>
      <g class="gp-home-map-threads" data-home-map-dynamic-threads aria-hidden="true"></g>

      {/* steward nodes — gold, smaller, sit beside their chapter. Two
          ripple circles render in front and only animate on focus, giving
          the active node a subtle nutrient pulse without idle noise. */}
      <g class="gp-home-map-stewards">
        {stewardNodes.map((s) => (
          <g class="gp-home-map-node-link is-steward" tabindex="0" data-node-id={s.id} data-node-type="steward">
            <title>{`${s.name} · Steward · ${s.chapterName}`}</title>
            <circle class="gp-home-map-node-halo" cx={s.x} cy={s.y} r="2.6" />
            <circle class="gp-home-map-node-dot" cx={s.x} cy={s.y} r="1.2" />
            <circle class="gp-home-map-node-ripple is-ripple-a" cx={s.x} cy={s.y} r="0" />
            <circle class="gp-home-map-node-ripple is-ripple-b" cx={s.x} cy={s.y} r="0" />
          </g>
        ))}
      </g>

      {/* chapter nodes — lime fill + dark ring, anchored */}
      <g class="gp-home-map-chapters">
        {chapterNodes.map((c) => (
          <a
            class="gp-home-map-node-link is-chapter"
            href={c.href}
            data-node-id={c.id}
            data-node-type="chapter"
          >
            <title>{`${c.name}${c.city ? ` · ${c.city}` : ''}`}</title>
            <circle class="gp-home-map-node-halo" cx={c.x} cy={c.y} r={c.size + 2.6} />
            <circle class="gp-home-map-node-ring" cx={c.x} cy={c.y} r={c.size + 0.6} />
            <circle class="gp-home-map-node-dot" cx={c.x} cy={c.y} r={c.size} />
            <circle class="gp-home-map-node-ripple is-ripple-a" cx={c.x} cy={c.y} r="0" />
            <circle class="gp-home-map-node-ripple is-ripple-b" cx={c.x} cy={c.y} r="0" />
          </a>
        ))}
      </g>

      {/* member nodes — approved submitted + local-pending nodes injected
          client-side from /map/state. Empty at build time so the map renders
          and degrades gracefully when the agent is unavailable. */}
      <g class="gp-home-map-members" data-home-map-members></g>
    </svg>

    {/* Integrated stats overlay - top-right inside the map */}
    <div class="gp-home-map-stats" aria-hidden="true">
      <span class="gp-home-map-stat">
        <span class="gp-home-map-stat-mark is-chapter" aria-hidden="true"></span>
        <span class="gp-home-map-stat-value">{chapterCount}</span>
        <span class="gp-home-map-stat-label">chapters</span>
      </span>
    </div>

    {/* Focus card — populated by inline script on hover/focus */}
    <div class="gp-home-map-focus" data-home-map-focus role="status" aria-live="polite" aria-hidden="true">
      <span class="gp-home-map-focus-role" data-focus-role></span>
      <span class="gp-home-map-focus-name" data-focus-name></span>
      <span class="gp-home-map-focus-meta" data-focus-meta></span>
    </div>
  </div>

  {legendThemes.length > 0 && (
    <div class="gp-home-map-legend" role="list" aria-label="Theme legend">
      {legendThemes.map((t) => (
        <span class="gp-home-map-legend-item" role="listitem">
          <span class="gp-home-map-legend-swatch" style={`background: ${t.color};`} aria-hidden="true"></span>
          <span class="gp-home-map-legend-label">{t.label}</span>
        </span>
      ))}
    </div>
  )}

  {/* Theme labels/colors for client-rendered member chips, so the script does
      not need to import the shared map-state module into the browser bundle. */}
  <script type="application/json" data-home-map-theme-info set:html={JSON.stringify(THEME_INFO)}></script>

  {/* Selected-node panel — opens in-flow when a submitted member node is
      activated. Chapter nodes navigate; steward nodes only show the hover
      card. The owner-edit affordance appears for approved nodes only. */}
  <div class="gp-home-map-selected" data-home-map-selected hidden role="region" aria-label="Selected map node">
    <button type="button" class="gp-home-map-selected-close" data-selected-close aria-label="Close selected node">
      <span aria-hidden="true">×</span>
    </button>
    <p class="gp-home-map-selected-kicker" data-selected-kicker>Network node</p>
    <p class="gp-home-map-selected-name" data-selected-name></p>
    <p class="gp-home-map-selected-place" data-selected-place></p>
    <div class="gp-home-map-selected-themes" data-selected-themes></div>

    <div class="gp-home-map-update" data-home-map-update hidden>
      <button type="button" class="gp-home-map-update-trigger" data-update-trigger>Update this node</button>

      <form class="gp-home-map-update-form" data-update-form hidden novalidate>
        <label class="gp-home-map-update-field">
          <span>Owner email</span>
          <input type="email" name="email" inputmode="email" autocomplete="email" required placeholder="you@example.org" />
        </label>
        <div class="gp-home-map-update-actions">
          <button type="button" class="gp-home-map-update-cancel" data-update-cancel>Cancel</button>
          <button type="submit" class="gp-home-map-update-submit">Send edit link</button>
        </div>
        <p class="gp-home-map-update-error" data-update-error role="alert"></p>
      </form>

      <p class="gp-home-map-update-success" data-update-success role="status" hidden>
        If this email matches the node owner, we'll send an edit link.
      </p>
    </div>
  </div>

  {/* Add-node panel — collapsed by default so the hero stays clean. Local
      pending state is only written after the server accepts the submission. */}
  <details class="gp-home-map-addnode" data-home-map-addnode>
    <summary>Add your node</summary>
    <form class="gp-home-map-addnode-form" data-home-map-addnode-form novalidate>
      <div class="gp-home-map-addnode-grid">
        <label>
          <span>Name</span>
          <input name="name" autocomplete="name" required placeholder="Your name or project" />
        </label>
        <label>
          <span>City or place</span>
          <input name="place" autocomplete="address-level2" required placeholder="Lagos, Nigeria" />
        </label>
        <label>
          <span>Latitude</span>
          <input name="lat" inputmode="decimal" required type="number" step="0.000001" min="-90" max="90" placeholder="6.5244" />
        </label>
        <label>
          <span>Longitude</span>
          <input name="long" inputmode="decimal" required type="number" step="0.000001" min="-180" max="180" placeholder="3.3792" />
        </label>
      </div>

      <fieldset class="gp-home-map-addnode-themes">
        <legend>Themes</legend>
        <div class="gp-home-map-addnode-theme-options">
          {mapThemes.map((theme) => (
            <label class="gp-home-map-addnode-theme">
              <input type="checkbox" name="themes" value={theme.id} />
              <span>{theme.label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <label class="gp-home-map-addnode-note">
        <span>Public note</span>
        <textarea name="publicNote" rows="3" maxlength="280" placeholder="What are you working on with the network?"></textarea>
      </label>

      <label class="gp-home-map-addnode-email">
        <span>Private email for future edits</span>
        <input name="contact" autocomplete="email" type="email" required placeholder="you@example.org" />
      </label>

      <div class="gp-home-map-addnode-footer">
        <p class="gp-home-map-addnode-mode" data-home-map-mode-copy>In moderated mode, your node appears on your device while stewards review it. Your email stays private and is used only for future edit links.</p>
        <button type="submit" class="gp-home-map-addnode-submit">Add node</button>
      </div>

      <p class="gp-home-map-addnode-status" data-home-map-addnode-status role="status"></p>
    </form>
  </details>
</figure>

<script>
  import {
    PENDING_NODE_UPDATED_EVENT,
    loadLocalPendingNodes,
    saveLocalPendingNode,
  } from '@greenpill-network/shared/map-nodes';

  type DynamicMapNodeType = 'member' | 'steward' | 'project' | 'place';

  type DynamicMapNode = {
    key: string;
    sourceId: string;
    type: DynamicMapNodeType;
    name: string;
    place: string;
    themes: string[];
    lat: number;
    long: number;
    approved: boolean;
    pending: boolean;
  };

  (() => {
    const root = document.querySelector('[data-home-map]') as HTMLElement | null;
    if (!root) return;
    // root is the canvas (its .is-focused class drives the SVG focus styles).
    // The legend, selected panel, update form, and add-node form live in the
    // surrounding <figure>, so query those from the figure scope, not root.
    const scope: ParentNode = root.closest('.gp-home-map') ?? document;
    // Astro scopes component <style> via a generated attribute. Elements created
    // in JS must carry the same attribute, or the scoped node/chip styles (fill,
    // halo, ring, theme chips) will not apply and nodes render unstyled.
    const astroCidAttr = root.getAttributeNames().find((n) => n.startsWith('data-astro-cid-')) ?? '';
    const applyScope = (el: Element) => { if (astroCidAttr) el.setAttribute(astroCidAttr, ''); };

    // Equirectangular projection — must match the build-time SSR projection
    // (viewBox 0..200 x 0..100) so injected nodes land on the same grid.
    const VIEW_W = 200;
    const VIEW_H = 100;
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const lonToX = (lon: number) => ((lon + 180) / 360) * VIEW_W;
    const latToY = (lat: number) => ((90 - lat) / 180) * VIEW_H;

    const isLocalHost = ['localhost', '127.0.0.1', '0.0.0.0', '::1'].includes(window.location.hostname);
    const agentBaseUrl = isLocalHost ? 'http://127.0.0.1:8787' : 'https://agent.greenpill.network';

    const membersGroup = root.querySelector('[data-home-map-members]') as SVGGElement | null;
    const dynamicThreadsGroup = root.querySelector('[data-home-map-dynamic-threads]') as SVGGElement | null;
    const focusEl = root.querySelector('[data-home-map-focus]') as HTMLElement | null;
    const focusRole = root.querySelector('[data-focus-role]') as HTMLElement | null;
    const focusName = root.querySelector('[data-focus-name]') as HTMLElement | null;
    const focusMeta = root.querySelector('[data-focus-meta]') as HTMLElement | null;

    // Theme labels/colors for member chips, serialized from SSR.
    const themeInfo: Record<string, { label: string; color: string }> = (() => {
      const node = document.querySelector('[data-home-map-theme-info]');
      try {
        return node?.textContent ? JSON.parse(node.textContent) : {};
      } catch {
        return {};
      }
    })();
    const themeLabel = (slug: string) => themeInfo[slug]?.label ?? slug.replace(/-/g, ' ');
    const themeColor = (slug: string) => themeInfo[slug]?.color ?? '#B8E835';

    const clean = (value: unknown) => (typeof value === 'string' ? value.trim() : '');
    const toFiniteNumber = (value: unknown) => {
      const num = typeof value === 'number' ? value : Number(value);
      return Number.isFinite(num) ? num : null;
    };

    const seedForEdge = (value: string) => Array.from(value).reduce((acc, char) => (
      ((acc * 31) + char.charCodeAt(0)) % 100000
    ), 17);

    const edgeRand = (seed: number) => {
      let state = seed || 1;
      return () => {
        state = (state * 9301 + 49297) % 233280;
        return state / 233280;
      };
    };

    const buildMycelialPath = (
      a: { x: number; y: number },
      b: { x: number; y: number },
      seed: number
    ) => {
      const dx = b.x - a.x;
      const dy = b.y - a.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 0.1) return `M ${a.x.toFixed(2)} ${a.y.toFixed(2)}`;
      const rand = edgeRand(seed);
      const nx = -dy / dist;
      const ny = dx / dist;
      const segments = Math.max(4, Math.min(12, Math.round(dist / 9)));
      const points: Array<[number, number]> = [];
      for (let i = 0; i <= segments; i += 1) {
        const t = i / segments;
        const taper = Math.sin(t * Math.PI);
        const wobble = (rand() - 0.5) * Math.min(8, dist * 0.16) * taper;
        points.push([
          a.x + dx * t + nx * wobble,
          a.y + dy * t + ny * wobble,
        ]);
      }

      let d = `M ${points[0][0].toFixed(2)} ${points[0][1].toFixed(2)}`;
      for (let i = 0; i < points.length - 1; i += 1) {
        const p0 = points[Math.max(0, i - 1)];
        const p1 = points[i];
        const p2 = points[i + 1];
        const p3 = points[Math.min(points.length - 1, i + 2)];
        const k = 0.2;
        const c1x = p1[0] + (p2[0] - p0[0]) * k;
        const c1y = p1[1] + (p2[1] - p0[1]) * k;
        const c2x = p2[0] - (p3[0] - p1[0]) * k;
        const c2y = p2[1] - (p3[1] - p1[1]) * k;
        d += ` C ${c1x.toFixed(2)} ${c1y.toFixed(2)} ${c2x.toFixed(2)} ${c2y.toFixed(2)} ${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;
      }
      return d;
    };

    // ---- Hover / focus card (lightweight, pointer-events:none) -------------
    const clearFocus = () => {
      root.classList.remove('is-focused');
      root.querySelectorAll('.gp-home-map-thread').forEach((t) => t.classList.remove('is-adj', 'is-dim'));
      root.querySelectorAll('.gp-home-map-node-link').forEach((l) => l.classList.remove('is-adj', 'is-dim'));
      if (focusEl) focusEl.setAttribute('aria-hidden', 'true');
    };

    const setFocus = (target: Element) => {
      const id = target.getAttribute('data-node-id');
      const type = target.getAttribute('data-node-type');
      if (!id || !type) return;

      root.classList.add('is-focused');

      const adjacentIds = new Set<string>([id]);
      root.querySelectorAll<SVGPathElement>('.gp-home-map-thread').forEach((t) => {
        const from = t.getAttribute('data-from');
        const to = t.getAttribute('data-to');
        if (from === id || to === id) {
          t.classList.add('is-adj');
          t.classList.remove('is-dim');
          if (from && from !== id) adjacentIds.add(from);
          if (to && to !== id) adjacentIds.add(to);
        } else {
          t.classList.remove('is-adj');
          t.classList.add('is-dim');
        }
      });

      root.querySelectorAll('.gp-home-map-node-link').forEach((l) => {
        const lid = l.getAttribute('data-node-id');
        if (!lid) return;
        l.classList.toggle('is-adj', adjacentIds.has(lid));
        l.classList.toggle('is-dim', !adjacentIds.has(lid));
      });

      if (focusEl && focusRole && focusName && focusMeta) {
        const raw = target.querySelector('title')?.textContent || '';
        const parts = raw.split('·').map((s) => s.trim());
        focusName.textContent = parts[0] || '';
        focusRole.textContent = type.charAt(0).toUpperCase() + type.slice(1);
        focusMeta.textContent = parts.slice(1).join(' · ');
        focusEl.setAttribute('aria-hidden', 'false');
      }
    };

    // ---- Selected-node panel + owner edit-link request ---------------------
    const selectedEl = scope.querySelector('[data-home-map-selected]') as HTMLElement | null;
    const selectedKicker = scope.querySelector('[data-selected-kicker]') as HTMLElement | null;
    const selectedName = scope.querySelector('[data-selected-name]') as HTMLElement | null;
    const selectedPlace = scope.querySelector('[data-selected-place]') as HTMLElement | null;
    const selectedThemes = scope.querySelector('[data-selected-themes]') as HTMLElement | null;
    const selectedClose = scope.querySelector('[data-selected-close]') as HTMLButtonElement | null;
    const updateWrap = scope.querySelector('[data-home-map-update]') as HTMLElement | null;
    const updateTrigger = scope.querySelector('[data-update-trigger]') as HTMLButtonElement | null;
    const updateForm = scope.querySelector('[data-update-form]') as HTMLFormElement | null;
    const updateCancel = scope.querySelector('[data-update-cancel]') as HTMLButtonElement | null;
    const updateError = scope.querySelector('[data-update-error]') as HTMLElement | null;
    const updateSuccess = scope.querySelector('[data-update-success]') as HTMLElement | null;
    const updateEmail = updateForm?.elements.namedItem('email') as HTMLInputElement | null;

    let activeSourceId = '';

    const resetUpdateState = () => {
      activeSourceId = '';
      if (updateForm) {
        updateForm.hidden = true;
        if (updateEmail) updateEmail.value = '';
      }
      if (updateError) updateError.textContent = '';
      if (updateSuccess) updateSuccess.hidden = true;
      if (updateTrigger) updateTrigger.hidden = false;
    };

    const closeSelected = () => {
      if (selectedEl) selectedEl.hidden = true;
      resetUpdateState();
      root.querySelectorAll('.gp-home-map-node-link.is-selected').forEach((l) => l.classList.remove('is-selected'));
    };

    const openSelected = (member: DynamicMapNode, link: Element) => {
      if (!selectedEl) return;
      resetUpdateState();
      root.querySelectorAll('.gp-home-map-node-link.is-selected').forEach((l) => l.classList.remove('is-selected'));
      link.classList.add('is-selected');

      if (selectedKicker) {
        const typeLabel = member.type.charAt(0).toUpperCase() + member.type.slice(1);
        selectedKicker.textContent = member.pending ? `Pending ${member.type} node` : `${typeLabel} node`;
      }
      if (selectedName) selectedName.textContent = member.name;
      if (selectedPlace) selectedPlace.textContent = member.place;
      if (selectedThemes) {
        selectedThemes.textContent = '';
        member.themes.slice(0, 4).forEach((slug) => {
          const chip = document.createElement('span');
          applyScope(chip);
          chip.textContent = themeLabel(slug);
          chip.style.setProperty('--chip-color', themeColor(slug));
          selectedThemes.append(chip);
        });
      }

      // Owner edit-link is offered for approved submitted nodes only.
      if (updateWrap) updateWrap.hidden = !member.approved;
      activeSourceId = member.approved ? member.sourceId : '';

      selectedEl.hidden = false;
      selectedEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };

    // Fire-and-forget. The public response is intentionally neutral, so the UI
    // shows the same copy whether or not the email/node match — and even if the
    // network request fails — to avoid leaking ownership signal.
    const requestEditLink = (sourceId: string, email: string) => {
      if (!sourceId) return;
      void fetch(`${agentBaseUrl}/map-nodes/${encodeURIComponent(sourceId)}/edit-link`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      }).catch(() => {});
    };

    updateTrigger?.addEventListener('click', () => {
      if (!updateForm) return;
      updateTrigger.hidden = true;
      updateForm.hidden = false;
      if (updateError) updateError.textContent = '';
      updateEmail?.focus();
    });

    updateCancel?.addEventListener('click', () => {
      if (updateForm) updateForm.hidden = true;
      if (updateError) updateError.textContent = '';
      if (updateEmail) updateEmail.value = '';
      if (updateTrigger) updateTrigger.hidden = false;
    });

    updateForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      const email = clean(updateEmail?.value).toLowerCase();
      if (updateEmail) updateEmail.value = email;
      if (!email || !updateEmail?.checkValidity()) {
        if (updateError) updateError.textContent = 'Enter a valid email address.';
        return;
      }

      const sourceId = activeSourceId;
      // Terminal, neutral UI first; clear the input so no email lingers in the DOM.
      updateForm.hidden = true;
      if (updateEmail) updateEmail.value = '';
      if (updateTrigger) updateTrigger.hidden = true;
      if (updateError) updateError.textContent = '';
      if (updateSuccess) updateSuccess.hidden = false;

      requestEditLink(sourceId, email);
    });

    selectedClose?.addEventListener('click', closeSelected);

    // ---- Member node injection ---------------------------------------------
    const injectedKeys = new Set<string>();
    const memberByKey = new Map<string, DynamicMapNode>();

    const makeCircle = (cls: string, cx: number, cy: number, r: number) => {
      const circle = document.createElementNS(SVG_NS, 'circle');
      circle.setAttribute('class', cls);
      circle.setAttribute('cx', cx.toFixed(2));
      circle.setAttribute('cy', cy.toFixed(2));
      circle.setAttribute('r', String(r));
      applyScope(circle);
      return circle;
    };

    const registerNode = (link: Element) => {
      link.addEventListener('mouseenter', () => setFocus(link));
      link.addEventListener('focus', () => setFocus(link));
      link.addEventListener('mouseleave', clearFocus);
      link.addEventListener('blur', clearFocus);
      if (!(link as HTMLElement).dataset.memberKey) return;
      const open = () => {
        const key = (link as HTMLElement).dataset.memberKey || '';
        const member = memberByKey.get(key);
        if (member) openSelected(member, link);
      };
      link.addEventListener('click', open);
      link.addEventListener('keydown', (event) => {
        const key = (event as KeyboardEvent).key;
        if (key === 'Enter' || key === ' ') {
          event.preventDefault();
          open();
        }
      });
    };

    const injectMember = (member: DynamicMapNode) => {
      if (!membersGroup || injectedKeys.has(member.key)) return;
      injectedKeys.add(member.key);
      memberByKey.set(member.key, member);

      const x = lonToX(member.long);
      const y = latToY(member.lat);
      const group = document.createElementNS(SVG_NS, 'g');
      applyScope(group);
      group.setAttribute(
        'class',
        `gp-home-map-node-link is-${member.type}${member.pending ? ' is-pending' : ''}`
      );
      group.setAttribute('tabindex', '0');
      group.setAttribute('role', 'button');
      group.setAttribute('data-node-id', member.key);
      group.setAttribute('data-node-type', member.type);
      group.dataset.memberKey = member.key;
      const roleWord = member.pending ? `Pending ${member.type} node` : `${member.type} node`;
      group.setAttribute('aria-label', `${member.name}, ${roleWord}${member.place ? `, ${member.place}` : ''}`);

      const title = document.createElementNS(SVG_NS, 'title');
      const titleType = member.type.charAt(0).toUpperCase() + member.type.slice(1);
      title.textContent = `${member.name} · ${titleType}${member.place ? ` · ${member.place}` : ''}`;
      group.append(title);
      group.append(makeCircle('gp-home-map-node-halo', x, y, 4));
      if (member.type !== 'steward') {
        group.append(makeCircle('gp-home-map-node-ring', x, y, 2.3));
      }
      group.append(makeCircle('gp-home-map-node-dot', x, y, 1.6));
      group.append(makeCircle('gp-home-map-node-ripple is-ripple-a', x, y, 0));
      group.append(makeCircle('gp-home-map-node-ripple is-ripple-b', x, y, 0));

      membersGroup.append(group);
      registerNode(group);
    };

    const toMember = (
      raw: Record<string, any>,
      kind: 'approved-submission' | 'local-pending'
    ): DynamicMapNode | null => {
      const lat = toFiniteNumber(raw.lat ?? raw.latitude);
      const long = toFiniteNumber(raw.long ?? raw.longitude);
      if (lat === null || long === null) return null;
      const name = clean(raw.name || raw.displayName);
      if (!name) return null;
      const sourceId = clean(raw.sourceId || raw.id).replace(/^submission:/, '');
      const themes = Array.isArray(raw.themes) ? raw.themes.map(clean).filter(Boolean) : [];
      const place = clean(raw.place || raw.placeName || raw.city);
      const approved = kind === 'approved-submission';
      const rawType = clean(raw.type || raw.nodeType);
      const type = ['steward', 'project', 'place'].includes(rawType)
        ? rawType as DynamicMapNodeType
        : 'member';
      return {
        key: approved ? `submission:${sourceId}` : `local:${clean(raw.id) || `${lat},${long}`}`,
        sourceId: approved ? sourceId : '',
        type,
        name,
        place,
        themes,
        lat,
        long,
        approved,
        pending: !approved,
      };
    };

    const renderDynamicThreads = (
      rawNodes: Array<Record<string, any>>,
      rawEdges: Array<Record<string, any>>
    ) => {
      if (!dynamicThreadsGroup) return;
      dynamicThreadsGroup.textContent = '';
      const nodeById = new Map<string, { x: number; y: number }>();
      rawNodes.forEach((node) => {
        const id = clean(node?.id);
        const lat = toFiniteNumber(node?.lat);
        const long = toFiniteNumber(node?.long);
        if (!id || lat === null || long === null) return;
        nodeById.set(id, { x: lonToX(long), y: latToY(lat) });
      });

      rawEdges.forEach((edge, idx) => {
        const from = clean(edge?.from);
        const to = clean(edge?.to);
        const a = nodeById.get(from);
        const b = nodeById.get(to);
        if (!from || !to || !a || !b) return;

        const theme = clean(edge?.theme);
        const color = themeColor(theme);
        const path = document.createElementNS(SVG_NS, 'path');
        applyScope(path);
        path.setAttribute('class', 'gp-home-map-thread');
        path.setAttribute('data-from', from);
        path.setAttribute('data-to', to);
        path.setAttribute('d', buildMycelialPath(a, b, seedForEdge(`${from}:${to}:${theme}`)));
        path.setAttribute('pathLength', '1');
        path.setAttribute('stroke', color);
        const growDelay = (idx % 12) * 0.12;
        const pulseDelay = (idx % 9) * 0.45;
        path.setAttribute(
          'style',
          `--thread-color: ${color}; --thread-grow-delay: ${growDelay}s; --thread-pulse-delay: ${pulseDelay}s; animation-delay: ${growDelay}s, ${pulseDelay + 1.6}s;`
        );
        dynamicThreadsGroup.append(path);
      });
    };

    const renderLocalPending = () => {
      loadLocalPendingNodes(window.localStorage).forEach((node) => {
        const member = toMember(node as Record<string, any>, 'local-pending');
        if (member) injectMember(member);
      });
    };

    // ---- Add-node intake mode copy -----------------------------------------
    const modeCopyEl = scope.querySelector('[data-home-map-mode-copy]') as HTMLElement | null;
    const setModeCopy = (mode: string) => {
      if (!modeCopyEl) return;
      modeCopyEl.textContent = mode === 'live'
        ? 'Live onboarding is on — your node appears on the public map right after you submit. Your email stays private and is used only for future edit links.'
        : 'In moderated mode, your node appears on your device while stewards review it. Your email stays private and is used only for future edit links.';
    };

    let intakeMode: 'moderated' | 'live' = 'moderated';

    // ---- /map/state fetch (single, no polling) -----------------------------
    const loadMapState = async () => {
      try {
        const response = await fetch(`${agentBaseUrl}/map/state`, { cache: 'no-store' });
        if (!response.ok) return;
        const state = await response.json();
        intakeMode = state?.intakeMode === 'live' ? 'live' : 'moderated';
        setModeCopy(intakeMode);
        const nodes = Array.isArray(state?.nodes) ? state.nodes : [];
        nodes
          .filter((node: Record<string, any>) => node?.source === 'approved-submission')
          .forEach((node: Record<string, any>) => {
            const member = toMember(node, 'approved-submission');
            if (member) injectMember(member);
          });
        renderDynamicThreads(
          nodes as Array<Record<string, any>>,
          Array.isArray(state?.edges) ? state.edges : []
        );
      } catch {
        // Agent unavailable: keep the SSR baseline map. No-op.
      }
    };

    // ---- Add-node submission ------------------------------------------------
    const addForm = scope.querySelector('[data-home-map-addnode-form]') as HTMLFormElement | null;
    const addStatus = scope.querySelector('[data-home-map-addnode-status]') as HTMLElement | null;

    const setAddStatus = (message: string, tone: 'idle' | 'success' | 'error' = 'idle') => {
      if (!addStatus) return;
      addStatus.textContent = message;
      if (tone === 'idle') addStatus.removeAttribute('data-tone');
      else addStatus.dataset.tone = tone;
    };

    const createLocalId = () => (
      'randomUUID' in crypto
        ? `local-${crypto.randomUUID()}`
        : `local-${Date.now()}-${Math.round(Math.random() * 1e5)}`
    );

    addForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitButton = addForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const data = new FormData(addForm);
      const name = clean(data.get('name'));
      const place = clean(data.get('place'));
      const lat = toFiniteNumber(data.get('lat'));
      const long = toFiniteNumber(data.get('long'));
      const themes = data.getAll('themes').map((v) => clean(v)).filter(Boolean);
      const publicNote = clean(data.get('publicNote'));
      const emailInput = addForm.elements.namedItem('contact') as HTMLInputElement | null;
      const email = clean(data.get('contact')).toLowerCase();
      if (emailInput) emailInput.value = email;

      if (!name || !place || lat === null || long === null || !emailInput?.checkValidity()) {
        setAddStatus('Add a name, place, latitude, longitude, and valid private email before submitting.', 'error');
        return;
      }

      setAddStatus('Submitting your node…', 'idle');
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch(`${agentBaseUrl}/map-nodes`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            displayName: name,
            placeName: place,
            lat,
            long,
            role: 'member',
            themes,
            publicNote,
            email,
            contactConsent: true,
          }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload?.error?.message || 'Submission failed.');
        }

        const node = payload?.node || payload;
        if (node?.status === 'approved') {
          // Live onboarding: the node is public immediately. Never write local
          // pending state for an approved node.
          const member = toMember({ ...node, sourceId: node.id }, 'approved-submission');
          if (member) injectMember(member);
          setAddStatus('Your node is approved and visible on the public map.', 'success');
        } else {
          // Moderated: only now — after the server accepted — do we persist a
          // local pending node for this browser.
          saveLocalPendingNode(window.localStorage, {
            id: createLocalId(),
            name,
            place,
            lat,
            long,
            role: 'member',
            themes,
            publicNote,
          });
          window.dispatchEvent(new Event(PENDING_NODE_UPDATED_EVENT));
          renderLocalPending();
          setAddStatus('Saved on this device and submitted for steward review.', 'success');
        }
        addForm.reset();
      } catch (error) {
        // Server rejected or the request failed: do NOT write local pending state.
        // Surface server-provided validation messages, but show friendly copy for
        // raw network failures (fetch throws a TypeError when it cannot connect).
        const message = error instanceof Error && error.name !== 'TypeError'
          ? error.message
          : 'We could not reach the network right now. Please try again.';
        setAddStatus(message, 'error');
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });

    // ---- Init ---------------------------------------------------------------
    root.querySelectorAll('.gp-home-map-node-link').forEach(registerNode);
    root.addEventListener('mouseleave', clearFocus);
    window.addEventListener(PENDING_NODE_UPDATED_EVENT, renderLocalPending);

    renderLocalPending();
    loadMapState();
  })();
</script>

<style>
  .gp-home-map {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
  }

  .gp-home-map-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .gp-home-map-canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-xl);
    background:
      radial-gradient(ellipse at center, rgba(20, 68, 52, 0.65) 0%, rgba(11, 46, 35, 0.95) 100%);
    overflow: hidden;
    box-shadow: var(--gp-shadow-deep);
  }

  .gp-home-map-topo {
    position: absolute;
    inset: 0;
    background-image: url('/images/hifi/topo-bg.png');
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .gp-home-map-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .gp-home-map-graticule line {
    stroke: var(--gp-green-600);
    stroke-width: 0.04;
    opacity: 0.32;
    stroke-dasharray: 1 1.4;
  }

  .gp-home-map-world circle {
    fill: var(--gp-green-500);
    opacity: 0.5;
    transition: opacity 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gp-home-map-canvas.is-focused .gp-home-map-world circle {
    opacity: 0.3;
  }

  .gp-home-map-thread {
    fill: none;
    stroke-width: 0.22;
    stroke-linecap: round;
    opacity: 0.55;
    mix-blend-mode: screen;
    filter: drop-shadow(0 0 0.5px var(--thread-color));
    transition: stroke-width 240ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 240ms cubic-bezier(0.4, 0, 0.2, 1);
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation:
      gpMapThreadGrow 1.6s cubic-bezier(0.22, 1, 0.36, 1) forwards,
      gpMapThread 5.6s ease-in-out infinite;
  }

  .gp-home-map-thread.is-dim {
    opacity: 0.08;
  }

  /* Node links */
  .gp-home-map-node-link {
    cursor: pointer;
    outline: none;
    transition: opacity 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gp-home-map-node-link.is-dim {
    opacity: 0.22;
  }

  .gp-home-map-node-link.is-adj {
    opacity: 1;
  }

  /* Chapter node treatment — lime fill, dark ring, glow halo */
  .gp-home-map-node-link.is-chapter .gp-home-map-node-dot {
    fill: var(--gp-primary);
    stroke: var(--gp-green-950);
    stroke-width: 0.6;
    transition: r 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .gp-home-map-node-link.is-chapter .gp-home-map-node-ring {
    fill: none;
    stroke: var(--gp-green-950);
    stroke-width: 0.4;
    opacity: 0.65;
  }
  .gp-home-map-node-link.is-chapter .gp-home-map-node-halo {
    fill: var(--gp-primary);
    opacity: 0.12;
    transition: opacity 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .gp-home-map-node-link.is-chapter:hover .gp-home-map-node-halo,
  .gp-home-map-node-link.is-chapter:focus-visible .gp-home-map-node-halo {
    opacity: 0.42;
  }
  .gp-home-map-node-link.is-chapter:focus-visible .gp-home-map-node-dot {
    stroke: var(--gp-lime-400);
    stroke-width: 0.9;
  }

  /* Steward node treatment — warm gold, smaller, no ring */
  .gp-home-map-node-link.is-steward .gp-home-map-node-dot {
    fill: var(--gp-secondary);
  }
  .gp-home-map-node-link.is-steward .gp-home-map-node-halo {
    fill: var(--gp-secondary);
    opacity: 0.15;
    transition: opacity 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .gp-home-map-node-link.is-steward:hover .gp-home-map-node-halo,
  .gp-home-map-node-link.is-steward:focus-visible .gp-home-map-node-halo {
    opacity: 0.5;
  }

  /* Member/project/place node treatment — submitted nodes injected client-side.
     Teal keeps them distinct from lime chapters and gold stewards. */
  .gp-home-map-node-link.is-member .gp-home-map-node-dot,
  .gp-home-map-node-link.is-project .gp-home-map-node-dot,
  .gp-home-map-node-link.is-place .gp-home-map-node-dot {
    fill: #4FD1C5;
    stroke: var(--gp-green-950);
    stroke-width: 0.5;
    transition: r 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .gp-home-map-node-link.is-member .gp-home-map-node-ring,
  .gp-home-map-node-link.is-project .gp-home-map-node-ring,
  .gp-home-map-node-link.is-place .gp-home-map-node-ring {
    fill: none;
    stroke: #4FD1C5;
    stroke-width: 0.4;
    opacity: 0.6;
  }
  .gp-home-map-node-link.is-member .gp-home-map-node-halo,
  .gp-home-map-node-link.is-project .gp-home-map-node-halo,
  .gp-home-map-node-link.is-place .gp-home-map-node-halo {
    fill: #4FD1C5;
    opacity: 0.14;
    transition: opacity 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .gp-home-map-node-link.is-member:hover .gp-home-map-node-halo,
  .gp-home-map-node-link.is-member:focus-visible .gp-home-map-node-halo,
  .gp-home-map-node-link.is-member.is-selected .gp-home-map-node-halo,
  .gp-home-map-node-link.is-project:hover .gp-home-map-node-halo,
  .gp-home-map-node-link.is-project:focus-visible .gp-home-map-node-halo,
  .gp-home-map-node-link.is-project.is-selected .gp-home-map-node-halo,
  .gp-home-map-node-link.is-place:hover .gp-home-map-node-halo,
  .gp-home-map-node-link.is-place:focus-visible .gp-home-map-node-halo,
  .gp-home-map-node-link.is-place.is-selected .gp-home-map-node-halo {
    opacity: 0.46;
  }
  .gp-home-map-node-link.is-member:focus-visible .gp-home-map-node-dot,
  .gp-home-map-node-link.is-member.is-selected .gp-home-map-node-dot,
  .gp-home-map-node-link.is-project:focus-visible .gp-home-map-node-dot,
  .gp-home-map-node-link.is-project.is-selected .gp-home-map-node-dot,
  .gp-home-map-node-link.is-place:focus-visible .gp-home-map-node-dot,
  .gp-home-map-node-link.is-place.is-selected .gp-home-map-node-dot {
    stroke: var(--gp-lime-400);
    stroke-width: 0.8;
  }
  /* Pending nodes live only in this browser; render them as provisional. */
  .gp-home-map-node-link.is-member.is-pending .gp-home-map-node-dot,
  .gp-home-map-node-link.is-project.is-pending .gp-home-map-node-dot,
  .gp-home-map-node-link.is-place.is-pending .gp-home-map-node-dot {
    fill: var(--gp-green-500);
    stroke: #4FD1C5;
  }
  .gp-home-map-node-link.is-member.is-pending .gp-home-map-node-ring,
  .gp-home-map-node-link.is-project.is-pending .gp-home-map-node-ring,
  .gp-home-map-node-link.is-place.is-pending .gp-home-map-node-ring {
    stroke-dasharray: 0.8 0.8;
    opacity: 0.9;
  }

  /* Focus ripples — only visible while the node is actively focused. We
     animate a CSS variable through stops so each ripple breathes
     outward and fades, then resets. r is CSS-animatable in modern
     browsers; we attribute it via custom properties. */
  .gp-home-map-node-ripple {
    fill: none;
    stroke-width: 0.18;
    opacity: 0;
    pointer-events: none;
    transform-box: fill-box;
  }
  .gp-home-map-node-link.is-chapter .gp-home-map-node-ripple {
    stroke: var(--gp-primary);
  }
  .gp-home-map-node-link.is-steward .gp-home-map-node-ripple {
    stroke: var(--gp-secondary);
    stroke-width: 0.14;
  }
  .gp-home-map-node-link.is-member .gp-home-map-node-ripple,
  .gp-home-map-node-link.is-project .gp-home-map-node-ripple,
  .gp-home-map-node-link.is-place .gp-home-map-node-ripple {
    stroke: #4FD1C5;
    stroke-width: 0.16;
  }
  .gp-home-map-node-link:hover .gp-home-map-node-ripple,
  .gp-home-map-node-link:focus-visible .gp-home-map-node-ripple {
    animation: gpMapNodeRipple 2.6s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }
  .gp-home-map-node-link:hover .gp-home-map-node-ripple.is-ripple-b,
  .gp-home-map-node-link:focus-visible .gp-home-map-node-ripple.is-ripple-b {
    animation-delay: 0.9s;
  }

  /* Nutrient blips on adjacent threads when a node is focused. The dash
     pattern is 0.04 / 0.96 so a single short stroke segment chases along
     each adjacent path, riding the active thread color. Subtle, only on
     focus, and respects reduced motion. */
  .gp-home-map-thread.is-adj {
    opacity: 0.95;
    stroke-width: 0.34;
    stroke: var(--gp-lime-400);
    /* Override the dasharray set by the grow-in animation so the blip
       gets a tight pattern to chase along the path. */
    stroke-dasharray: 0.04 0.96;
    stroke-dashoffset: 0;
    animation:
      gpMapThread 5.6s ease-in-out infinite,
      gpMapNutrientBlip 2.6s linear infinite;
  }

  /* Stats overlay inside the map */
  .gp-home-map-stats {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 8px 14px;
    background: rgba(11, 38, 28, 0.78);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-pill);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 3;
    max-width: calc(100% - 24px);
    pointer-events: none;
  }

  .gp-home-map-stat {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .gp-home-map-stat-mark {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
  }

  .gp-home-map-stat-mark.is-chapter {
    background: var(--gp-primary);
    box-shadow: 0 0 0 1.5px var(--gp-green-950);
  }

  .gp-home-map-stat-value {
    font-family: var(--gp-font-display);
    color: var(--gp-secondary);
    font-size: 18px;
    line-height: 1;
    font-weight: 500;
  }

  .gp-home-map-stat-label {
    font-family: var(--gp-font-mono);
    color: var(--gp-fg-dim);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  /* Focus card */
  .gp-home-map-focus {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    border: 1px solid rgba(184, 232, 53, 0.32);
    border-radius: var(--gp-radius-md);
    background: rgba(15, 50, 38, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--gp-fg);
    max-width: 60%;
    z-index: 4;
    pointer-events: none;
  }

  .gp-home-map-focus[aria-hidden='false'] {
    display: inline-flex;
  }

  .gp-home-map-focus-role {
    font-family: var(--gp-font-mono);
    color: var(--gp-primary);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .gp-home-map-focus-name {
    font-family: var(--gp-font-display);
    color: var(--gp-secondary);
    font-size: 18px;
    line-height: 1.1;
  }

  .gp-home-map-focus-meta {
    font-family: var(--gp-font-body);
    color: var(--gp-fg-muted);
    font-size: 12px;
    line-height: 1.3;
  }

  .gp-home-map-focus-meta:empty {
    display: none;
  }

  /* Plain-language theme legend underneath the map */
  .gp-home-map-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 14px;
  }

  .gp-home-map-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-pill);
    background: rgba(15, 61, 46, 0.5);
    color: var(--gp-fg-muted);
    font-family: var(--gp-font-body);
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
  }

  .gp-home-map-legend-swatch {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
  }

  /* Selected-node panel — in-flow (not an overlay) so it never clips on
     mobile. Appears only when a submitted member node is activated. */
  .gp-home-map-selected {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 16px;
    border: 1px solid rgba(79, 209, 197, 0.32);
    border-radius: var(--gp-radius-md);
    background: rgba(15, 50, 38, 0.92);
  }
  .gp-home-map-selected[hidden] { display: none; }

  .gp-home-map-selected-close {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-pill);
    background: rgba(7, 24, 15, 0.6);
    color: var(--gp-fg-muted);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
  }
  .gp-home-map-selected-close:hover { color: var(--gp-fg); }

  .gp-home-map-selected-kicker {
    margin: 0;
    padding-right: 38px;
    font-family: var(--gp-font-mono);
    color: #7fe6da;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .gp-home-map-selected-name {
    margin: 0;
    padding-right: 38px;
    font-family: var(--gp-font-display);
    color: var(--gp-secondary);
    font-size: 18px;
    line-height: 1.15;
    overflow-wrap: anywhere;
  }
  .gp-home-map-selected-place {
    margin: 0;
    color: var(--gp-fg-muted);
    font-size: 13px;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
  .gp-home-map-selected-place:empty { display: none; }

  .gp-home-map-selected-themes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }
  .gp-home-map-selected-themes:empty { display: none; }
  .gp-home-map-selected-themes span {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 2px 9px;
    border: 1px solid color-mix(in srgb, var(--chip-color, #4FD1C5) 60%, transparent);
    border-radius: var(--gp-radius-pill);
    background: color-mix(in srgb, var(--chip-color, #4FD1C5) 16%, transparent);
    color: var(--gp-fg);
    font-size: 12px;
    line-height: 1;
    overflow-wrap: anywhere;
  }

  /* Owner edit-link request — neutral on every outcome. */
  .gp-home-map-update { margin-top: 8px; }
  .gp-home-map-update[hidden] { display: none; }
  .gp-home-map-update-trigger {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border: 1px solid rgba(79, 209, 197, 0.5);
    border-radius: var(--gp-radius-pill);
    background: rgba(79, 209, 197, 0.14);
    color: #b8f5ec;
    font-family: var(--gp-font-body);
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: background 160ms ease;
  }
  .gp-home-map-update-trigger:hover { background: rgba(79, 209, 197, 0.24); }
  .gp-home-map-update-trigger[hidden] { display: none; }

  .gp-home-map-update-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 6px;
  }
  .gp-home-map-update-form[hidden] { display: none; }
  .gp-home-map-update-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gp-home-map-update-field span {
    color: var(--gp-fg-muted);
    font-size: 12px;
    font-weight: 700;
  }
  .gp-home-map-update-field input {
    width: 100%;
    box-sizing: border-box;
    min-height: 44px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    padding: 10px 12px;
    background: rgba(2, 12, 7, 0.7);
    color: var(--gp-fg);
    font: inherit;
    outline: none;
  }
  .gp-home-map-update-field input:focus {
    border-color: rgba(79, 209, 197, 0.78);
    box-shadow: 0 0 0 3px rgba(79, 209, 197, 0.14);
  }
  .gp-home-map-update-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .gp-home-map-update-actions button {
    min-height: 44px;
    flex: 1 1 auto;
    border-radius: var(--gp-radius-pill);
    padding: 8px 16px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }
  .gp-home-map-update-cancel {
    border: 1px solid var(--gp-border-soft);
    background: transparent;
    color: var(--gp-fg-muted);
  }
  .gp-home-map-update-submit {
    border: 0;
    background: #4FD1C5;
    color: #07241a;
  }
  .gp-home-map-update-error {
    margin: 0;
    color: #f0dca0;
    font-size: 13px;
  }
  .gp-home-map-update-error:empty { display: none; }
  .gp-home-map-update-success {
    margin: 6px 0 0;
    color: #b8f5ec;
    font-size: 14px;
    line-height: 1.4;
  }
  .gp-home-map-update-success[hidden] { display: none; }

  /* Add-node panel — collapsed by default; keeps the hero uncluttered. */
  .gp-home-map-addnode {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    background: rgba(7, 24, 15, 0.5);
  }
  .gp-home-map-addnode > summary {
    min-height: 48px;
    display: flex;
    align-items: center;
    padding: 12px 16px;
    color: var(--gp-primary);
    font-family: var(--gp-font-body);
    font-weight: 700;
    cursor: pointer;
    list-style: none;
  }
  .gp-home-map-addnode > summary::-webkit-details-marker { display: none; }
  .gp-home-map-addnode > summary::before {
    content: '+';
    margin-right: 8px;
    font-size: 18px;
    line-height: 1;
  }
  .gp-home-map-addnode[open] > summary::before { content: '\2013'; }

  .gp-home-map-addnode-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 0 16px 16px;
  }
  .gp-home-map-addnode-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .gp-home-map-addnode-form > label,
  .gp-home-map-addnode-grid label,
  .gp-home-map-addnode-themes {
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
  }
  .gp-home-map-addnode-form label > span,
  .gp-home-map-addnode-themes > legend {
    color: var(--gp-fg-muted);
    font-size: 12px;
    font-weight: 700;
  }
  .gp-home-map-addnode-themes {
    border: 0;
    padding: 0;
    margin: 0;
  }
  .gp-home-map-addnode-form input,
  .gp-home-map-addnode-form textarea {
    width: 100%;
    box-sizing: border-box;
    min-height: 44px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    padding: 10px 12px;
    background: rgba(2, 12, 7, 0.7);
    color: var(--gp-fg);
    font: inherit;
    outline: none;
  }
  .gp-home-map-addnode-form textarea { min-height: 76px; resize: vertical; }
  .gp-home-map-addnode-form input:focus,
  .gp-home-map-addnode-form textarea:focus {
    border-color: rgba(184, 232, 53, 0.7);
    box-shadow: 0 0 0 3px rgba(184, 232, 53, 0.12);
  }
  .gp-home-map-addnode-theme-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  .gp-home-map-addnode-theme {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    padding: 6px 10px;
    background: rgba(2, 12, 7, 0.36);
    cursor: pointer;
  }
  .gp-home-map-addnode-theme input {
    width: 16px;
    min-height: 16px;
    flex: none;
    accent-color: var(--gp-primary);
  }
  .gp-home-map-addnode-theme span { font-size: 13px; font-weight: 600; }
  .gp-home-map-addnode-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .gp-home-map-addnode-mode {
    flex: 1 1 14rem;
    margin: 0;
    color: var(--gp-fg-muted);
    font-size: 12px;
    line-height: 1.4;
  }
  .gp-home-map-addnode-submit {
    min-height: 48px;
    min-width: 8.5rem;
    border: 0;
    border-radius: var(--gp-radius-pill);
    padding: 10px 18px;
    background: var(--gp-primary);
    color: var(--gp-primary-fg);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    transition: transform 160ms ease, opacity 160ms ease;
  }
  .gp-home-map-addnode-submit:disabled { opacity: 0.64; cursor: wait; }
