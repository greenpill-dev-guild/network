    min-height: 26px;
    padding: 2px 9px;
    border: 1px solid color-mix(in srgb, var(--chip-color, var(--gp-map-member)) 60%, transparent);
    border-radius: var(--gp-radius-pill);
    background: color-mix(in srgb, var(--chip-color, var(--gp-map-member)) 16%, transparent);
    color: var(--gp-fg);
    font-size: 12px;
    line-height: 1;
    overflow-wrap: anywhere;
  }

  /* Owner edit-link request — neutral on every outcome. */
  .gp-home-map-update { margin-top: 8px; }
  .gp-home-map-update[hidden] { display: none; }
  .gp-home-map-update-trigger {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border: 1px solid color-mix(in srgb, var(--gp-map-member) 55%, transparent);
    border-radius: var(--gp-radius-pill);
    background: color-mix(in srgb, var(--gp-map-member) 14%, transparent);
    color: var(--gp-map-member);
    font-family: var(--gp-font-body);
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: background 160ms ease;
  }
  .gp-home-map-update-trigger:hover {
    background: color-mix(in srgb, var(--gp-map-member) 24%, transparent);
  }
  .gp-home-map-update-trigger[hidden] { display: none; }

  .gp-home-map-update-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 6px;
  }
  .gp-home-map-update-form[hidden] { display: none; }
  .gp-home-map-update-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gp-home-map-update-field span {
    color: var(--gp-fg-muted);
    font-size: 12px;
    font-weight: 700;
  }
  .gp-home-map-update-field input {
    width: 100%;
    box-sizing: border-box;
    min-height: 44px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    padding: 10px 12px;
    background: rgba(2, 12, 7, 0.7);
    color: var(--gp-fg);
    font: inherit;
    outline: none;
  }
  .gp-home-map-update-field input:focus {
    border-color: color-mix(in srgb, var(--gp-map-member) 78%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--gp-map-member) 14%, transparent);
  }
  .gp-home-map-update-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .gp-home-map-update-actions button {
    min-height: 44px;
    flex: 1 1 auto;
    border-radius: var(--gp-radius-pill);
    padding: 8px 16px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }
  .gp-home-map-update-cancel {
    border: 1px solid var(--gp-border-soft);
    background: transparent;
    color: var(--gp-fg-muted);
  }
  .gp-home-map-update-submit {
    border: 0;
    background: var(--gp-map-member);
    color: #07241a;
  }
  .gp-home-map-update-error {
    margin: 0;
    color: #f0dca0;
    font-size: 13px;
  }
  .gp-home-map-update-error:empty { display: none; }
  .gp-home-map-update-success {
    margin: 6px 0 0;
    color: var(--gp-map-member);
    font-size: 14px;
    line-height: 1.4;
  }
  .gp-home-map-update-success[hidden] { display: none; }

  /* Find-your-people walkthrough — modal layer, no map layout jump. */
  .gp-home-map-addnode-dialog {
    position: relative;
    box-sizing: border-box;
    width: min(720px, calc(100vw - 32px));
    height: auto;
    max-height: min(680px, calc(100svh - 32px));
    margin: auto;
    padding: 24px 26px;
    border: 1px solid color-mix(in srgb, var(--gp-map-member) 34%, transparent);
    border-radius: var(--gp-radius-xl);
    background:
      radial-gradient(circle at 18% 8%, rgba(184, 232, 53, 0.12), transparent 30%),
      linear-gradient(145deg, rgba(18, 72, 52, 0.98), rgba(6, 26, 18, 0.99));
    color: var(--gp-fg);
    box-shadow: 0 28px 88px -28px rgba(0, 0, 0, 0.82);
    overflow: hidden;
  }

  .gp-home-map-addnode-dialog::backdrop {
    background: rgba(2, 12, 7, 0.74);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  .gp-home-map-addnode-dialog:not([open]) {
    display: none;
  }

  .gp-home-map-addnode-topo {
    position: absolute;
    inset: 0;
    background-image: url('/images/hifi/topo-bg.png');
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .gp-home-map-addnode-close {
    position: absolute;
    top: 22px;
    right: 22px;
    z-index: 3;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(250, 247, 238, 0.18);
    border-radius: var(--gp-radius-pill);
    background: rgba(7, 24, 15, 0.68);
    color: var(--gp-fg-muted);
    font: inherit;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
  }

  .gp-home-map-addnode-close:hover,
  .gp-home-map-addnode-close:focus-visible {
    color: var(--gp-fg);
    border-color: color-mix(in srgb, var(--gp-map-member) 50%, transparent);
    outline: none;
  }

  .gp-home-map-addnode-progress {
    display: none;
  }

  .gp-home-map-addnode-progress span {
    width: 42px;
    height: 4px;
    border-radius: var(--gp-radius-pill);
    background: rgba(250, 247, 238, 0.16);
  }

  .gp-home-map-addnode-progress span.is-active {
    background: var(--gp-map-member);
    box-shadow: 0 0 16px color-mix(in srgb, var(--gp-map-member) 44%, transparent);
  }

  .gp-home-map-addnode-form {
    position: relative;
    z-index: 2;
    max-height: calc(100svh - 80px);
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 14px;
  }

  .gp-home-map-addnode-step {
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: auto;
    padding-right: 4px;
  }

  .gp-home-map-addnode-step[hidden] {
    display: none;
  }

  .gp-home-map-addnode-kicker {
    margin: 0;
    color: var(--gp-map-member);
    font-family: var(--gp-font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .gp-home-map-addnode-dialog h2 {
    max-width: calc(100% - 52px);
    margin: 0;
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: 38px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.02;
    white-space: nowrap;
  }

  .gp-home-map-addnode-copy,
  .gp-home-map-addnode-mode,
  .gp-home-map-addnode-location-status,
  .gp-home-map-addnode-status {
    margin: 0;
    color: var(--gp-fg-muted);
    font-size: 14px;
    line-height: 1.45;
  }

  .gp-home-map-addnode-copy {
    max-width: 52ch;
  }

  .gp-home-map-addnode-theme-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-top: 2px;
  }

  .gp-home-map-addnode-theme {
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid color-mix(in srgb, var(--theme-color, var(--gp-map-member)) 42%, rgba(250, 247, 238, 0.14));
    border-radius: var(--gp-radius-pill);
    padding: 8px 12px;
    background: color-mix(in srgb, var(--theme-color, var(--gp-map-member)) 10%, rgba(2, 12, 7, 0.42));
    color: var(--gp-fg);
    font: inherit;
    font-size: 13px;
    font-weight: 750;
    line-height: 1.15;
    text-align: left;
    cursor: pointer;
    transition: background 160ms ease, border-color 160ms ease, opacity 160ms ease, transform 160ms ease;
  }

  .gp-home-map-addnode-theme:hover,
  .gp-home-map-addnode-theme:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--theme-color, var(--gp-map-member)) 70%, transparent);
    outline: none;
  }

  .gp-home-map-addnode-theme[aria-pressed='true'] {
    background: color-mix(in srgb, var(--theme-color, var(--gp-map-member)) 28%, rgba(2, 12, 7, 0.38));
    border-color: var(--theme-color, var(--gp-map-member));
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--theme-color, var(--gp-map-member)) 16%, transparent);
  }

  .gp-home-map-addnode-theme:disabled {
    opacity: 0.36;
    cursor: not-allowed;
    transform: none;
  }

  .gp-home-map-addnode-theme-dot {
    width: 12px;
    height: 12px;
    flex: none;
    border-radius: 999px;
    background: var(--theme-color, var(--gp-map-member));
    box-shadow: 0 0 14px color-mix(in srgb, var(--theme-color, var(--gp-map-member)) 56%, transparent);
  }

  .gp-home-map-addnode-theme-count {
    align-self: flex-start;
    margin: 0;
    padding: 7px 10px;
    border: 1px solid rgba(250, 247, 238, 0.12);
    border-radius: var(--gp-radius-pill);
    background: rgba(2, 12, 7, 0.28);
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .gp-home-map-addnode-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .gp-home-map-addnode-form label {
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-width: 0;
  }

  .gp-home-map-addnode-form label > span,
  .gp-home-map-addnode-location-head > span {
    color: var(--gp-map-member);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.1;
  }

  .gp-home-map-addnode-form input,
  .gp-home-map-addnode-form textarea {
    width: 100%;
    box-sizing: border-box;
    min-height: 48px;
    border: 1px solid rgba(250, 247, 238, 0.14);
    border-radius: var(--gp-radius-md);
    padding: 12px 13px;
    background: rgba(2, 12, 7, 0.55);
    color: var(--gp-fg);
    font: inherit;
    outline: none;
  }

  .gp-home-map-addnode-form textarea {
    min-height: 88px;
    resize: vertical;
  }

  .gp-home-map-addnode-form input:focus,
  .gp-home-map-addnode-form textarea:focus {
    border-color: color-mix(in srgb, var(--gp-map-member) 76%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--gp-map-member) 14%, transparent);
  }

  .gp-home-map-addnode-location {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 10px;
    border: 1px solid rgba(250, 247, 238, 0.12);
    border-radius: var(--gp-radius-lg);
    background: rgba(2, 12, 7, 0.24);
  }

  .gp-home-map-addnode-location-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .gp-home-map-addnode-location-head button,
  .gp-home-map-addnode-review button {
    border: 0;
    background: transparent;
    color: var(--gp-map-member);
    font: inherit;
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    cursor: pointer;
  }

  .gp-home-map-addnode-location-head button:hover,
  .gp-home-map-addnode-location-head button:focus-visible,
  .gp-home-map-addnode-review button:hover,
  .gp-home-map-addnode-review button:focus-visible {
    color: var(--gp-secondary);
    outline: none;
  }

  .gp-home-map-addnode-mini-map {
    position: relative;
    aspect-ratio: 2 / 1;
    min-height: 156px;
    border: 1px solid color-mix(in srgb, var(--gp-map-member) 24%, transparent);
    border-radius: var(--gp-radius-md);
    background: radial-gradient(ellipse at center, rgba(20, 68, 52, 0.72), rgba(7, 24, 15, 0.96));
    overflow: hidden;
    cursor: crosshair;
  }

  .gp-home-map-addnode-mini-map[hidden],
  .gp-home-map-addnode-city[hidden],
  .gp-home-map-addnode-back[hidden],
  .gp-home-map-addnode-next[hidden],
  .gp-home-map-addnode-submit[hidden] {
    display: none;
  }

  .gp-home-map-addnode-mini-topo {
    position: absolute;
    inset: 0;
    background-image: url('/images/hifi/topo-bg.png');
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .gp-home-map-addnode-mini-map svg {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
  }

  .gp-home-map-addnode-mini-map svg circle {
    fill: var(--gp-green-400);
    opacity: 0.52;
  }

  .gp-home-map-addnode-mini-map [data-location-pin] {
    fill: var(--gp-map-member);
    stroke: var(--gp-green-950);
    stroke-width: 0.75;
    opacity: 1;
    filter: drop-shadow(0 0 5px var(--gp-map-member));
  }

  .gp-home-map-addnode-mini-map span {
    position: absolute;
    left: 50%;
    bottom: 10px;
    z-index: 2;
    transform: translateX(-50%);
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
  }

  .gp-home-map-addnode-note {
    margin-top: 0;
  }

  .gp-home-map-addnode-preview {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px;
    border: 1px solid color-mix(in srgb, var(--gp-map-member) 26%, transparent);
    border-radius: var(--gp-radius-lg);
    background: rgba(2, 12, 7, 0.28);
  }

  .gp-home-map-addnode-preview-dot {
    width: 24px;
    height: 24px;
    flex: none;
    border-radius: 999px;
    background: var(--gp-map-member);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--gp-map-member) 18%, transparent);
  }

  .gp-home-map-addnode-preview strong {
    display: block;
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.05;
  }

  .gp-home-map-addnode-preview span:not(.gp-home-map-addnode-preview-dot) {
    display: block;
    margin-top: 3px;
    color: var(--gp-fg-muted);
    font-size: 13px;
  }

  .gp-home-map-addnode-review {
    display: grid;
    gap: 10px;
  }

  .gp-home-map-addnode-review > div {
    display: grid;
    grid-template-columns: minmax(90px, 0.32fr) minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    min-height: 46px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(250, 247, 238, 0.1);
  }

  .gp-home-map-addnode-review > div > span {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .gp-home-map-addnode-review p {
    margin: 0;
    color: var(--gp-fg-muted);
    font-size: 13px;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .gp-home-map-addnode-review [data-review-themes] {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .gp-home-map-addnode-review [data-review-themes] span {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 2px 8px;
    border: 1px solid color-mix(in srgb, var(--chip-color, var(--gp-map-member)) 54%, transparent);
    border-radius: var(--gp-radius-pill);
    background: color-mix(in srgb, var(--chip-color, var(--gp-map-member)) 16%, transparent);
    color: var(--gp-fg);
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  .gp-home-map-addnode-status[data-tone='error'] {
    color: #f0dca0;
  }

  .gp-home-map-addnode-status[data-tone='success'] {
    color: var(--gp-map-member);
  }

  .gp-home-map-addnode-status:empty {
    display: none;
  }

  .gp-home-map-addnode-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-top: 0;
  }

  .gp-home-map-addnode-back,
  .gp-home-map-addnode-next,
  .gp-home-map-addnode-submit {
    min-height: 44px;
    border-radius: var(--gp-radius-pill);
    padding: 10px 18px;
    font: inherit;
    font-weight: 850;
    cursor: pointer;
    transition: transform 160ms ease, opacity 160ms ease, background 160ms ease;
  }

  .gp-home-map-addnode-back {
    border: 1px solid rgba(250, 247, 238, 0.16);
    background: transparent;
    color: var(--gp-fg-muted);
  }

  .gp-home-map-addnode-next,
  .gp-home-map-addnode-submit {
    margin-left: auto;
    border: 0;
    background: var(--gp-map-member);
    color: var(--gp-green-950);
    box-shadow: 0 12px 32px -18px var(--gp-map-member);
  }

  .gp-home-map-addnode-back:hover,
  .gp-home-map-addnode-back:focus-visible,
  .gp-home-map-addnode-next:not(:disabled):hover,
  .gp-home-map-addnode-next:focus-visible,
  .gp-home-map-addnode-submit:not(:disabled):hover,
  .gp-home-map-addnode-submit:focus-visible {
    transform: translateY(-1px);
    outline: none;
  }

  .gp-home-map-addnode-next:disabled,
  .gp-home-map-addnode-submit:disabled {
    opacity: 0.46;
    cursor: not-allowed;
    transform: none;
  }

  @container (max-width: 640px) {
    .gp-home-map-addnode-dialog {
      width: calc(100vw - 20px);
      max-height: calc(100svh - 20px);
      padding: 20px;
      border-radius: var(--gp-radius-lg);
    }

    .gp-home-map-addnode-close {
      top: 16px;
      right: 16px;
    }

    .gp-home-map-addnode-form {
      max-height: calc(100svh - 60px);
    }

    .gp-home-map-addnode-dialog h2 {
      max-width: calc(100% - 48px);
      font-size: 32px;
      white-space: normal;
    }

    .gp-home-map-addnode-theme-options,
    .gp-home-map-addnode-grid {
      grid-template-columns: 1fr;
    }

    .gp-home-map-addnode-review > div {
      grid-template-columns: 1fr auto;
    }

    .gp-home-map-addnode-review > div > span {
      grid-column: 1 / -1;
    }

    .gp-home-map-addnode-footer {
      align-items: stretch;
    }

    .gp-home-map-addnode-back,
    .gp-home-map-addnode-next,
    .gp-home-map-addnode-submit {
      flex: 1 1 auto;
      padding-inline: 14px;
    }
  }

  @keyframes gpMapThread {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 0.75; }
  }

  @keyframes gpMapThreadGrow {
    from { stroke-dashoffset: 1; }
    to   { stroke-dashoffset: 0; }
  }

  @keyframes gpMapNodeRipple {
    0%   { r: 1; opacity: 0.55; }
    80%  { r: 6; opacity: 0; }
    100% { r: 6; opacity: 0; }
  }

  @keyframes gpMapNutrientBlip {
    from { stroke-dashoffset: 1; }
    to   { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    /* Drop motion but keep threads visible — without this the dasharray
       leaves them invisible at offset:1 when the global rule clamps the
       grow-in animation to ~0ms before any keyframe interpolation runs. */
    .gp-home-map-thread {
      animation: none !important;
      stroke-dasharray: none;
      stroke-dashoffset: 0;
    }
    .gp-home-map-thread.is-adj {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
    }
    .gp-home-map-node-ripple {
      animation: none !important;
      opacity: 0 !important;
    }
  }

  @container (max-width: 720px) {
    .gp-home-map-canvas {
      aspect-ratio: 4 / 3;
      border-radius: var(--gp-radius-lg);
    }

    .gp-home-map-legend {
      top: 8px;
      right: 8px;
      padding: 8px 10px;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .gp-home-map-legend-label {
      font-size: 10px;
      letter-spacing: 0.08em;
    }

    .gp-home-map-focus {
      padding: 8px 10px;
      min-width: 180px;
      max-width: min(240px, calc(100% - 16px));
    }

    .gp-home-map-focus-name {
      font-size: 14px;
    }

    .gp-home-map-controls {
      left: 8px;
      bottom: 8px;
      max-width: calc(100% - 16px);
    }

    .gp-home-map-filter-panel {
      width: min(340px, calc(100vw - 40px));
      max-height: 44cqw;
      padding: 10px;
    }

    .gp-home-map-filter-panel.is-themes {
      grid-template-columns: 1fr;
    }

    .gp-home-map-filter-tabs {
      gap: 5px;
    }

    .gp-home-map-filter-tabs button {
      min-height: 44px;
      padding-inline: 12px;
      font-size: 12px;
    }
  }

  @container (max-width: 480px) {
    .gp-home-map-legend {
      max-width: 52%;
    }

