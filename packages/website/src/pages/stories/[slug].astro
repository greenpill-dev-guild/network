---
import { getCollection } from 'astro:content';
import GpLayout from '../../layouts/GpLayout.astro';
import Container from '../../components/ui/Container.astro';
import Card from '../../components/ui/Card.astro';
import Chip from '../../components/ui/Chip.astro';
import ArrowLink from '../../components/ui/ArrowLink.astro';
import Overline from '../../components/ui/Overline.astro';
import Text from '../../components/ui/Text.astro';
import Meta from '../../components/ui/Meta.astro';
import Breadcrumb from '../../components/shell/Breadcrumb.astro';
import Avatar from '../../components/ui/Avatar.astro';
import { publicGuildPath } from '../../lib/public-routes';

export async function getStaticPaths() {
  const items = await getCollection('stories');
  return items
    .filter((item) => item.data.status === 'published' && !item.data.seo?.noindex)
    .map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const data = item.data;

const allStories = await getCollection('stories');
const continueIds: string[] = (data.continueReadingStorySlugs ?? []).length > 0
  ? data.continueReadingStorySlugs
  : (data.relatedStorySlugs ?? []);

const continueReading = continueIds
  .map((slug) => allStories.find((s) => s.id === slug && s.data.status === 'published'))
  .filter((s): s is typeof allStories[number] => Boolean(s));

type StoryBodyBlock =
  | { kind: 'p' | 'h2' | 'quote'; text: string }
  | { kind: 'ul' | 'ol'; items: string[] };

function bodyToBlocks(body: string): StoryBodyBlock[] {
  if (!body) return [];
  return body.split(/\n{2,}/).flatMap((segment) => {
    const trimmed = segment.trim();
    if (!trimmed) return [];
    const lines = trimmed.split('\n').map((line) => line.trim()).filter(Boolean);
    if (trimmed.startsWith('## ')) return { kind: 'h2' as const, text: trimmed.slice(3) };
    if (trimmed.startsWith('> ')) return { kind: 'quote' as const, text: trimmed.slice(2) };
    if (lines.length > 0 && lines.every((line) => /^[-*]\s+/.test(line))) {
      return { kind: 'ul' as const, items: lines.map((line) => line.replace(/^[-*]\s+/, '')) };
    }
    if (lines.length > 0 && lines.every((line) => /^\d+\.\s+/.test(line))) {
      return { kind: 'ol' as const, items: lines.map((line) => line.replace(/^\d+\.\s+/, '')) };
    }
    return { kind: 'p' as const, text: trimmed };
  });
}

function linkifyText(text: string) {
  return text
    .split(/(https?:\/\/[^\s]+)/g)
    .filter(Boolean)
    .map((part) => ({
      text: part,
      href: /^https?:\/\//.test(part) ? part : '',
    }));
}

const bodyBlocks = bodyToBlocks(data.body || '');
const relatedGuild = data.relatedGuild || '';
const relatedGuildPath = publicGuildPath(relatedGuild);
const storyImage = data.media?.image || data.image || '';
const storyImageAlt = data.media?.imageAlt || `${data.title} story image`;
---

<GpLayout
  title={data.seo?.title || `${data.title} · Greenpill Stories`}
  description={data.seo?.description || data.excerpt || ''}
  ogImage={data.seo?.ogImage || data.media?.ogImage || undefined}
  canonicalPath={data.seo?.canonicalPath || `/stories/${item.id}`}
  noindex={data.seo?.noindex}
  activeNav="Stories"
  ogType="article"
>
  <main class="gp-story">
    <header class="gp-story-hero gp-topo">
      <Container size="lg">
        <Breadcrumb
          back={{ label: 'All stories', href: '/stories' }}
          crumbs={[{ label: data.category || 'story' }, { label: data.title }]}
        />
        <div class="gp-story-hero-inner">
          <Meta items={[data.category || 'story', data.region || 'global', data.publishDate || '']} accentIndex={0} />
          <Text variant="display" class="gp-story-title">{data.title}</Text>
          {data.dek && <Text variant="body-lg" class="gp-story-dek">{data.dek}</Text>}
          {!data.dek && data.excerpt && <Text variant="body-lg" class="gp-story-dek">{data.excerpt}</Text>}

          {data.author && (
            <div class="gp-story-byline">
              <Avatar name={data.author} size={48} />
              <div>
                <Text variant="title-md">{data.author}</Text>
                {data.authorRole && <Text variant="caption">{data.authorRole}</Text>}
              </div>
              {data.readTime && (
                <span class="gp-story-readtime">
                  <Text variant="mono">{data.readTime}</Text>
                </span>
              )}
            </div>
          )}

          {storyImage && (
            <figure class="gp-story-hero-media">
              <img src={storyImage} alt={storyImageAlt} loading="eager" decoding="async" />
            </figure>
          )}
        </div>
      </Container>
    </header>

    {bodyBlocks.length > 0 && (
      <section class="gp-story-body">
        <Container size="md">
          <div class="gp-story-prose">
            {bodyBlocks.map((part) => {
              if (part.kind === 'h2') return <h2>{part.text}</h2>;
              if (part.kind === 'quote') return <blockquote>{part.text}</blockquote>;
              if (part.kind === 'ul' || part.kind === 'ol') {
                const Tag = part.kind;
                return (
                  <Tag>
                    {part.items.map((item) => (
                      <li>
                        {linkifyText(item).map((piece) => (
                          piece.href
                            ? <a href={piece.href} target="_blank" rel="noopener">{piece.text}</a>
                            : piece.text
                        ))}
                      </li>
                    ))}
                  </Tag>
                );
              }
              return <p>{part.text}</p>;
            })}
          </div>
        </Container>
      </section>
    )}

    {(data.proofSignals?.length ?? 0) > 0 && (
      <section class="gp-story-section">
        <Container size="lg">
          <Card padded="lg">
            <Overline>Proof links</Overline>
            <div class="gp-story-proof">
              {(data.proofSignals ?? []).map((signal: any) => (
                <a class="gp-story-proof-row" href={signal.href || '#'} target="_blank" rel="noopener">
                  <Text variant="mono">{signal.source || 'Source'}</Text>
                  <Text variant="title-md">{signal.value}</Text>
                  <Text variant="body-sm">{signal.label}</Text>
                </a>
              ))}
            </div>
          </Card>
        </Container>
      </section>
    )}

    {(data.relatedChapter || data.relatedGuild) && (
      <section class="gp-story-section">
        <Container size="lg">
          <div class="gp-story-section-head">
            <Overline>Related</Overline>
            <Text variant="caption">Where this story connects in the network.</Text>
          </div>
          <ul class="gp-story-related">
            {data.relatedChapter && (
              <li>
                <a class="gp-story-related-chip" href={`/chapters/${data.relatedChapter}`}>
                  Chapter · {data.relatedChapter.replace(/-/g, ' ')}
                </a>
              </li>
            )}
            {relatedGuildPath && (
              <li>
                <a class="gp-story-related-chip" href={relatedGuildPath}>
                  Guild · {relatedGuild.replace(/-/g, ' ')}
                </a>
              </li>
            )}
          </ul>
        </Container>
      </section>
    )}

    {continueReading.length > 0 && (
      <section class="gp-story-section">
        <Container size="lg">
          <div class="gp-story-section-head">
            <Overline>Continue reading</Overline>
            <ArrowLink href="/stories">All stories</ArrowLink>
          </div>
          <div class="gp-story-continue-grid">
            {continueReading.map((c) => (
              <a class="gp-story-continue" href={`/stories/${c.id}`}>
                <Meta items={[c.data.category || 'story', c.data.publishDate || '']} accentIndex={0} />
                <Text variant="h3" class="gp-story-continue-title">{c.data.title}</Text>
                {c.data.excerpt && <Text variant="body-sm">{c.data.excerpt}</Text>}
                <ArrowLink size="sm">Read</ArrowLink>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}
  </main>
</GpLayout>

<style>
  .gp-story {
    min-height: 100dvh;
    background: transparent;
    /* Inherited: long words / URLs in story content break instead of
       overflowing the viewport on mobile. */
    overflow-wrap: break-word;
  }

  .gp-story-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-2xl), 6vw, var(--gp-space-4xl)) 0 var(--gp-space-2xl);
  }

  .gp-story-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-lg);
    margin-top: var(--gp-space-xl);
  }

  .gp-story-hero-inner :global(.gp-story-title) {
    max-width: 24ch;
    font-size: var(--gp-h1-size);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .gp-story-hero-inner :global(.gp-story-dek) {
    color: var(--gp-fg-muted);
    max-width: 60ch;
  }

  .gp-story-byline {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: var(--gp-space-md);
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-story-byline > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gp-story-hero-media {
    width: min(100%, 920px);
    aspect-ratio: 16 / 9;
    margin: var(--gp-space-sm) 0 0;
    overflow: hidden;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: rgba(255, 255, 255, 0.04);
  }

  .gp-story-hero-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .gp-story-readtime {
    margin-inline-start: auto;
  }

  .gp-story-body {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-story-prose {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-lg);
    color: var(--gp-fg);
    font-family: var(--gp-font-body);
    font-size: 17px;
    line-height: 1.7;
  }

  .gp-story-prose p {
    margin: 0;
  }

  .gp-story-prose ul,
  .gp-story-prose ol {
    margin: 0;
    padding-inline-start: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .gp-story-prose li {
    padding-inline-start: 0.2rem;
  }

  .gp-story-prose a {
    color: var(--gp-secondary);
    text-decoration-color: rgba(184, 232, 53, 0.5);
    text-underline-offset: 0.18em;
  }

  .gp-story-prose a:hover {
    text-decoration-color: var(--gp-primary);
  }

  .gp-story-prose h2 {
    margin: var(--gp-space-xl) 0 0;
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: var(--gp-h3-size);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.2;
  }

  .gp-story-prose blockquote {
    margin: 0;
    padding-block: var(--gp-space-md);
    padding-inline: var(--gp-space-lg) 0;
    border-inline-start: 3px solid var(--gp-primary);
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: var(--gp-title-lg);
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
  }

  .gp-story-section {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-3xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-story-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--gp-space-md);
    flex-wrap: wrap;
    margin-bottom: var(--gp-space-lg);
  }

  .gp-story-proof {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--gp-space-md);
    margin-top: var(--gp-space-md);
  }

  .gp-story-proof-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--gp-space-md);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms;
  }

  .gp-story-proof-row:hover {
    border-color: rgba(184, 232, 53, 0.42);
  }

  .gp-story-related {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gp-story-related-chip {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 14px;
    border: 1px solid var(--gp-border);
    border-radius: var(--gp-radius-pill);
    color: var(--gp-fg-muted);
    font-family: var(--gp-font-body);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 200ms, color 200ms;
  }

  a.gp-story-related-chip:hover {
    border-color: rgba(184, 232, 53, 0.42);
    color: var(--gp-primary);
  }

  .gp-story-continue-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-story-continue {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-story-continue:hover {
    border-color: rgba(184, 232, 53, 0.32);
    background: var(--gp-card-elev);
  }

  .gp-story-continue :global(.gp-story-continue-title) {
    letter-spacing: 0;
  }

  @container (max-width: 720px) {
    .gp-story-continue-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
