---
import garden from '../../content/garden.json';
import GpLayout from '../../layouts/GpLayout.astro';
import Button from '../../components/ui/Button.astro';
import Container from '../../components/ui/Container.astro';
import EmailInput from '../../components/ui/EmailInput.astro';
import Meta from '../../components/ui/Meta.astro';
import Overline from '../../components/ui/Overline.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Text from '../../components/ui/Text.astro';

const fallbackSteps = [
  {
    level: 1,
    kicker: 'Read',
    title: 'Subscribe to field notes',
    body: 'A monthly public digest with chapter updates, new resources, podcast highlights, and upcoming calls.',
    meta: 'Monthly · public updates · no account',
    cta: { label: 'Subscribe', href: '#step-1', kind: 'form' },
  },
  {
    level: 2,
    kicker: 'Meet',
    title: 'Join the public conversation',
    body: 'Drop into the shared Greenpill chat and listen before you contribute.',
    meta: 'Public conversation · listen first',
    cta: { label: 'Open Telegram', href: 'https://t.me/+e-aa2Ed3LWVlYjNh', kind: 'external' },
  },
  {
    level: 3,
    kicker: 'Signal',
    title: 'Take the Regen Assessment',
    body: 'Answer a short set of questions about what you bring, what you want to learn, and whether a chapter, guild, or story path is the best fit.',
    meta: 'Self-guided · public · no account',
    cta: { label: 'Start assessment', href: 'https://forms.gle/1JNLcvExXLekgzt59', kind: 'form' },
  },
  {
    level: 4,
    kicker: 'Grow',
    title: 'Book a steward call',
    body: 'For people thinking about starting a chapter, joining a guild, partnering on a project, or finding the right steward to talk with.',
    meta: 'Private · by request',
    cta: { label: 'Book a call', href: 'https://calendar.app.google/gia7UpaSVKwwEKxy5', kind: 'booking' },
  },
];

const title = garden.title || 'Greenpill Garden';
const summary = garden.summary || 'A participation ramp for people moving from reading about regeneration to joining chapters, contributing skills, and coordinating real-world public goods.';
const steps = garden.steps.length > 0 ? garden.steps : fallbackSteps;
const stickyCta = garden.stickyCta?.label ? garden.stickyCta : { label: 'Start with Step 1', href: '#step-1' };
const seoTitle = garden.seo.title || `${title} · Greenpill Network`;
const seoDescription = garden.seo.description || summary;
const isExternalHref = (href = '') => /^https?:\/\//.test(href);
---

<GpLayout
  title={seoTitle}
  description={seoDescription}
  ogImage={garden.seo.ogImage || garden.media.ogImage || undefined}
  canonicalPath={garden.seo.canonicalPath || '/garden'}
  activeNav="Garden"
  noindex={garden.seo.noindex}
>
  <main class="gp-garden-page">
    <section class="gp-garden-hero gp-topo">
      <Container size="2xl">
        <div class="gp-garden-hero-grid">
          <div class="gp-garden-hero-copy">
            <Overline segments={['Greenpill Garden', garden.framing || 'bridge']} />
            <Text variant="display">{title}</Text>
            <Text variant="body-lg">{summary}</Text>
            <div class="gp-garden-actions">
              <Button href={stickyCta.href || '#step-1'}>{stickyCta.label || 'Start with Step 1'}</Button>
            </div>
          </div>
          <div class="gp-garden-hero-mark" aria-hidden="true">
            <img
              src="/images/greenpill-logo.svg"
              alt=""
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </Container>
    </section>

    <Container size="2xl" class="gp-garden-stack">
      <section class="gp-garden-section">
        <SectionHeader title="The participation ramp." segments={['Garden', 'Ramp']}>
        </SectionHeader>
        <div class="gp-garden-steps">
          {steps.map((step, index) => {
            const level = step.level || index + 1;
            const stepHref = step.cta?.href || '';
            const external = isExternalHref(stepHref);
            return (
              <article class="gp-garden-step" id={`step-${level}`}>
                <div class="gp-garden-step-index">
                  <span>{String(level).padStart(2, '0')}</span>
                  <small>/ {String(steps.length).padStart(2, '0')}</small>
                </div>
                <div class="gp-garden-step-copy">
                  <Meta items={[step.kicker || 'Garden', step.meta || step.stage || 'Open path']} accentIndex={0} />
                  <Text variant="h3">{step.title}</Text>
                  <Text variant="body-sm">{step.body}</Text>
                  {level === 1 ? (
                    <form class="gp-garden-subscribe" data-garden-subscribe-form novalidate>
                      <EmailInput
                        label="Email address"
                        placeholder="you@example.com"
                        autocomplete="email"
                        required
                        aria-describedby="garden-subscribe-status"
                        data-garden-subscribe-email
                      />
                      <Button type="submit" data-garden-subscribe-submit>
                        {step.cta?.label || 'Subscribe'}
                      </Button>
                      <p
                        id="garden-subscribe-status"
                        class="gp-garden-subscribe-status"
                        data-garden-subscribe-status
                        aria-live="polite"
                      ></p>
                    </form>
                  ) : step.cta?.label && stepHref && (
                    <div class="gp-garden-step-action">
                      <Button
                        href={stepHref}
                        variant="ghost"
                        target={external ? '_blank' : undefined}
                        rel={external ? 'noopener noreferrer' : undefined}
                      >
                        {step.cta.label}
                      </Button>
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </section>
    </Container>
  </main>
</GpLayout>

<script>
  (() => {
    const form = document.querySelector('[data-garden-subscribe-form]');
    if (!(form instanceof HTMLFormElement)) return;

    const emailInput = form.querySelector('[data-garden-subscribe-email]');
    const submitButton = form.querySelector('[data-garden-subscribe-submit]');
    const status = form.querySelector('[data-garden-subscribe-status]');
    if (!(emailInput instanceof HTMLInputElement) || !(submitButton instanceof HTMLButtonElement) || !status) return;

    const clean = (value: unknown) => (typeof value === 'string' ? value.trim() : '');
    const isLocalHost = ['localhost', '127.0.0.1', '0.0.0.0', '::1'].includes(window.location.hostname);
    const agentBaseUrl = isLocalHost ? 'http://127.0.0.1:3303' : 'https://agent.greenpill.network';

    const setStatus = (message: string, state: 'idle' | 'submitting' | 'success' | 'error') => {
      status.textContent = message;
      status.setAttribute('data-state', state);
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const email = clean(emailInput.value).toLowerCase();
      emailInput.value = email;
      if (!email || !emailInput.checkValidity()) {
        setStatus('Enter a valid email address.', 'error');
        return;
      }

      submitButton.disabled = true;
      setStatus('Subscribing...', 'submitting');

      try {
        const response = await fetch(`${agentBaseUrl}/newsletter/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok !== true) {
          throw new Error('newsletter_subscribe_failed');
        }

        emailInput.value = '';
        setStatus('You are subscribed.', 'success');
      } catch {
        setStatus('Subscription is unavailable right now. Please try again later.', 'error');
      } finally {
        submitButton.disabled = false;
      }
    });
  })();
</script>

<style>
  .gp-garden-page {
    min-height: 100dvh;
    background: transparent;
  }

  .gp-garden-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-3xl), 8vw, var(--gp-space-5xl)) 0 var(--gp-space-4xl);
  }

  .gp-garden-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 320px);
    gap: clamp(var(--gp-space-2xl), 6vw, var(--gp-space-4xl));
    align-items: center;
  }

  .gp-garden-hero-copy,
  .gp-garden-step-copy {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-lg);
    min-width: 0;
  }

  .gp-garden-hero-copy {
    max-width: 850px;
  }

  .gp-garden-hero-copy :global(.gp-text.is-body-lg) {
    max-width: 720px;
    color: var(--gp-fg-muted);
  }

  .gp-garden-actions,
  .gp-garden-step-action {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .gp-garden-hero-mark {
    position: relative;
    isolation: isolate;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
  }

  .gp-garden-hero-mark::before {
    position: absolute;
    inset: 4%;
    border: 1px solid rgba(184, 232, 53, 0.2);
    border-radius: 50%;
    content: '';
  }

  .gp-garden-hero-mark::after {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184, 232, 53, 0.24), transparent 68%);
    content: '';
    filter: blur(18px);
    z-index: -1;
  }

  .gp-garden-hero-mark img {
    position: relative;
    z-index: 1;
    width: min(68%, 220px);
    height: auto;
    filter: drop-shadow(0 24px 64px rgba(184, 232, 53, 0.25));
  }

  .gp-garden-stack {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-2xl);
    padding-block: var(--gp-space-2xl) var(--gp-space-4xl);
  }

  .gp-garden-section {
    min-width: 0;
  }

  .gp-garden-steps {
    display: grid;
    gap: 0;
  }

  .gp-garden-step {
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr);
    gap: var(--gp-space-2xl);
    padding: var(--gp-space-2xl) 0;
    border-top: 1px solid var(--gp-border-soft);
    scroll-margin-block-start: calc(var(--gp-header-height) + var(--gp-space-lg));
  }

  .gp-garden-step:last-child {
    border-bottom: 1px solid var(--gp-border-soft);
  }

  .gp-garden-step-index {
    display: flex;
    align-items: baseline;
    gap: 8px;
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
  }

  .gp-garden-step-index span {
    font-size: 56px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
  }

  .gp-garden-step-index small {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .gp-garden-subscribe {
    display: flex;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: var(--gp-space-md);
    max-width: 620px;
  }

  .gp-garden-subscribe :global(.gp-email-field) {
    flex: 1 1 280px;
  }

  .gp-garden-subscribe-status {
    flex-basis: 100%;
    min-height: 1.4em;
    margin: 0;
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-body);
    font-size: var(--gp-body-sm);
    line-height: 1.4;
  }

  .gp-garden-subscribe-status[data-state='success'] {
    color: var(--gp-primary);
  }

  .gp-garden-subscribe-status[data-state='error'] {
    color: var(--gp-danger, #ff8a7a);
  }

  @container (max-width: 980px) {
    .gp-garden-hero-grid {
      grid-template-columns: 1fr;
    }

    .gp-garden-hero-mark {
      max-width: 340px;
    }
  }

  @container (max-width: 640px) {
    .gp-garden-step {
      grid-template-columns: 1fr;
      gap: var(--gp-space-lg);
      padding: var(--gp-space-xl) 0;
    }

    .gp-garden-step-index span {
      font-size: 42px;
    }

    .gp-garden-subscribe {
      align-items: stretch;
    }
  }
</style>
