---
import GpLayout from '../../layouts/GpLayout.astro';
import Container from '../../components/ui/Container.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Chip from '../../components/ui/Chip.astro';
import ArrowLink from '../../components/ui/ArrowLink.astro';
import Overline from '../../components/ui/Overline.astro';
import Text from '../../components/ui/Text.astro';
import Meta from '../../components/ui/Meta.astro';
import LinkRow from '../../components/ui/LinkRow.astro';
import Breadcrumb from '../../components/shell/Breadcrumb.astro';
import StatusChip from '../../components/ui/StatusChip.astro';
import {
  buildChapterImpactEndpoint,
  shouldRenderChapterImpactUi,
} from '@greenpill-network/shared/chapter-impact';
import {
  getOperationalChapterInitiatives,
  getOperationalChapters,
} from '../../lib/operational-content';

export async function getStaticPaths() {
  const items = await getOperationalChapters();
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const data = item.data;
const themes = (data.themeSlugs ?? []) as string[];
const links = (data.links ?? []).filter((l: any) => l.url);
const connectLinks = (data.connectLinks ?? []).filter((l: any) => l.url);
const proofSignals = data.proofSignals ?? [];
const stewardSlugs: string[] = data.stewardSlugs ?? [];
const stewardRecords = (data.stewards ?? []).filter((s: any) => s.name);
const relatedSlugs: string[] = data.relatedChapterSlugs ?? [];

function titleCase(slug: string) {
  return slug
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

const stewardEntries: { name: string; role?: string }[] = stewardRecords.length > 0
  ? stewardRecords.map((s: any) => ({ name: s.name as string, role: s.role as string | undefined }))
  : stewardSlugs.map((slug) => ({ name: titleCase(slug) }));

const allChapters = await getOperationalChapters();
const relatedChapters = relatedSlugs
  .map((slug) => allChapters.find((c) => c.id === slug))
  .filter((c): c is typeof allChapters[number] => Boolean(c));
const initiatives = await getOperationalChapterInitiatives(item.id);

const showImpact = shouldRenderChapterImpactUi(data.impactSources ?? {});
const impactEndpoint = showImpact ? buildChapterImpactEndpoint(item.id) : '';

function regionLabel(slug: string) {
  if (!slug) return 'Global';
  return slug.charAt(0).toUpperCase() + slug.slice(1);
}

function primaryInitiativeHref(initiative: any) {
  return (initiative.data.links ?? []).find((link: any) => link.url)?.url || '';
}
---

<GpLayout
  title={data.seo?.title || `${data.name} · Greenpill Chapter`}
  description={data.seo?.description || data.summary || `${data.name} chapter of the Greenpill Network.`}
  ogImage={data.seo?.ogImage || data.media?.ogImage || undefined}
  canonicalPath={data.seo?.canonicalPath || `/chapters/${item.id}`}
  noindex={data.seo?.noindex}
  activeNav="Chapters"
  ogType="profile"
>
  <main class="gp-chapter">
    <section class="gp-chapter-hero gp-topo">
      <Container size="2xl">
        <Breadcrumb
          back={{ label: 'All chapters', href: '/chapters' }}
          crumbs={[{ label: regionLabel(data.region || 'global') }, { label: data.name }]}
        />
        <div class="gp-chapter-hero-inner">
          <Overline>
            <span>Chapter</span>
            <span aria-hidden="true">·</span>
            <span>{regionLabel(data.region || 'global')}</span>
          </Overline>

          <Text variant="display" class="gp-chapter-name">{data.name}</Text>

          {data.city && (
            <Text variant="body-lg" class="gp-chapter-place">
              {data.city}{data.country && `, ${data.country}`}
            </Text>
          )}

          {data.summary && (
            <Text variant="body-lg" class="gp-chapter-summary">{data.summary}</Text>
          )}

          <div class="gp-chapter-chips">
            <StatusChip tone={data.status === 'forming' ? 'secondary' : 'primary'}>
              {(data.status || 'active').charAt(0).toUpperCase() + (data.status || 'active').slice(1)}
            </StatusChip>
            {themes.slice(0, 6).map((t) => (
              <Chip tone="soft-lime">{t.replace(/-/g, ' ')}</Chip>
            ))}
          </div>

          {(data.link || links.length > 0) && (
            <div class="gp-chapter-hero-actions">
              {data.link && <Button href={data.link} variant="ghost">Workspace</Button>}
              {links[0] && <Button href={links[0].url}>{links[0].action || links[0].label}</Button>}
            </div>
          )}
        </div>
      </Container>
    </section>

    {proofSignals.length > 0 && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Public proof</Overline>
            <Text variant="caption">Source-backed evidence anchoring this chapter profile.</Text>
          </div>
          <div class="gp-chapter-proof-grid">
            {proofSignals.map((signal: any) => (
              <a class="gp-chapter-proof" href={signal.href || '#'} target={signal.href ? '_blank' : undefined} rel="noopener">
                <Text variant="mono">{signal.source || 'Public source'}</Text>
                <Text variant="title-md" class="gp-chapter-proof-value">{signal.value}</Text>
                <Text variant="body-sm">{signal.label}</Text>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}

    {initiatives.length > 0 && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Initiatives</Overline>
            <Text variant="caption">{initiatives.length} chapter-owned effort{initiatives.length === 1 ? '' : 's'}</Text>
          </div>
          <div class="gp-chapter-initiative-grid">
            {initiatives.map((initiative) => {
              const href = primaryInitiativeHref(initiative);
              const initiativeThemes = (initiative.data.themeSlugs ?? []).slice(0, 4);
              const initiativeProof = initiative.data.proofSignals ?? [];
              const initiativeContent = (
                <>
                  <Meta items={['Initiative', initiative.data.status || 'active']} accentIndex={1} />
                  <Text variant="title-lg" class="gp-chapter-initiative-title">{initiative.data.title}</Text>
                  {initiative.data.summary && <Text variant="body-sm">{initiative.data.summary}</Text>}
                  {initiativeThemes.length > 0 && (
                    <div class="gp-chapter-initiative-themes">
                      {initiativeThemes.map((theme: string) => (
                        <Chip tone="soft-lime" size="sm">{theme.replace(/-/g, ' ')}</Chip>
                      ))}
                    </div>
                  )}
                  {initiativeProof.length > 0 && (
                    <div class="gp-chapter-initiative-proof">
                      {initiativeProof.slice(0, 2).map((signal: any) => (
                        <span>{signal.label}{signal.value ? ` · ${signal.value}` : ''}</span>
                      ))}
                    </div>
                  )}
                </>
              );
              if (!href) {
                return (
                  <article class="gp-chapter-initiative">
                    {initiativeContent}
                  </article>
                );
              }
              return (
                <a
                  class="gp-chapter-initiative"
                  href={href}
                  target={href?.startsWith('http') ? '_blank' : undefined}
                  rel={href?.startsWith('http') ? 'noopener' : undefined}
                >
                  {initiativeContent}
                </a>
              );
            })}
          </div>
        </Container>
      </section>
    )}

    {links.length > 0 && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Public links</Overline>
            <Text variant="caption">{links.length} source-backed destinations</Text>
          </div>
          <Card padded="lg">
            {links.map((link: any, index: number) => (
              <LinkRow
                href={link.url}
                label={link.label}
                sub={link.subtext}
                handle={link.handle}
                last={index === links.length - 1}
              />
            ))}
          </Card>
        </Container>
      </section>
    )}

    {showImpact && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Impact feed</Overline>
            <Text variant="caption">Public cache · refreshes on the agent service.</Text>
          </div>
          <Card
            padded="lg"
            class="gp-chapter-impact"
          >
            <div data-impact-section data-impact-endpoint={impactEndpoint}>
              <Text variant="body-sm" data-impact-loading>
                Loading chapter impact data...
              </Text>
              <Text variant="body-sm" data-impact-empty class="is-hidden">
                Impact source connected. Public updates will appear here after the cache publishes.
              </Text>
              <Text variant="body-sm" data-impact-error class="is-hidden">
                Impact source connected. Live impact data is temporarily unavailable.
              </Text>

              <div class="gp-chapter-impact-loaded is-hidden" data-impact-loaded>
                <dl class="gp-chapter-impact-stats">
                  <div>
                    <dt>Actions</dt>
                    <dd data-impact-stat="actionCount">0</dd>
                  </div>
                  <div>
                    <dt>Milestones</dt>
                    <dd data-impact-stat="milestoneCount">0</dd>
                  </div>
                  <div>
                    <dt>Updates</dt>
                    <dd data-impact-stat="updateCount">0</dd>
                  </div>
                  <div>
                    <dt>Proofs</dt>
                    <dd data-impact-stat="proofLinkCount">0</dd>
                  </div>
                </dl>
                <ul class="gp-chapter-impact-events" data-impact-events></ul>
              </div>

              <noscript>
                <Text variant="body-sm">Impact source connected. Enable JavaScript for live updates.</Text>
              </noscript>
            </div>
          </Card>
        </Container>
      </section>
    )}

    {connectLinks.length > 0 && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Connect</Overline>
            <Text variant="caption">Public, approved channels for this chapter.</Text>
          </div>
          <Card padded="lg">
            {connectLinks.map((link: any, index: number) => (
              <LinkRow
                href={link.url}
                label={link.label}
                sub={link.subtext}
                handle={link.handle}
                last={index === connectLinks.length - 1}
              />
            ))}
          </Card>
        </Container>
      </section>
    )}

    {stewardEntries.length > 0 && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Public stewards</Overline>
            <Text variant="caption">{stewardEntries.length} steward{stewardEntries.length === 1 ? '' : 's'}</Text>
          </div>
          <div class="gp-chapter-stewards">
            {stewardEntries.map((s) => (
              <Chip tone="soft-gold">
                {s.name}{s.role ? ` · ${s.role}` : ''}
              </Chip>
            ))}
          </div>
        </Container>
      </section>
    )}

    {relatedChapters.length > 0 && (
      <section class="gp-chapter-section">
        <Container size="2xl">
          <div class="gp-chapter-section-head">
            <Overline>Related chapters</Overline>
            <ArrowLink href="/chapters">See all chapters</ArrowLink>
          </div>
          <div class="gp-chapter-related-grid">
            {relatedChapters.map((c) => (
              <a class="gp-chapter-related-card" href={`/chapters/${c.id}`}>
                <Meta items={[regionLabel(c.data.region || 'global'), c.data.status || 'active']} accentIndex={1} />
                <Text variant="title-lg" class="gp-chapter-related-title">{c.data.name}</Text>
                {c.data.city && (
                  <Text variant="caption">{c.data.city}{c.data.country && `, ${c.data.country}`}</Text>
                )}
                <Text variant="body-sm">{c.data.summary}</Text>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}

    <section class="gp-chapter-cta">
      <Container size="2xl">
        <div class="gp-chapter-cta-inner">
          <div>
            <Overline>Get involved</Overline>
            <Text variant="h2">Bring this work into your city.</Text>
            <Text variant="body" class="gp-chapter-cta-body">
              The Garden is the public ramp to find people, learn what local chapters are doing, and book a steward
              conversation when you are ready.
            </Text>
          </div>
          <div class="gp-chapter-cta-actions">
            <Button href="/garden">Enter the Garden</Button>
            <Button href="/chapters" variant="ghost">All chapters</Button>
          </div>
        </div>
      </Container>
    </section>
  </main>
</GpLayout>

{showImpact && (
  <script is:inline>
    const numberFormatter = new Intl.NumberFormat('en');
    const visible = (element, shouldShow) => {
      if (!element) return;
      element.classList.toggle('is-hidden', !shouldShow);
    };
    const setText = (root, selector, value) => {
      const element = root.querySelector(selector);
      if (element) element.textContent = String(value);
    };
    const renderEvents = (root, payload) => {
      const list = root.querySelector('[data-impact-events]');
      if (!list) return;
      list.textContent = '';
      const events = [
        ...(payload?.karma?.milestones ?? []),
        ...(payload?.karma?.updates ?? []),
        ...(payload?.proofLinks ?? []),
      ].slice(0, 5);
      for (const event of events) {
        const item = document.createElement('li');
        item.className = 'gp-chapter-impact-event';
        const label = event.title || event.label || event.url || 'Impact proof';
        if (event.url) {
          const link = document.createElement('a');
          link.href = event.url;
          link.target = '_blank';
          link.rel = 'noopener';
          link.textContent = label;
          item.append(link);
        } else {
          item.textContent = label;
        }
        list.append(item);
      }
    };
    const renderImpact = (root, payload) => {
      const summary = payload?.summary ?? {};
      for (const key of ['actionCount', 'milestoneCount', 'updateCount', 'proofLinkCount']) {
        setText(root, '[data-impact-stat="' + key + '"]', numberFormatter.format(summary[key] ?? 0));
      }
      renderEvents(root, payload);
      visible(root.querySelector('[data-impact-loading]'), false);
      visible(root.querySelector('[data-impact-error]'), false);
      visible(root.querySelector('[data-impact-empty]'), false);
      visible(root.querySelector('[data-impact-loaded]'), true);
    };
    const renderEmpty = (root) => {
      visible(root.querySelector('[data-impact-loading]'), false);
      visible(root.querySelector('[data-impact-loaded]'), false);
      visible(root.querySelector('[data-impact-error]'), false);
      visible(root.querySelector('[data-impact-empty]'), true);
    };
    const renderError = (root) => {
      visible(root.querySelector('[data-impact-loading]'), false);
      visible(root.querySelector('[data-impact-loaded]'), false);
      visible(root.querySelector('[data-impact-empty]'), false);
      visible(root.querySelector('[data-impact-error]'), true);
    };
    for (const root of document.querySelectorAll('[data-impact-section]')) {
      const endpoint = root.getAttribute('data-impact-endpoint');
      if (!endpoint) { renderEmpty(root); continue; }
      fetch(endpoint, { headers: { Accept: 'application/json' } })
        .then((response) => {
          if (!response.ok) throw new Error('Impact request failed with ' + response.status);
          return response.json();
        })
        .then((payload) => {
          const summary = payload?.summary ?? {};
          const hasAnyData = Object.values(summary).some((value) => Number(value) > 0);
          if (!hasAnyData && !payload?.karma && !payload?.greenGoods) { renderEmpty(root); return; }
          renderImpact(root, payload);
        })
        .catch(() => renderError(root));
    }
  </script>
)}

<style>
  .gp-chapter {
    min-height: 100dvh;
    background: transparent;
  }

  .gp-chapter-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-2xl), 6vw, var(--gp-space-4xl)) 0 var(--gp-space-2xl);
  }

  .gp-chapter-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    margin-top: var(--gp-space-xl);
  }

  .gp-chapter-hero-inner :global(.gp-chapter-name) {
    max-width: 18ch;
    font-size: var(--gp-display-size);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .gp-chapter-hero-inner :global(.gp-chapter-place),
  .gp-chapter-hero-inner :global(.gp-chapter-summary) {
    color: var(--gp-fg-muted);
    max-width: 70ch;
  }

  .gp-chapter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gp-chapter-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: var(--gp-space-md);
  }

  .gp-chapter-section {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-3xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-chapter-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--gp-space-md);
    flex-wrap: wrap;
    margin-bottom: var(--gp-space-lg);
  }

  .gp-chapter-proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-chapter-proof {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-chapter-proof:hover {
    border-color: rgba(184, 232, 53, 0.42);
    background: var(--gp-card-elev);
  }

  .gp-chapter-proof-value {
    color: var(--gp-primary);
    font-family: var(--gp-font-display);
    font-size: var(--gp-h3-size);
    font-weight: 500;
    letter-spacing: 0;
  }

  .gp-chapter-stewards {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gp-chapter-initiative-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-chapter-initiative {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-chapter-initiative:hover {
    border-color: rgba(184, 232, 53, 0.32);
    background: var(--gp-card-elev);
  }

  article.gp-chapter-initiative:hover {
    border-color: var(--gp-border-soft);
    background: var(--gp-card);
  }

  .gp-chapter-initiative :global(.gp-chapter-initiative-title) {
    letter-spacing: 0;
  }

  .gp-chapter-initiative-themes {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gp-chapter-initiative-proof {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: auto;
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .gp-chapter-impact .is-hidden {
    display: none;
  }

  .gp-chapter-impact-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--gp-space-md);
    margin: 0 0 var(--gp-space-lg);
    padding: 0;
  }

  .gp-chapter-impact-stats div {
    padding: var(--gp-space-md);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    background: rgba(15, 61, 46, 0.45);
  }

  .gp-chapter-impact-stats dt {
    margin: 0;
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gp-chapter-impact-stats dd {
    margin: 4px 0 0;
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
  }

  .gp-chapter-impact-events {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
  }

  .gp-chapter-impact-event {
    padding: 10px 14px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    background: rgba(15, 61, 46, 0.45);
    font-family: var(--gp-font-body);
    font-size: 13px;
    color: var(--gp-fg-muted);
  }

  .gp-chapter-impact-event a {
    color: var(--gp-primary);
    text-decoration: none;
  }

  .gp-chapter-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-chapter-related-card {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-chapter-related-card:hover {
    border-color: rgba(184, 232, 53, 0.32);
    background: var(--gp-card-elev);
  }

  .gp-chapter-related-card :global(.gp-chapter-related-title) {
    letter-spacing: 0;
  }

  .gp-chapter-cta {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-chapter-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--gp-space-2xl);
    padding: clamp(var(--gp-space-xl), 4vw, var(--gp-space-3xl));
    border: 1px solid rgba(184, 232, 53, 0.32);
    border-radius: var(--gp-radius-xl);
    background: linear-gradient(135deg, rgba(184, 232, 53, 0.06), rgba(15, 61, 46, 0.5));
  }

  .gp-chapter-cta-inner > div:first-child {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    max-width: 540px;
  }

  .gp-chapter-cta-body {
    color: var(--gp-fg-muted);
  }

  .gp-chapter-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @container (max-width: 720px) {
    .gp-chapter-cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
