---
import GpLayout from '../../layouts/GpLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import Overline from '../../components/ui/Overline.astro';
import Text from '../../components/ui/Text.astro';
import Meta from '../../components/ui/Meta.astro';
import AvatarStack from '../../components/ui/AvatarStack.astro';
import chaptersIndex from '../../content/chapters-index.json';
import { getOperationalChapters } from '../../lib/operational-content';

const all = await getOperationalChapters();

const directory = [...all]
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const totals = {
  total: all.length,
  active: all.filter((c) => c.data.status === 'active').length,
  forming: all.filter((c) => c.data.status === 'forming').length,
  regions: new Set(all.map((c) => c.data.region).filter(Boolean)).size,
};

const regionOrder = ['americas', 'africa', 'asia', 'europe', 'oceania'];
const allRegions = Array.from(
  new Set(all.map((c) => c.data.region || 'global')),
).sort((a, b) => {
  const ai = regionOrder.indexOf(a);
  const bi = regionOrder.indexOf(b);
  if (ai === -1 && bi === -1) return a.localeCompare(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});

function regionLabel(slug: string) {
  if (!slug) return 'Global';
  return slug.charAt(0).toUpperCase() + slug.slice(1);
}

function titleCase(slug: string) {
  return slug
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

function stewardNamesFor(chapter: typeof all[number]) {
  const stewardNames = (chapter.data.stewards ?? [])
    .map((steward: any) => steward.name)
    .filter(Boolean);

  if (stewardNames.length > 0) return stewardNames;

  return (chapter.data.stewardSlugs ?? [])
    .map((slug: string) => titleCase(slug))
    .filter(Boolean);
}

function approvedImageFor(chapter: typeof all[number]) {
  const media = chapter.data.media ?? {};
  const seo = chapter.data.seo ?? {};
  if (media.reviewStatus !== 'approved') return '';
  return media.image || chapter.data.image || media.ogImage || seo.ogImage || '';
}

const hero = chaptersIndex.hero ?? {};
---

<GpLayout
  title={chaptersIndex.seo?.title || 'Chapters · Greenpill Network'}
  description={chaptersIndex.seo?.description || 'Local chapters of the Greenpill regenerative network.'}
  ogImage={chaptersIndex.seo?.ogImage || undefined}
  canonicalPath={chaptersIndex.seo?.canonicalPath || '/chapters'}
  noindex={chaptersIndex.seo?.noindex}
  activeNav="Chapters"
>
  <main class="gp-chapters">
    <section class="gp-chapters-hero gp-topo">
      <Container size="2xl">
        <div class="gp-chapters-hero-inner">
          <Overline tone="muted">
            <span>Chapters</span>
            <span aria-hidden="true">·</span>
            <span>{totals.total} nodes</span>
          </Overline>

          <Text variant="display" class="gp-chapters-hero-title">{hero.title || 'The local nodes of the Greenpill network.'}</Text>

          <Text variant="body-lg" class="gp-chapters-hero-dek">
            {hero.dek || 'Active and forming chapters across multiple regions — local hubs running public-goods work, education, events, and onchain coordination.'}
          </Text>

          <div class="gp-chapters-stat-strip">
            <div class="gp-chapters-stat">
              <span class="gp-chapters-stat-big">{totals.total}</span>
              <span class="gp-chapters-stat-sub">Chapters</span>
            </div>
            <div class="gp-chapters-stat is-accent">
              <span class="gp-chapters-stat-big">{totals.active}</span>
              <span class="gp-chapters-stat-sub">Active</span>
            </div>
            {totals.forming > 0 && (
              <div class="gp-chapters-stat">
                <span class="gp-chapters-stat-big">{totals.forming}</span>
                <span class="gp-chapters-stat-sub">Forming</span>
              </div>
            )}
            <div class="gp-chapters-stat">
              <span class="gp-chapters-stat-big">{totals.regions}</span>
              <span class="gp-chapters-stat-sub">Regions</span>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <section class="gp-chapters-filters">
      <Container size="2xl">
        <div class="gp-chapters-filter-row" data-gp-filters>
          <div class="gp-chapters-filter-group" role="radiogroup" aria-label="Filter chapters by region">
            <button class="gp-chapters-pill is-active" data-region="all" type="button">All</button>
            {allRegions.map((region) => (
              <button class="gp-chapters-pill" data-region={region} type="button">{regionLabel(region)}</button>
            ))}
          </div>
          <div class="gp-chapters-filter-group" aria-label="Filter chapters by status">
            <button class="gp-chapters-pill is-mono is-active" data-status="active" type="button" aria-pressed="true">Active · {totals.active}</button>
            {totals.forming > 0 && (
              <button class="gp-chapters-pill is-mono is-active" data-status="forming" type="button" aria-pressed="true">Forming · {totals.forming}</button>
            )}
          </div>
        </div>
      </Container>
    </section>

    {directory.length > 0 && (
      <section class="gp-chapters-section">
        <Container size="2xl">
          <div class="gp-chapters-grid is-directory" data-chapter-grid>
            {directory.map((chapter) => {
              const stewardNames = stewardNamesFor(chapter);
              const chapterImage = approvedImageFor(chapter);
              return (
                <a
                  class="gp-chapters-card is-directory"
                  href={`/chapters/${chapter.id}`}
                  data-region={chapter.data.region || 'global'}
                  data-status={chapter.data.status || 'active'}
                >
                  {chapterImage && (
                    <div class="gp-chapters-card-media">
                      <img
                        src={chapterImage}
                        alt={chapter.data.media?.imageAlt || `${chapter.data.name} chapter activity`}
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="gp-chapters-card-body">
                    <Meta items={[regionLabel(chapter.data.region || 'global'), chapter.data.status || 'active']} accentIndex={1} />
                    <Text variant="title-lg" class="gp-chapters-card-title">{chapter.data.name}</Text>
                    {chapter.data.city && (
                      <Text variant="caption">{chapter.data.city}{chapter.data.country && `, ${chapter.data.country}`}</Text>
                    )}
                    {chapter.data.summary && (
                      <Text variant="body-sm" class="gp-chapters-card-summary">{chapter.data.summary}</Text>
                    )}
                    {stewardNames.length > 0 && (
                      <div class="gp-chapters-card-stewards is-directory">
                        <AvatarStack names={stewardNames} count={Math.min(stewardNames.length, 3)} extra={Math.max(0, stewardNames.length - 3)} size={24} />
                        <Text variant="mono">{stewardNames.length}</Text>
                      </div>
                    )}
                    <span class="gp-chapters-card-arrow" aria-hidden="true">→</span>
                  </div>
                </a>
              );
            })}
          </div>

          <p class="gp-chapters-empty" data-chapter-empty hidden>
            {chaptersIndex.filterCopy?.emptyState || 'No chapters match this filter yet.'}
          </p>
        </Container>
      </section>
    )}

    <section class="gp-chapters-cta">
      <Container size="2xl">
        <div class="gp-chapters-cta-inner">
          <div>
            <Overline>Start a chapter</Overline>
            <Text variant="h2">Do not see your city?</Text>
            <Text variant="body" class="gp-chapters-cta-body">
              Chapters start with public goods, shared learning, and small in-person gatherings. The Garden is the
              public ramp to find your people and connect with a steward.
            </Text>
          </div>
          <div class="gp-chapters-cta-actions">
            <Button href="/garden">Enter the Garden</Button>
            <Button href="https://hub.regencoordination.xyz/c/updates/chapter-updates/14" variant="ghost">Read chapter updates</Button>
          </div>
        </div>
      </Container>
    </section>
  </main>
</GpLayout>

<script>
  const filterRow = document.querySelector('[data-gp-filters]');
  if (filterRow) {
    let region = 'all';
    const status = new Set(['active', 'forming']);
    const grids = document.querySelectorAll('[data-chapter-grid]');
    const empty = document.querySelector('[data-chapter-empty]');

    const apply = () => {
      let shown = 0;
      grids.forEach((grid) => {
        grid.querySelectorAll('[data-region]').forEach((card) => {
          const el = card as HTMLElement;
          const r = el.dataset.region || 'global';
          const s = el.dataset.status || 'active';
          const regionMatch = region === 'all' || r === region;
          const statusMatch = status.has(s);
          const visible = regionMatch && statusMatch;
          el.hidden = !visible;
          if (visible) shown += 1;
        });
      });
      if (empty) (empty as HTMLElement).hidden = shown > 0;
    };

    filterRow.querySelectorAll('[data-region]').forEach((btn) => {
      btn.addEventListener('click', () => {
        region = (btn as HTMLElement).dataset.region || 'all';
        filterRow.querySelectorAll('[data-region]').forEach((b) => b.classList.toggle('is-active', b === btn));
        apply();
      });
    });

    filterRow.querySelectorAll('[data-status]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const s = (btn as HTMLElement).dataset.status || '';
        if (status.has(s)) {
          if (status.size === 1) return;
          status.delete(s);
        } else {
          status.add(s);
        }
        btn.classList.toggle('is-active', status.has(s));
        btn.setAttribute('aria-pressed', String(status.has(s)));
        apply();
      });
    });
  }
</script>

<style>
  .gp-chapters {
    min-height: 100dvh;
    background: transparent;
  }

  .gp-chapters-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-3xl), 7vw, var(--gp-space-5xl)) 0 var(--gp-space-2xl);
  }

  .gp-chapters-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(var(--gp-space-lg), 3vw, var(--gp-space-xl));
  }

  .gp-chapters-hero-inner :global(.gp-chapters-hero-title) {
    max-width: 18ch;
    font-size: var(--gp-display-size);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .gp-chapters-hero-inner :global(.gp-chapters-hero-dek) {
    max-width: 60ch;
    color: var(--gp-fg-muted);
  }

  .gp-chapters-stat-strip {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(var(--gp-space-lg), 3vw, var(--gp-space-2xl));
    padding-top: var(--gp-space-lg);
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-chapters-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gp-chapters-stat-big {
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: var(--gp-h2-size);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0;
  }

  .gp-chapters-stat.is-accent .gp-chapters-stat-big {
    color: var(--gp-primary);
  }

  .gp-chapters-stat-sub {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gp-chapters-filters {
    padding: var(--gp-space-xl) 0;
    border-top: 1px solid var(--gp-border-soft);
    border-bottom: 1px solid var(--gp-border-soft);
    background: rgba(15, 61, 46, 0.4);
    position: sticky;
    top: var(--gp-header-height);
    z-index: 10;
    backdrop-filter: blur(8px);
  }

  .gp-chapters-filter-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--gp-space-md);
  }

  .gp-chapters-filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .gp-chapters-pill {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 36px;
    padding: 0 14px;
    border: 1px solid var(--gp-border);
    border-radius: var(--gp-radius-pill);
    background: transparent;
    color: var(--gp-fg-muted);
    font-family: var(--gp-font-body);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (hover: none) and (pointer: coarse) {
    .gp-chapters-pill { height: 44px; padding: 0 18px; }
  }

  .gp-chapters-pill.is-mono {
    font-family: var(--gp-font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 11px;
  }

  .gp-chapters-pill:hover {
    color: var(--gp-fg);
    border-color: rgba(184, 232, 53, 0.42);
  }

  .gp-chapters-pill.is-active {
    background: var(--gp-primary);
    border-color: var(--gp-primary);
    color: var(--gp-primary-fg);
  }

  .gp-chapters-section {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-chapters-grid {
    display: grid;
    gap: clamp(14px, 1.5vw, 20px);
  }

  .gp-chapters-grid.is-directory {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .gp-chapters-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    min-width: 0;
    overflow: hidden;
    transition: border-color 200ms cubic-bezier(0.4, 0, 0.2, 1), background 200ms cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .gp-chapters-card:hover {
    border-color: rgba(184, 232, 53, 0.32);
  }

  a.gp-chapters-card:hover {
    background: var(--gp-card-elev);
  }

  .gp-chapters-card-media {
    width: 100%;
    overflow: hidden;
    border-bottom: 1px solid var(--gp-border-soft);
    background: rgba(10, 45, 33, 0.52);
  }

  .gp-chapters-card-media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gp-chapters-card:hover .gp-chapters-card-media img {
    transform: scale(1.02);
  }

  .gp-chapters-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--gp-space-sm);
    min-height: 218px;
    padding: var(--gp-space-lg);
    position: relative;
  }

  .gp-chapters-card-title {
    letter-spacing: 0;
    transition: color 200ms;
  }

  .gp-chapters-card-summary {
    color: var(--gp-fg-muted);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .gp-chapters-card-stewards {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    gap: 8px;
  }

  .gp-chapters-card-stewards :global(.gp-avatar-extra) {
    display: none;
  }

  .gp-chapters-card-stewards :global(.gp-text) {
    color: var(--gp-fg-dim);
    white-space: nowrap;
  }

  .gp-chapters-card-stewards.is-directory {
    margin-top: auto;
    padding-top: var(--gp-space-sm);
  }

  .gp-chapters-card.is-directory {
    padding: 0;
  }

  .gp-chapters-card.is-directory .gp-chapters-card-arrow {
    position: absolute;
    bottom: var(--gp-space-lg);
    right: var(--gp-space-lg);
    color: var(--gp-fg-dim);
    transition: color 200ms, transform 200ms;
  }

  .gp-chapters-card.is-directory:hover .gp-chapters-card-arrow {
    color: var(--gp-primary);
    transform: translateX(3px);
  }

  .gp-chapters-empty {
    color: var(--gp-fg-muted);
    text-align: center;
    padding: var(--gp-space-2xl) 0;
  }

  .gp-chapters-cta {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-chapters-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--gp-space-2xl);
    padding: clamp(var(--gp-space-xl), 4vw, var(--gp-space-3xl));
    border: 1px solid rgba(184, 232, 53, 0.32);
    border-radius: var(--gp-radius-xl);
    background: linear-gradient(135deg, rgba(184, 232, 53, 0.06), rgba(15, 61, 46, 0.5));
  }

  .gp-chapters-cta-inner > div:first-child {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    max-width: 540px;
  }

  .gp-chapters-cta-body {
    color: var(--gp-fg-muted);
  }

  .gp-chapters-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @container (max-width: 1100px) {
    .gp-chapters-grid.is-directory {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gp-chapters-cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @container (max-width: 720px) {
    .gp-chapters-filters {
      position: static;
    }

    .gp-chapters-filter-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .gp-chapters-grid.is-directory {
      grid-template-columns: 1fr;
    }

    .gp-chapters-card-body {
      min-height: auto;
    }

    /* 44px minimum touch targets at mobile width (DESIGN.md rule 12). The
       coarse-pointer rule above covers touch devices; this covers the narrow
       viewport the verifier renders. */
    .gp-chapters-pill {
      min-height: 44px;
      padding-inline: 18px;
    }

  }
</style>
