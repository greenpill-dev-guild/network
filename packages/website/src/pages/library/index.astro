---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import library from '../../content/library.json';
import '../../styles/global.css';

const books = (await getCollection('books')).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);
---

<BaseLayout
  title={library.seo.title || 'Library · Greenpill Network'}
  description={library.seo.description || 'Books, podcasts, tools, and toolkit from the Greenpill regenerative network.'}
  ogImage={library.seo.ogImage || undefined}
  canonicalPath={library.seo.canonicalPath || '/library'}
  noindex={library.seo.noindex}
>
  <Nav />
  <main class="pt-32 pb-24 px-4 max-w-6xl mx-auto">
    <header class="mb-12">
      <span class="text-xs uppercase font-bold text-green tracking-widest">Library</span>
      <h1 class="font-volkhov text-4xl sm:text-5xl text-yellow mt-2">The Library</h1>
      <p class="text-white text-base sm:text-lg mt-4 max-w-2xl opacity-80">
        Books, podcasts, tools, and toolkit from across the Greenpill network. This page is a stub — the unified Library experience (filters, canvas pages) is part of the V2 redesign.
      </p>
    </header>

    <section class="mb-12">
      <h2 class="font-volkhov text-2xl text-yellow mb-5">Books</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
        {books.map(book => (
          <a href={book.data.ebookLink} class="block rounded-2xl border border-green bg-black bg-opacity-40 backdrop-blur-md p-5 transition-all hover:bg-opacity-60">
            {book.data.image && (
              <img
                src={book.data.image}
                alt={book.data.imageAlt}
                width={book.data.imageWidth}
                height={book.data.imageHeight}
                class="w-full h-auto rounded mb-3"
                style={book.data.imageStyle}
              />
            )}
            <h3 class="font-volkhov text-lg text-yellow">{book.data.title}</h3>
            {book.data.translations.length > 0 && (
              <span class="text-xs text-green mt-1 inline-block">
                {book.data.translations.length} translation{book.data.translations.length === 1 ? '' : 's'}
              </span>
            )}
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="font-volkhov text-2xl text-yellow mb-5">Podcast & Tools</h2>
      <p class="text-white opacity-80">
        Podcast episodes and network tooling are also part of the library — see the homepage podcast section and the <a href="/projects" class="text-green hover:text-[var(--mid-green)]">Projects</a> page until the unified Library lands.
      </p>
    </section>
  </main>
  <Footer />
  <script>
    import '../../scripts/mobile-menu';
  </script>
</BaseLayout>
