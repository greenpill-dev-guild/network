---
import { getCollection } from 'astro:content';
import GpLayout from '../../layouts/GpLayout.astro';
import { getOperationalGuilds } from '../../lib/operational-content';
import { publicGuildPath } from '../../lib/public-routes';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import ArrowLink from '../../components/ui/ArrowLink.astro';
import Overline from '../../components/ui/Overline.astro';
import Text from '../../components/ui/Text.astro';
import Meta from '../../components/ui/Meta.astro';
import library from '../../content/library.json';
import podcastFeed from '../../data/podcast-feed-snapshot.json';

const books = (await getCollection('books')).sort(
  (a, b) => (a.data.sortOrder ?? 0) - (b.data.sortOrder ?? 0),
);

const allResources = await getCollection('resources');
const resourceRank = new Map((library.featuredResourceSlugs ?? []).map((slug, index) => [slug, index]));
const resources = allResources
  .filter((r) => r.data.status === 'published')
  .sort((a, b) => (resourceRank.get(a.id) ?? 99) - (resourceRank.get(b.id) ?? 99));

const podcastResource = resources.find((r) => r.id === 'greenpill-podcast');
const guilds = (await getOperationalGuilds())
  .filter((guild) => !guild.data.seo?.noindex)
  .sort((a, b) => (
    Number(b.data.featuredWeight ?? 0) - Number(a.data.featuredWeight ?? 0) ||
    String(a.data.name ?? a.id).localeCompare(String(b.data.name ?? b.id))
  ));

const hero = library.hero ?? {};
const podcastEpisodes = `${podcastFeed.episodeCount} episodes`;
const recentPodcastEpisodes = podcastFeed.episodes ?? [];
const featuredEpisode = recentPodcastEpisodes[0];
const listedEpisodes = recentPodcastEpisodes.slice(1, 4);
const podcastArchiveHref = podcastFeed.archiveUrl || podcastResource?.data.primaryUrl || 'https://podcasts.apple.com/us/podcast/greenpill/id1609313639';
const podcastCoverImage = podcastFeed.image || '/images/podcast-cover.png';
const podcastUpdated = formatDate(podcastFeed.lastBuildDate);
const gardenGuideResources = ['greenpill-garden-season-one', 'regen-protocols']
  .map((slug) => resources.find((resource) => resource.id === slug))
  .filter((resource): resource is typeof resources[number] => Boolean(resource));
const gardenGuides = [
  ...gardenGuideResources.map((resource) => ({
    title: resource.data.card?.title || resource.data.title,
    summary: resource.data.card?.summary || resource.data.summary || resource.data.description,
    href: resource.data.primaryUrl || resource.data.card?.href || '/garden',
    meta: resource.data.readTime || resource.data.publishDate || 'Public guide',
    updated: resource.data.updatedDate || resource.data.publishDate || 'Public source',
    authors: resource.data.author || 'Network stewards',
    topics: (resource.data.themeSlugs ?? []).slice(0, 3).map(titleCaseTheme),
  })),
  {
    title: library.gardenCard?.title || 'Enter the Garden',
    summary: library.gardenCard?.summary || 'A public onboarding ramp from a light newsletter subscription to a high-intent steward call.',
    href: library.gardenCard?.href || '/garden',
    meta: 'Public ramp',
    updated: 'Live page',
    authors: 'Network stewards',
    topics: ['Onboarding', 'Stewardship', 'Coordination'],
  },
];
const libraryStats = [
  { value: String(books.length), label: 'Books' },
  { value: podcastEpisodes, label: 'Podcast archive' },
  { value: String(guilds.length), label: guilds.length === 1 ? 'Guild' : 'Guilds' },
  { value: String(gardenGuides.length), label: gardenGuides.length === 1 ? 'Garden guide' : 'Garden guides' },
];

function titleCaseTheme(slug: string) {
  return slug
    .split('-')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function formatDate(value: string) {
  if (!value) return '';
  const date = new Date(value);
  if (Number.isNaN(date.valueOf())) return '';
  return new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(date);
}

function episodeMeta(episode: typeof recentPodcastEpisodes[number]) {
  return [
    episode.season ? `Season ${episode.season}` : 'Podcast',
    episode.episode ? `Ep ${episode.episode}` : '',
    formatDate(episode.publishedAt),
    episode.duration,
  ].filter(Boolean);
}

function guildHref(guild: typeof guilds[number]) {
  return (
    publicGuildPath(guild.id || guild.slug) ||
    (guild.data.links ?? []).find((link) => link.url)?.url ||
    (guild.data.connectLinks ?? []).find((link) => link.url)?.url ||
    '#'
  );
}

function guildFootLabel(guild: typeof guilds[number]) {
  return publicGuildPath(guild.id || guild.slug)
    ? `${(guild.data.proofSignals ?? []).length || 'Public'} proof sources`
    : 'Visit guild site';
}
---

<GpLayout
  title={library.seo?.title || 'Library · Greenpill Network'}
  description={library.seo?.description || 'Books, podcast episodes, public docs, and Garden onboarding material.'}
  ogImage={library.seo?.ogImage || undefined}
  canonicalPath={library.seo?.canonicalPath || '/library'}
  noindex={library.seo?.noindex}
  activeNav="Library"
>
  <main class="gp-library">
    <section class="gp-library-hero gp-topo">
      <Container size="2xl">
        <div class="gp-library-hero-inner">
          <Overline tone="muted">
            <span>Library</span>
            <span aria-hidden="true">·</span>
            <span>Public knowledge commons</span>
          </Overline>

          <Text variant="display" class="gp-library-hero-title">{hero.title || 'Everything we have made public.'}</Text>

          <Text variant="body-lg" class="gp-library-hero-dek">
            {hero.dek || 'Books, podcast conversations, Hub threads, project docs, and Garden resources from across the Greenpill network.'}
          </Text>

          <div class="gp-library-hero-actions">
            <Button href="#books">{hero.primaryCta?.label || 'Browse books'}</Button>
	            <Button
	              href={hero.secondaryCta?.href || '#podcast'}
	              variant="ghost"
	            >
              {hero.secondaryCta?.label || 'Listen to the podcast'}
            </Button>
          </div>

          <div class="gp-library-stat-strip">
            {libraryStats.map((stat, index) => (
              <div class:list={['gp-library-stat', { 'is-accent': index === 1 }]}>
                <span class="gp-library-stat-big">{stat.value}</span>
                <span class="gp-library-stat-sub">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <section class="gp-library-section" id="books">
      <Container size="2xl">
        <div class="gp-library-section-head">
          <div class="gp-library-section-head-copy">
            <Overline>Books · {books.length} titles</Overline>
            <Text variant="h2">The foundation shelf.</Text>
            <Text variant="body" class="gp-library-section-dek">
              Open-source books on regenerative crypto, public goods, capital allocation, local regeneration,
              and onchain impact networks.
            </Text>
          </div>
          <Text variant="mono">All free · multiple languages</Text>
        </div>

        <div class="gp-library-books-grid">
          {books.map((book, index) => (
            <a class="gp-library-book" href={book.data.ebookLink || '#'} target={book.data.ebookLink?.startsWith('http') ? '_blank' : undefined} rel="noopener">
              <span class="gp-library-book-index">{String(index + 1).padStart(2, '0')}</span>
              <span class="gp-library-book-cover">
                {book.data.image && (
                  <img
                    src={book.data.image}
                    alt={book.data.imageAlt}
                    width={book.data.imageWidth ?? 200}
                    height={book.data.imageHeight ?? 300}
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </span>
              <div class="gp-library-book-meta">
                <Text variant="title-md" class="gp-library-book-title">{book.data.title}</Text>
                {book.data.author && <Text variant="caption">{book.data.author}{book.data.publishYear && ` · ${book.data.publishYear}`}</Text>}
                {book.data.translations.length > 0 && (
                  <Text variant="mono">{book.data.translations.length} translations</Text>
                )}
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>

    {featuredEpisode && (
      <section class="gp-library-section" id="podcast">
        <Container size="2xl">
          <div class="gp-library-section-head">
            <div class="gp-library-section-head-copy">
              <Overline>Podcast · {podcastEpisodes}</Overline>
              <Text variant="h2">A long-running public conversation.</Text>
              <Text variant="body" class="gp-library-section-dek">
                Recent episodes from the GreenPill RSS feed, playable directly on the site.
              </Text>
            </div>
            <div class="gp-library-podcast-links">
              <ArrowLink href={podcastArchiveHref}>Apple Podcasts</ArrowLink>
              <ArrowLink href={podcastFeed.sourceUrl} tone="muted">RSS feed</ArrowLink>
            </div>
          </div>

          <div class="gp-library-podcast-layout">
            <article class="gp-library-podcast-feature">
              <div class="gp-library-podcast-cover">
                <img
                  src={featuredEpisode.image || podcastCoverImage}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="gp-library-podcast-copy">
                <Meta items={['Latest episode', ...episodeMeta(featuredEpisode)]} accentIndex={0} />
                <Text variant="h3" class="gp-library-podcast-title">{featuredEpisode.title}</Text>
                <Text variant="body-sm" class="gp-library-podcast-summary">{featuredEpisode.summary || podcastFeed.description || podcastResource?.data.summary}</Text>
              </div>
              <audio class="gp-library-audio gp-library-feature-audio" controls preload="none">
                <source src={featuredEpisode.audioUrl} type={featuredEpisode.audioType || 'audio/mpeg'} />
                Your browser does not support the audio element.
              </audio>
              <div class="gp-library-episode-source">
                <a href={featuredEpisode.link}>Episode notes</a>
                {podcastUpdated && <span>Feed updated {podcastUpdated}</span>}
              </div>
            </article>

            <div class="gp-library-episode-list" aria-label="Featured public episodes">
              {listedEpisodes.map((episode) => (
                <article class="gp-library-episode-row">
                  <img
                    class="gp-library-episode-image"
                    src={episode.image || podcastCoverImage}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="gp-library-episode-copy">
                    <Meta items={episodeMeta(episode)} accentIndex={1} />
                    <Text variant="title-md" class="gp-library-episode-title">{episode.title}</Text>
                    <Text variant="caption">{episode.author || 'GreenPill'}</Text>
                  </span>
                  <audio class="gp-library-audio gp-library-row-audio" controls preload="none">
                    <source src={episode.audioUrl} type={episode.audioType || 'audio/mpeg'} />
                    Your browser does not support the audio element.
                  </audio>
                  <a class="gp-library-episode-notes" href={episode.link}>Notes</a>
                </article>
              ))}
            </div>
          </div>
        </Container>
      </section>
    )}

    <section class="gp-library-section" id="tools-guides">
      <Container size="2xl">
        <div class="gp-library-bento-stack">
          {guilds.length > 0 && (
            <div>
              <div class="gp-library-section-head">
                <div class="gp-library-section-head-copy">
                  <Overline>Guilds · Working circles</Overline>
                  <Text variant="h2">Build with the network.</Text>
                  <Text variant="body" class="gp-library-section-dek">
                    Public guild pages collect the tools, writing, and coordination work already visible to the network.
                  </Text>
                </div>
              </div>

	              <div class="gp-library-guild-grid">
	                {guilds.map((guild, index) => {
	                  const href = guildHref(guild);
	                  const isExternal = href.startsWith('http');
	                  return (
	                    <a class:list={['gp-library-guild-card', { 'is-bento-wide': guilds.length === 3 && index === 2 }]} href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
	                      <span class="gp-library-status">{guild.data.status || 'active'}</span>
	                      <Text variant="h3" class="gp-library-guild-title">{guild.data.name}</Text>
	                      <Text variant="body-sm">{guild.data.summary || guild.data.oneliner || guild.data.description}</Text>
	                      <span class="gp-library-guild-foot">
	                        <span>{guildFootLabel(guild)}</span>
	                        <span aria-hidden="true">→</span>
	                      </span>
	                    </a>
	                  );
	                })}
	              </div>
            </div>
          )}

          <div>
            <div class="gp-library-section-head">
              <div class="gp-library-section-head-copy">
                <Overline>Knowledge Garden · Living guides</Overline>
                <Text variant="h2">Learn how the network operates.</Text>
                <Text variant="body" class="gp-library-section-dek">
                  Garden threads, public docs, and source-backed guides stay here when they are ready for public readers.
                </Text>
              </div>
              <ArrowLink href="/garden">Open Garden</ArrowLink>
            </div>

	            <div class="gp-library-garden-grid">
	              {gardenGuides.map((guide, index) => (
	                <a class:list={['gp-library-garden-card', { 'is-featured': index === 0 }]} href={guide.href} target={guide.href.startsWith('http') ? '_blank' : undefined} rel={guide.href.startsWith('http') ? 'noopener' : undefined}>
	                  <span class="gp-library-garden-wash" aria-hidden="true"></span>
	                  <span class="gp-library-garden-head">
	                    <Overline>Knowledge Garden</Overline>
	                    <span>{guide.meta}</span>
	                  </span>
	                  <Text variant="h3" class="gp-library-garden-title">{guide.title}</Text>
	                  <Text variant="body-sm">{guide.summary}</Text>
	                  <span class="gp-library-garden-topics">
	                    {guide.topics.map((topic) => <span>{topic}</span>)}
	                  </span>
	                  <span class="gp-library-garden-foot">
	                    <span>{guide.updated}</span>
	                    <span>{guide.authors}</span>
	                  </span>
	                  <span class="gp-library-resource-arrow" aria-hidden="true">↗</span>
	                </a>
	              ))}
	            </div>
          </div>
        </div>
      </Container>
    </section>
  </main>
</GpLayout>

<style>
  .gp-library {
    min-height: 100dvh;
    background: transparent;
  }

  .gp-library-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-3xl), 7vw, var(--gp-space-5xl)) 0 var(--gp-space-2xl);
  }

  .gp-library-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-lg);
  }

  .gp-library-hero-inner :global(.gp-library-hero-title) {
    max-width: 18ch;
    font-size: var(--gp-display-size);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .gp-library-hero-inner :global(.gp-library-hero-dek) {
    max-width: 60ch;
    color: var(--gp-fg-muted);
  }

  .gp-library-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .gp-library-stat-strip {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(var(--gp-space-lg), 3vw, var(--gp-space-2xl));
    padding-top: var(--gp-space-lg);
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-library-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gp-library-stat-big {
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: var(--gp-h2-size);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0;
  }

  .gp-library-stat.is-accent .gp-library-stat-big {
    color: var(--gp-primary);
  }

  .gp-library-stat-sub {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gp-library-section {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-library-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--gp-space-xl);
    flex-wrap: wrap;
    margin-bottom: var(--gp-space-xl);
  }

  .gp-library-section-head-copy {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    max-width: 720px;
  }

  .gp-library-section-head-copy :global(.gp-library-section-dek) {
    color: var(--gp-fg-muted);
  }

	  .gp-library-books-grid {
	    display: grid;
	    grid-template-columns: repeat(10, minmax(0, 1fr));
	    gap: var(--gp-space-2xl) clamp(18px, 2vw, 28px);
	  }

	  .gp-library-book {
	    position: relative;
	    display: flex;
	    grid-column: span 2;
	    flex-direction: column;
	    gap: 14px;
	    min-width: 0;
    text-decoration: none;
    color: var(--gp-fg);
	    transition: transform 200ms, color 200ms;
	  }

	  .gp-library-book:last-child:nth-child(5n + 1) {
	    grid-column: 5 / span 2;
	  }

	  .gp-library-book:nth-last-child(2):nth-child(5n + 1) {
	    grid-column: 4 / span 2;
	  }

	  .gp-library-book:nth-last-child(3):nth-child(5n + 1) {
	    grid-column: 3 / span 2;
	  }

	  .gp-library-book:nth-last-child(4):nth-child(5n + 1) {
	    grid-column: 2 / span 2;
	  }

	  .gp-library-book:hover {
	    transform: translateY(-3px);
	  }

  .gp-library-book-index {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .gp-library-book-cover {
	    display: grid;
	    place-items: center;
	    width: 100%;
	    aspect-ratio: 3 / 4;
	    padding: 10px;
	    border: 1px solid rgba(240, 220, 160, 0.14);
	    border-radius: var(--gp-radius-md);
	    background: rgba(15, 61, 46, 0.5);
	    box-shadow: var(--gp-shadow-card);
	    overflow: hidden;
	    transition: border-color 200ms, background 200ms, box-shadow 200ms;
	  }

  .gp-library-book:hover .gp-library-book-cover {
    border-color: rgba(184, 232, 53, 0.34);
    background: rgba(15, 61, 46, 0.68);
    box-shadow: var(--gp-shadow-card-lg);
  }

  .gp-library-book-cover img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: var(--gp-radius-sm);
  }

  .gp-library-book-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .gp-library-book-meta :global(.gp-library-book-title) {
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0;
  }

	  .gp-library-podcast-layout {
	    display: grid;
	    grid-template-columns: minmax(300px, 0.8fr) minmax(0, 1.2fr);
	    gap: clamp(var(--gp-space-xl), 4vw, var(--gp-space-3xl));
	    align-items: start;
	  }

	  .gp-library-podcast-links {
	    display: inline-flex;
	    flex-wrap: wrap;
	    align-items: center;
	    justify-content: flex-end;
	    gap: var(--gp-space-md);
	  }

	  .gp-library-podcast-feature {
	    display: grid;
	    grid-template-columns: minmax(88px, 112px) minmax(0, 1fr);
	    gap: var(--gp-space-md);
	    align-items: start;
	    justify-self: start;
	    width: min(100%, 460px);
	    padding: var(--gp-space-md);
	    border: 1px solid rgba(184, 232, 53, 0.28);
	    border-radius: var(--gp-radius-lg);
	    background: linear-gradient(145deg, rgba(184, 232, 53, 0.08), rgba(15, 61, 46, 0.56));
	    color: var(--gp-fg);
	    text-decoration: none;
	    transition: border-color 200ms, transform 200ms, background 200ms;
	  }

  .gp-library-podcast-feature:hover {
    border-color: rgba(184, 232, 53, 0.48);
    background: linear-gradient(145deg, rgba(184, 232, 53, 0.12), rgba(15, 61, 46, 0.68));
    transform: translateY(-2px);
  }

  .gp-library-podcast-cover {
    display: grid;
    place-items: center;
  }

  .gp-library-podcast-cover img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--gp-radius-md);
    box-shadow: var(--gp-shadow-card-lg);
  }

	  .gp-library-podcast-copy {
	    display: flex;
	    flex-direction: column;
	    gap: var(--gp-space-sm);
	    min-width: 0;
	  }

	  .gp-library-podcast-copy :global(.gp-library-podcast-title) {
	    display: -webkit-box;
	    overflow: hidden;
	    -webkit-box-orient: vertical;
	    -webkit-line-clamp: 3;
	    letter-spacing: 0;
	  }

	  .gp-library-podcast-copy :global(.gp-library-podcast-summary) {
	    display: -webkit-box;
	    overflow: hidden;
	    -webkit-box-orient: vertical;
	    -webkit-line-clamp: 3;
	  }

	  .gp-library-episode-list {
	    display: flex;
	    flex-direction: column;
	    justify-content: flex-start;
    border-top: 1px solid var(--gp-border-soft);
    border-bottom: 1px solid var(--gp-border-soft);
  }

	  .gp-library-episode-row {
	    display: grid;
	    grid-template-columns: 64px minmax(0, 1fr) minmax(160px, 220px) auto;
	    gap: var(--gp-space-sm);
	    align-items: center;
	    padding: var(--gp-space-md) 0;
	    border-bottom: 1px solid var(--gp-border-soft);
	    color: var(--gp-fg);
	    text-decoration: none;
	  }

  .gp-library-episode-row:last-child {
    border-bottom: 0;
  }

	  .gp-library-episode-image {
	    width: 64px;
	    height: 64px;
	    border: 1px solid var(--gp-border-soft);
	    border-radius: var(--gp-radius-md);
	    object-fit: cover;
	    box-shadow: var(--gp-shadow-card);
	  }

	  .gp-library-episode-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 4px;
  }

	  .gp-library-episode-copy :global(.gp-library-episode-title) {
	    display: -webkit-box;
	    overflow: hidden;
	    -webkit-box-orient: vertical;
	    -webkit-line-clamp: 2;
	    color: var(--gp-secondary);
	  }

	  .gp-library-audio {
	    display: block;
	    width: 100%;
	    min-width: 0;
	    accent-color: var(--gp-primary);
	  }

	  .gp-library-feature-audio {
	    grid-column: 1 / -1;
	    margin-top: 0;
	  }

	  .gp-library-episode-source,
	  .gp-library-episode-notes {
	    display: flex;
	    align-items: center;
	    gap: 10px;
	    color: var(--gp-fg-muted);
	    font-family: var(--gp-font-mono);
	    font-size: 11px;
	    letter-spacing: 0.06em;
