---
import { getCollection } from 'astro:content';
import GpLayout from '../../layouts/GpLayout.astro';
import { getOperationalGuilds } from '../../lib/operational-content';
import { publicGuildPath } from '../../lib/public-routes';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import Chip from '../../components/ui/Chip.astro';
import ArrowLink from '../../components/ui/ArrowLink.astro';
import Overline from '../../components/ui/Overline.astro';
import Text from '../../components/ui/Text.astro';
import Meta from '../../components/ui/Meta.astro';
import library from '../../content/library.json';

const books = (await getCollection('books')).sort(
  (a, b) => (a.data.sortOrder ?? 0) - (b.data.sortOrder ?? 0),
);

const allResources = await getCollection('resources');
const resourceRank = new Map((library.featuredResourceSlugs ?? []).map((slug, index) => [slug, index]));
const resources = allResources
  .filter((r) => r.data.status === 'published')
  .sort((a, b) => (resourceRank.get(a.id) ?? 99) - (resourceRank.get(b.id) ?? 99));

const podcastResource = resources.find((r) => r.id === 'greenpill-podcast');
const otherResources = resources.filter((r) => r.id !== 'greenpill-podcast');
const episodeResources = otherResources.filter((r) => r.data.kind === 'podcast');
const gardenResources = otherResources.filter((r) => r.data.card?.surfaceType === 'garden' || r.id.includes('garden'));
const guideResources = otherResources.filter((r) => r.data.kind !== 'podcast');

const guilds = (await getOperationalGuilds())
  .filter((guild) => publicGuildPath(guild.id || guild.slug));

const hero = library.hero ?? {};
const podcastEpisodes = library.proofSignals?.find((p) => p.label === 'Podcast archive')?.value ?? '293 episodes';
const libraryStats = [
  { value: String(books.length), label: 'Books' },
  { value: podcastEpisodes, label: 'Podcast archive' },
  { value: String(guilds.length), label: guilds.length === 1 ? 'Guild' : 'Guilds' },
  { value: String(gardenResources.length || 1), label: gardenResources.length === 1 ? 'Garden guide' : 'Garden guides' },
];

const themeLabel = (slug: string) => slug.replace(/-/g, ' ');
const resourceHref = (resource: typeof resources[number]) => resource.data.primaryUrl || resource.data.card?.href || '#';
const resourceMeta = (resource: typeof resources[number]) => [
  resource.data.kind || resource.data.card?.surfaceType || 'resource',
  resource.data.episodeNumber ? `Ep ${resource.data.episodeNumber}` : '',
  resource.data.publishDate || '',
].filter(Boolean);
---

<GpLayout
  title={library.seo?.title || 'Library · Greenpill Network'}
  description={library.seo?.description || 'Books, podcast episodes, public docs, and Garden onboarding material.'}
  ogImage={library.seo?.ogImage || undefined}
  canonicalPath={library.seo?.canonicalPath || '/library'}
  noindex={library.seo?.noindex}
  activeNav="Library"
>
  <main class="gp-library">
    <section class="gp-library-hero gp-topo">
      <Container size="2xl">
        <div class="gp-library-hero-inner">
          <Overline tone="muted">
            <span>Library</span>
            <span aria-hidden="true">·</span>
            <span>Public knowledge commons</span>
          </Overline>

          <Text variant="display" class="gp-library-hero-title">{hero.title || 'Everything we have made public.'}</Text>

          <Text variant="body-lg" class="gp-library-hero-dek">
            {hero.dek || 'Books, podcast conversations, Hub threads, project docs, and Garden resources from across the Greenpill network.'}
          </Text>

          <div class="gp-library-hero-actions">
            <Button href="#books">{hero.primaryCta?.label || 'Browse books'}</Button>
            <Button
              href={hero.secondaryCta?.href || 'https://podcasts.apple.com/us/podcast/greenpill/id1609313639'}
              variant="ghost"
            >
              {hero.secondaryCta?.label || 'Listen to the podcast'}
            </Button>
          </div>

          <div class="gp-library-stat-strip">
            {libraryStats.map((stat, index) => (
              <div class:list={['gp-library-stat', { 'is-accent': index === 1 }]}>
                <span class="gp-library-stat-big">{stat.value}</span>
                <span class="gp-library-stat-sub">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <section class="gp-library-section" id="books">
      <Container size="2xl">
        <div class="gp-library-section-head">
          <div class="gp-library-section-head-copy">
            <Overline>Books · {books.length} titles</Overline>
            <Text variant="h2">The foundation shelf.</Text>
            <Text variant="body" class="gp-library-section-dek">
              Open-source books on regenerative crypto, public goods, capital allocation, local regeneration,
              and onchain impact networks.
            </Text>
          </div>
          <Text variant="mono">All free · multiple languages</Text>
        </div>

        <div class="gp-library-books-grid">
          {books.map((book, index) => (
            <a class="gp-library-book" href={book.data.ebookLink || '#'} target={book.data.ebookLink?.startsWith('http') ? '_blank' : undefined} rel="noopener">
              <span class="gp-library-book-index">{String(index + 1).padStart(2, '0')}</span>
              <span class="gp-library-book-cover">
                {book.data.image && (
                  <img
                    src={book.data.image}
                    alt={book.data.imageAlt}
                    width={book.data.imageWidth ?? 200}
                    height={book.data.imageHeight ?? 300}
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </span>
              <div class="gp-library-book-meta">
                <Text variant="title-md" class="gp-library-book-title">{book.data.title}</Text>
                {book.data.author && <Text variant="caption">{book.data.author}{book.data.publishYear && ` · ${book.data.publishYear}`}</Text>}
                {book.data.translations.length > 0 && (
                  <Text variant="mono">{book.data.translations.length} translations</Text>
                )}
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>

    {podcastResource && (
      <section class="gp-library-section">
        <Container size="2xl">
          <div class="gp-library-section-head">
            <div class="gp-library-section-head-copy">
              <Overline>Podcast · {podcastEpisodes}</Overline>
              <Text variant="h2">A long-running public conversation.</Text>
              <Text variant="body" class="gp-library-section-dek">
                The Greenpill podcast archive on Apple Podcasts, plus public episodes connected to chapters and guilds.
              </Text>
            </div>
            <ArrowLink href={podcastResource.data.primaryUrl}>Open archive</ArrowLink>
          </div>

          <div class="gp-library-podcast-layout">
            <a class="gp-library-podcast-feature" href={podcastResource.data.primaryUrl}>
              <div class="gp-library-podcast-cover" aria-hidden="true">
                <img
                  src="/images/podcast-cover.png"
                  alt="Greenpill Podcast cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="gp-library-podcast-copy">
                <Meta items={['Podcast', podcastResource.data.host || 'Kevin Owocki', podcastResource.data.publishDate || '2022']} accentIndex={1} />
                <Text variant="h3" class="gp-library-podcast-title">{podcastResource.data.title}</Text>
                <Text variant="body-sm">{podcastResource.data.summary || podcastResource.data.description}</Text>
                <div class="gp-library-podcast-actions">
                  <span class="gp-library-play" aria-hidden="true">▶</span>
                  <span class="gp-library-progress" aria-hidden="true"><span></span></span>
                  <span class="gp-library-duration">{podcastEpisodes}</span>
                </div>
              </div>
            </a>

            <div class="gp-library-episode-list" aria-label="Featured public episodes">
              {episodeResources.map((episode, index) => (
                <a class="gp-library-episode-row" href={resourceHref(episode)} target={resourceHref(episode).startsWith('http') ? '_blank' : undefined} rel="noopener">
                  <span class="gp-library-episode-number">{episode.data.episodeNumber ? `EP ${episode.data.episodeNumber}` : String(index + 1).padStart(2, '0')}</span>
                  <span class="gp-library-episode-copy">
                    <Text variant="title-md" class="gp-library-episode-title">{episode.data.card?.title || episode.data.title}</Text>
                    <Text variant="caption">{episode.data.guest || episode.data.author || 'Public episode'}</Text>
                  </span>
                  <span class="gp-library-episode-play" aria-hidden="true">▶</span>
                </a>
              ))}
            </div>
          </div>
        </Container>
      </section>
    )}

    <section class="gp-library-section" id="tools-guides">
      <Container size="2xl">
        <div class="gp-library-bento-stack">
          {guilds.length > 0 && (
            <div>
              <div class="gp-library-section-head">
                <div class="gp-library-section-head-copy">
                  <Overline>Guilds · Working circles</Overline>
                  <Text variant="h2">Build with the network.</Text>
                  <Text variant="body" class="gp-library-section-dek">
                    Public guild pages collect the tools, writing, and coordination work already visible to the network.
                  </Text>
                </div>
              </div>

              <div class="gp-library-guild-grid">
                {guilds.map((guild) => (
                  <a class="gp-library-guild-card" href={publicGuildPath(guild.id || guild.slug)}>
                    <span class="gp-library-status">{guild.data.status || 'active'}</span>
                    <Text variant="h3" class="gp-library-guild-title">{guild.data.name}</Text>
                    <Text variant="body-sm">{guild.data.summary || guild.data.oneliner || guild.data.description}</Text>
                    <span class="gp-library-guild-foot">
                      <span>{(guild.data.proofSignals ?? []).length || 'Public'} proof sources</span>
                      <span aria-hidden="true">→</span>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div>
            <div class="gp-library-section-head">
              <div class="gp-library-section-head-copy">
                <Overline>Knowledge Garden · Living guides</Overline>
                <Text variant="h2">Learn how the network operates.</Text>
                <Text variant="body" class="gp-library-section-dek">
                  Garden threads, public docs, and source-backed guides stay here when they are ready for public readers.
                </Text>
              </div>
              <ArrowLink href="/garden">Open Garden</ArrowLink>
            </div>

            <div class="gp-library-resource-grid">
              {guideResources.map((res) => (
                <a class:list={['gp-library-resource', { 'is-garden': res.data.card?.surfaceType === 'garden' }]} href={resourceHref(res)} target={resourceHref(res).startsWith('http') ? '_blank' : undefined} rel="noopener">
                  {res.data.card?.image && <span class="gp-library-resource-image" style={`background-image: url('${res.data.card.image}')`}></span>}
                  <Meta items={resourceMeta(res)} accentIndex={0} />
                  <Text variant="title-lg" class="gp-library-resource-title">{res.data.card?.title || res.data.title}</Text>
                  <Text variant="body-sm">{res.data.card?.summary || res.data.summary || res.data.description}</Text>
                  {(res.data.themeSlugs ?? []).length > 0 && (
                    <div class="gp-library-resource-themes">
                      {(res.data.themeSlugs ?? []).slice(0, 3).map((t: string) => (
                        <Chip tone="soft-lime" size="sm">{themeLabel(t)}</Chip>
                      ))}
                    </div>
                  )}
                  <span class="gp-library-resource-arrow" aria-hidden="true">↗</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </Container>
    </section>
  </main>
</GpLayout>

<style>
  .gp-library {
    min-height: 100dvh;
    background: transparent;
  }

  .gp-library-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-3xl), 7vw, var(--gp-space-5xl)) 0 var(--gp-space-2xl);
  }

  .gp-library-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-lg);
  }

  .gp-library-hero-inner :global(.gp-library-hero-title) {
    max-width: 18ch;
    font-size: var(--gp-display-size);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .gp-library-hero-inner :global(.gp-library-hero-dek) {
    max-width: 60ch;
    color: var(--gp-fg-muted);
  }

  .gp-library-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .gp-library-stat-strip {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(var(--gp-space-lg), 3vw, var(--gp-space-2xl));
    padding-top: var(--gp-space-lg);
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-library-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gp-library-stat-big {
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: var(--gp-h2-size);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0;
  }

  .gp-library-stat.is-accent .gp-library-stat-big {
    color: var(--gp-primary);
  }

  .gp-library-stat-sub {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gp-library-section {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-library-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--gp-space-xl);
    flex-wrap: wrap;
    margin-bottom: var(--gp-space-xl);
  }

  .gp-library-section-head-copy {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    max-width: 720px;
  }

  .gp-library-section-head-copy :global(.gp-library-section-dek) {
    color: var(--gp-fg-muted);
  }

  .gp-library-books-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--gp-space-2xl) clamp(18px, 2vw, 28px);
  }

  .gp-library-book {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
    text-decoration: none;
    color: var(--gp-fg);
    transition: transform 200ms, color 200ms;
  }

  .gp-library-book:hover {
    transform: translateY(-3px);
  }

  .gp-library-book-index {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .gp-library-book-cover {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 2 / 3;
    padding: 10px;
    border: 1px solid rgba(240, 220, 160, 0.14);
    border-radius: var(--gp-radius-md);
    background: rgba(15, 61, 46, 0.5);
    box-shadow: var(--gp-shadow-card);
    transition: border-color 200ms, background 200ms, box-shadow 200ms;
  }

  .gp-library-book:hover .gp-library-book-cover {
    border-color: rgba(184, 232, 53, 0.34);
    background: rgba(15, 61, 46, 0.68);
    box-shadow: var(--gp-shadow-card-lg);
  }

  .gp-library-book-cover img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: var(--gp-radius-sm);
  }

  .gp-library-book-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .gp-library-book-meta :global(.gp-library-book-title) {
    color: var(--gp-secondary);
    font-family: var(--gp-font-display);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0;
  }

  .gp-library-podcast-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: clamp(var(--gp-space-xl), 4vw, var(--gp-space-3xl));
    align-items: stretch;
  }

  .gp-library-podcast-feature {
    display: grid;
    grid-template-columns: minmax(160px, 220px) minmax(0, 1fr);
    gap: var(--gp-space-xl);
    align-items: center;
    min-height: 360px;
    padding: var(--gp-space-xl);
    border: 1px solid rgba(184, 232, 53, 0.28);
    border-radius: var(--gp-radius-lg);
    background: linear-gradient(145deg, rgba(184, 232, 53, 0.08), rgba(15, 61, 46, 0.56));
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, transform 200ms, background 200ms;
  }

  .gp-library-podcast-feature:hover {
    border-color: rgba(184, 232, 53, 0.48);
    background: linear-gradient(145deg, rgba(184, 232, 53, 0.12), rgba(15, 61, 46, 0.68));
    transform: translateY(-2px);
  }

  .gp-library-podcast-cover {
    display: grid;
    place-items: center;
  }

  .gp-library-podcast-cover img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--gp-radius-md);
    box-shadow: var(--gp-shadow-card-lg);
  }

  .gp-library-podcast-copy {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    min-width: 0;
  }

  .gp-library-podcast-title {
    letter-spacing: 0;
  }

  .gp-library-podcast-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: auto;
    padding-top: var(--gp-space-md);
  }

  .gp-library-play,
  .gp-library-episode-play {
    display: inline-grid;
    place-items: center;
    flex: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gp-primary);
    color: var(--gp-primary-fg);
    font-size: 13px;
    box-shadow: var(--gp-shadow-pill);
  }

  .gp-library-progress {
    position: relative;
    flex: 1;
    height: 4px;
    min-width: 80px;
    border-radius: 999px;
    background: rgba(42, 107, 82, 0.8);
    overflow: hidden;
  }

  .gp-library-progress span {
    position: absolute;
    inset: 0 auto 0 0;
    width: 18%;
    border-radius: inherit;
    background: var(--gp-primary);
  }

  .gp-library-duration {
    color: var(--gp-fg-muted);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .gp-library-episode-list {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-top: 1px solid var(--gp-border-soft);
    border-bottom: 1px solid var(--gp-border-soft);
  }

  .gp-library-episode-row {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr) 44px;
    gap: var(--gp-space-md);
    align-items: center;
    padding: var(--gp-space-lg) 0;
    border-bottom: 1px solid var(--gp-border-soft);
    color: var(--gp-fg);
    text-decoration: none;
  }

  .gp-library-episode-row:last-child {
    border-bottom: 0;
  }

  .gp-library-episode-number {
    color: var(--gp-fg-dim);
    font-family: var(--gp-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gp-library-episode-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 4px;
  }

  .gp-library-episode-title {
    color: var(--gp-secondary);
  }

  .gp-library-episode-play {
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--gp-border);
    color: var(--gp-fg);
    box-shadow: none;
  }

  .gp-library-resource-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(14px, 1.5vw, 20px);
  }

  .gp-library-resource {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    min-height: 300px;
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: rgba(20, 63, 48, 0.5);
    color: var(--gp-fg);
    overflow: hidden;
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-library-resource > *:not(.gp-library-resource-image) {
    position: relative;
    z-index: 1;
  }

  .gp-library-resource:hover {
    border-color: rgba(184, 232, 53, 0.32);
    background: rgba(20, 63, 48, 0.7);
  }

  .gp-library-resource.is-garden {
    border-color: rgba(240, 220, 160, 0.24);
  }

  .gp-library-resource-image {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    opacity: 0.16;
    mix-blend-mode: overlay;
  }

  .gp-library-resource :global(.gp-library-resource-title) {
    letter-spacing: 0;
  }

  .gp-library-resource-themes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .gp-library-resource-arrow {
    position: absolute;
    top: var(--gp-space-lg);
    right: var(--gp-space-lg);
    color: var(--gp-fg-dim);
    transition: color 200ms;
  }

  .gp-library-resource:hover .gp-library-resource-arrow {
    color: var(--gp-primary);
  }

  .gp-library-bento-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(var(--gp-space-3xl), 7vw, var(--gp-space-5xl));
  }

  .gp-library-guild-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-library-guild-card {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    min-height: 280px;
    padding: var(--gp-space-xl);
    border: 1px solid rgba(184, 232, 53, 0.24);
    border-radius: var(--gp-radius-lg);
    background: linear-gradient(155deg, rgba(184, 232, 53, 0.06), rgba(20, 63, 48, 0.48));
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms, transform 200ms;
  }

  .gp-library-guild-card:hover {
    border-color: rgba(184, 232, 53, 0.44);
    background: linear-gradient(155deg, rgba(184, 232, 53, 0.1), rgba(20, 63, 48, 0.66));
    transform: translateY(-2px);
  }

  .gp-library-status {
    width: fit-content;
    padding: 5px 10px;
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-pill);
    color: var(--gp-primary);
    font-family: var(--gp-font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .gp-library-guild-title {
    color: var(--gp-secondary);
  }

  .gp-library-guild-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gp-space-md);
    margin-top: auto;
    padding-top: var(--gp-space-md);
    border-top: 1px solid var(--gp-border-soft);
    color: var(--gp-fg-muted);
