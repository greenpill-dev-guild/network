---
import GpLayout from '../../layouts/GpLayout.astro';
import Container from '../../components/ui/Container.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import Chip from '../../components/ui/Chip.astro';
import ArrowLink from '../../components/ui/ArrowLink.astro';
import Overline from '../../components/ui/Overline.astro';
import Text from '../../components/ui/Text.astro';
import Meta from '../../components/ui/Meta.astro';
import LinkRow from '../../components/ui/LinkRow.astro';
import Breadcrumb from '../../components/shell/Breadcrumb.astro';
import StatusChip from '../../components/ui/StatusChip.astro';
import { getOperationalGuilds, getOperationalProjects } from '../../lib/operational-content';
import { hasPublicGuildPage } from '../../lib/public-routes';

export async function getStaticPaths() {
  const items = await getOperationalGuilds();
  return items
    .filter((item) => hasPublicGuildPage(item.id))
    .map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const data = item.data;
const themes = (data.themeSlugs ?? []) as string[];
const links = (data.links ?? []).filter((l: any) => l.url);
const connectLinks = (data.connectLinks ?? []).filter((l: any) => l.url);
const outputs = data.outputs ?? [];
const mandate = data.mandateParagraphs ?? [];
const principles = data.principles ?? [];
const publicMembers = data.publicMembers ?? [];
const proofSignals = data.proofSignals ?? [];

const allProjects = await getOperationalProjects();
const projects = allProjects.filter((p) => p.data.guild === item.id);
const projectHref = (project: any) => project.data.liveUrl || project.data.repoUrl || '';

const surfaceLabel = data.type === 'guild' ? 'Guild' : 'Pod';
---

<GpLayout
  title={data.seo?.title || `${data.name} · Greenpill ${surfaceLabel}`}
  description={data.seo?.description || data.summary || ''}
  ogImage={data.seo?.ogImage || data.media?.ogImage || undefined}
  canonicalPath={data.seo?.canonicalPath || `/guilds/${item.id}`}
  noindex={data.seo?.noindex}
  activeNav="Guilds"
  ogType="profile"
>
  <main class="gp-guild">
    <section class="gp-guild-hero gp-topo">
      <Container size="2xl">
        <Breadcrumb
          back={{ label: 'Garden', href: '/garden' }}
          crumbs={[{ label: surfaceLabel }, { label: data.name }]}
        />
        <div class="gp-guild-hero-inner">
          <Overline>
            <span>{surfaceLabel}</span>
            {data.foundedYear && <><span aria-hidden="true">·</span><span>since {data.foundedYear}</span></>}
          </Overline>

          <Text variant="display" class="gp-guild-name">{data.name}</Text>

          {data.oneliner && <Text variant="body-lg" class="gp-guild-oneliner">{data.oneliner}</Text>}

          {data.summary && data.summary !== data.oneliner && (
            <Text variant="body" class="gp-guild-summary">{data.summary}</Text>
          )}

          <div class="gp-guild-chips">
            <StatusChip>{(data.status || 'active').charAt(0).toUpperCase() + (data.status || 'active').slice(1)}</StatusChip>
            {themes.slice(0, 6).map((t) => (
              <Chip tone="soft-lime">{t.replace(/-/g, ' ')}</Chip>
            ))}
          </div>

          {links.length > 0 && (
            <div class="gp-guild-hero-actions">
              {links.slice(0, 2).map((link: any) => (
                <Button href={link.url} variant={link === links[0] ? 'primary' : 'ghost'}>{link.action || link.label}</Button>
              ))}
            </div>
          )}
        </div>
      </Container>
    </section>

    {(mandate.length > 0 || principles.length > 0) && (
      <section class="gp-guild-section">
        <Container size="2xl">
          <div class="gp-guild-grid">
            {mandate.length > 0 && (
              <div class="gp-guild-mandate">
                <Overline>Mandate</Overline>
                <div class="gp-guild-mandate-prose">
                  {mandate.map((para) => (
                    <Text variant="body">{para}</Text>
                  ))}
                </div>
              </div>
            )}

            {principles.length > 0 && (
              <div class="gp-guild-principles">
                <Overline>Principles</Overline>
                <ol class="gp-guild-principle-list">
                  {principles.map((p) => (
                    <li>
                      <span class="gp-guild-principle-num">{String(p.order || 0).padStart(2, '0')}</span>
                      <div>
                        <Text variant="title-md">{p.title}</Text>
                        {p.body && <Text variant="body-sm">{p.body}</Text>}
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            )}
          </div>
        </Container>
      </section>
    )}

    {outputs.length > 0 && (
      <section class="gp-guild-section">
        <Container size="2xl">
          <div class="gp-guild-section-head">
            <Overline>Public outputs</Overline>
            <Text variant="caption">{outputs.length} surfaces</Text>
          </div>
          <div class="gp-guild-output-grid">
            {outputs.map((output) => (
              <a class="gp-guild-output" href={output.href || '#'} target={output.href?.startsWith('http') ? '_blank' : undefined} rel="noopener">
                <Text variant="title-lg" class="gp-guild-output-title">{output.label}</Text>
                {output.summary && <Text variant="body-sm">{output.summary}</Text>}
                <span class="gp-guild-output-arrow" aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}

    {projects.length > 0 && (
      <section class="gp-guild-section">
        <Container size="2xl">
          <div class="gp-guild-section-head">
            <Overline>Projects</Overline>
            <Text variant="caption">{projects.length} public project{projects.length === 1 ? '' : 's'}</Text>
          </div>
          <div class="gp-guild-project-grid">
            {projects.map((p) => (
              <a
                class="gp-guild-project"
                href={projectHref(p) || '#'}
                target={projectHref(p)?.startsWith('http') ? '_blank' : undefined}
                rel={projectHref(p)?.startsWith('http') ? 'noopener' : undefined}
              >
                <Meta items={['Project', p.data.status || 'active']} accentIndex={1} />
                <Text variant="title-lg" class="gp-guild-project-title">{p.data.name}</Text>
                {p.data.summary && <Text variant="body-sm">{p.data.summary}</Text>}
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}

    {proofSignals.length > 0 && (
      <section class="gp-guild-section">
        <Container size="2xl">
          <div class="gp-guild-section-head">
            <Overline>Public proof</Overline>
            <Text variant="caption">{proofSignals.length} source-backed signal{proofSignals.length === 1 ? '' : 's'}</Text>
          </div>
          <div class="gp-guild-proof-grid">
            {proofSignals.map((signal) => (
              <a class="gp-guild-proof" href={signal.href || '#'} target="_blank" rel="noopener">
                <Text variant="mono">{signal.source || 'Public source'}</Text>
                <Text variant="title-md" class="gp-guild-proof-value">{signal.value}</Text>
                <Text variant="body-sm">{signal.label}</Text>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}

    {publicMembers.length > 0 && (
      <section class="gp-guild-section">
        <Container size="2xl">
          <div class="gp-guild-section-head">
            <Overline>Public contributors</Overline>
            <Text variant="caption">{publicMembers.length} public reference{publicMembers.length === 1 ? '' : 's'}</Text>
          </div>
          <div class="gp-guild-member-grid">
            {publicMembers.map((m) => (
              <Card padded="md">
                <Text variant="title-md">{m.name}</Text>
                {m.role && <Text variant="caption">{m.role}</Text>}
                {m.bio && <Text variant="body-sm">{m.bio}</Text>}
              </Card>
            ))}
          </div>
        </Container>
      </section>
    )}

    {connectLinks.length > 0 && (
      <section class="gp-guild-section">
        <Container size="2xl">
          <div class="gp-guild-section-head">
            <Overline>Connect</Overline>
            <Text variant="caption">Public channels.</Text>
          </div>
          <Card padded="lg">
            {connectLinks.map((link: any, index: number) => (
              <LinkRow
                href={link.url}
                label={link.label}
                sub={link.subtext}
                handle={link.handle}
                last={index === connectLinks.length - 1}
              />
            ))}
          </Card>
        </Container>
      </section>
    )}

    <section class="gp-guild-cta">
      <Container size="2xl">
        <div class="gp-guild-cta-inner">
          <div>
            <Overline>Get involved</Overline>
            <Text variant="h2">Bring your craft into the guild.</Text>
            <Text variant="body" class="gp-guild-cta-body">
              The Garden is the public ramp into Greenpill guilds. Start small and build up to a steward conversation
              when the project is right.
            </Text>
          </div>
          <div class="gp-guild-cta-actions">
            <Button href="/garden">Enter the Garden</Button>
            <Button href="/library" variant="ghost">Open Library</Button>
          </div>
        </div>
      </Container>
    </section>
  </main>
</GpLayout>

<style>
  .gp-guild {
    min-height: 100vh;
    background: transparent;
  }

  .gp-guild-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--gp-space-2xl), 6vw, var(--gp-space-4xl)) 0 var(--gp-space-2xl);
  }

  .gp-guild-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    margin-top: var(--gp-space-xl);
  }

  .gp-guild-hero-inner :global(.gp-guild-name) {
    max-width: 18ch;
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1.02;
    letter-spacing: -0.02em;
  }

  .gp-guild-hero-inner :global(.gp-guild-oneliner) {
    color: var(--gp-fg-muted);
    max-width: 60ch;
  }

  .gp-guild-hero-inner :global(.gp-guild-summary) {
    color: var(--gp-fg-muted);
    max-width: 70ch;
  }

  .gp-guild-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gp-guild-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: var(--gp-space-md);
  }

  .gp-guild-section {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-3xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-guild-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--gp-space-md);
    flex-wrap: wrap;
    margin-bottom: var(--gp-space-lg);
  }

  .gp-guild-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: clamp(var(--gp-space-xl), 4vw, var(--gp-space-3xl));
  }

  .gp-guild-mandate,
  .gp-guild-principles {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    min-width: 0;
  }

  .gp-guild-mandate-prose {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
    color: var(--gp-fg);
  }

  .gp-guild-principle-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-md);
  }

  .gp-guild-principle-list li {
    display: flex;
    gap: var(--gp-space-md);
    padding: var(--gp-space-md);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-md);
    background: var(--gp-card);
  }

  .gp-guild-principle-list li > div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gp-guild-principle-num {
    color: var(--gp-primary);
    font-family: var(--gp-font-display);
    font-size: 24px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
    flex: none;
  }

  .gp-guild-output-grid,
  .gp-guild-project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-guild-output,
  .gp-guild-project {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-guild-output:hover,
  .gp-guild-project:hover {
    border-color: rgba(184, 232, 53, 0.32);
    background: var(--gp-card-elev);
  }

  .gp-guild-output :global(.gp-guild-output-title),
  .gp-guild-project :global(.gp-guild-project-title) {
    letter-spacing: -0.01em;
  }

  .gp-guild-output-arrow {
    position: absolute;
    top: var(--gp-space-lg);
    right: var(--gp-space-lg);
    color: var(--gp-fg-dim);
    transition: color 200ms;
  }

  .gp-guild-output:hover .gp-guild-output-arrow {
    color: var(--gp-primary);
  }

  .gp-guild-proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-guild-proof {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--gp-space-lg);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--gp-radius-lg);
    background: var(--gp-card);
    color: var(--gp-fg);
    text-decoration: none;
    transition: border-color 200ms, background 200ms;
  }

  .gp-guild-proof:hover {
    border-color: rgba(184, 232, 53, 0.42);
    background: var(--gp-card-elev);
  }

  .gp-guild-proof-value {
    color: var(--gp-primary);
    font-family: var(--gp-font-display);
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .gp-guild-member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--gp-space-md);
  }

  .gp-guild-cta {
    padding: clamp(var(--gp-space-2xl), 5vw, var(--gp-space-4xl)) 0;
    border-top: 1px solid var(--gp-border-soft);
  }

  .gp-guild-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--gp-space-2xl);
    padding: clamp(var(--gp-space-xl), 4vw, var(--gp-space-3xl));
    border: 1px solid rgba(184, 232, 53, 0.32);
    border-radius: var(--gp-radius-xl);
    background: linear-gradient(135deg, rgba(184, 232, 53, 0.06), rgba(15, 61, 46, 0.5));
  }

  .gp-guild-cta-inner > div:first-child {
    display: flex;
    flex-direction: column;
    gap: var(--gp-space-sm);
    max-width: 540px;
  }

  .gp-guild-cta-body {
    color: var(--gp-fg-muted);
  }

  .gp-guild-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 980px) {
    .gp-guild-grid,
    .gp-guild-output-grid,
    .gp-guild-project-grid {
      grid-template-columns: 1fr;
    }

    .gp-guild-cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
