---
import SiteHeader from '../components/shell/SiteHeader.astro';
import SiteFooter from '../components/shell/SiteFooter.astro';
import '../styles/gp-tokens.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalPath?: string;
  activeNav?: string | null;
  noindex?: boolean;
  hideShell?: boolean;
  ogType?: 'website' | 'article' | 'profile';
}

const {
  title,
  description,
  ogImage = 'https://greenpill.network/images/greenpill-twitter-card.png',
  canonicalPath = '',
  activeNav = null,
  noindex = false,
  hideShell = false,
  ogType = 'website',
} = Astro.props;
const canonicalUrl = canonicalPath ? `https://greenpill.network${canonicalPath}` : 'https://greenpill.network';

const bodyClasses = [
  'gp-root',
  'has-graphic-background',
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {canonicalPath && <link rel="canonical" href={canonicalUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/images/greenpill-logo-large.png" type="image/png" sizes="150x150" />
    <link rel="shortcut icon" href="/favicon.ico" />
  </head>
  <body class:list={bodyClasses}>
    <div class="gp-background-parallax" data-gp-parallax-bg aria-hidden="true"></div>
    {!hideShell && <a class="gp-skip-link" href="#main-content">Skip to content</a>}
    {!hideShell && <SiteHeader activeNav={activeNav} />}
    <div id="main-content" class="gp-main-target" tabindex="-1">
      <slot />
    </div>
    {!hideShell && <SiteFooter />}
  </body>
</html>

<style is:global>
  @media (prefers-reduced-motion: no-preference) {
    @view-transition {
      navigation: auto;
    }
  }

  html {
    background: var(--gp-green-950);
    overflow-x: clip;
  }

  body.gp-root {
    margin: 0;
    min-height: 100vh;
    background-color: var(--gp-green-950);
    background-image: none;
    position: relative;
    isolation: isolate;
    overflow-x: clip;
  }

  body.gp-root.has-graphic-background {
    background-image: none;
  }

  body.gp-root .gp-background-parallax {
    position: fixed;
    inset: -14vh 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      radial-gradient(circle at 16% 18%, rgba(184, 232, 53, 0.1), transparent 30%),
      radial-gradient(circle at 82% 74%, rgba(240, 220, 160, 0.08), transparent 34%),
      url('/images/greenpill-bg.png');
    background-position:
      center,
      center,
      top center;
    background-repeat: no-repeat, no-repeat, repeat-y;
    background-size:
      76vmax 76vmax,
      68vmax 68vmax,
      max(1400px, 100vw) auto;
    opacity: 0.94;
    transform: translate3d(0, 0, 0);
  }

  body.gp-root .gp-background-parallax::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/hifi/topo-bg.png');
    background-position: center;
    background-repeat: repeat;
    background-size: min(1200px, 140vw) auto;
    mix-blend-mode: overlay;
    opacity: 0.075;
  }

  body.gp-root .gp-site-header,
  body.gp-root .gp-main-target,
  body.gp-root .gp-site-footer {
    position: relative;
    z-index: 1;
  }

  body.gp-root a {
    color: inherit;
  }

  body.gp-root .gp-skip-link {
    position: fixed;
    top: var(--gp-space-lg);
    left: var(--gp-space-lg);
    z-index: 100;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 var(--gp-space-lg);
    border: 1px solid var(--gp-border);
    border-radius: var(--gp-radius-pill);
    background: var(--gp-primary);
    color: var(--gp-primary-fg);
    font-family: var(--gp-font-body);
    font-size: var(--gp-label-md);
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transform: translateY(calc(-100% - var(--gp-space-2xl)));
    transition: transform 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    body.gp-root .gp-background-parallax {
      position: absolute;
      inset: 0;
      min-height: 100%;
      transform: none;
    }
  }

  body.gp-root .gp-skip-link:focus {
    transform: translateY(0);
  }

  /* Page-level container-query context. Components reflow via @container
     against this; safe because no position:fixed elements live inside
     #main-content (the skip link + header overlay are siblings). */
  .gp-main-target {
    container-type: inline-size;
  }

  .gp-main-target:focus {
    outline: none;
  }
</style>
