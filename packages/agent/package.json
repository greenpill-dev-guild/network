{
  "name": "@greenpill-network/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd ../.. build:packages && bun ../../scripts/run-agent-dev.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "bun run --cwd ../.. build:packages && node --env-file-if-exists=../../.env.local dist/server.js",
    "db:local:up": "docker compose up -d agent-postgres",
    "db:local:down": "docker compose down"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./impact": {
      "types": "./dist/impact.d.ts",
      "default": "./dist/impact.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    },
    "./map-nodes": {
      "types": "./dist/map-nodes.d.ts",
      "default": "./dist/map-nodes.js"
    },
    "./map-state": {
      "types": "./dist/map-state.d.ts",
      "default": "./dist/map-state.js"
    },
    "./impact-cache": {
      "types": "./dist/impact-cache.d.ts",
      "default": "./dist/impact-cache.js"
    },
    "./green-goods-impact": {
      "types": "./dist/green-goods-impact.d.ts",
      "default": "./dist/green-goods-impact.js"
    },
    "./public-content": {
      "types": "./dist/public-content.d.ts",
      "default": "./dist/public-content.js"
    },
    "./newsletter": {
      "types": "./dist/newsletter.d.ts",
      "default": "./dist/newsletter.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@greenpill-network/shared": "workspace:*",
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18",
    "postgres": "^3.4.9"
  }
}
