{
  "name": "@greenpill-network/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env.local --watch src/server.js",
    "start": "node --env-file-if-exists=../../.env.local src/server.js",
    "db:local:up": "docker compose up -d agent-postgres",
    "db:local:down": "docker compose down"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./impact": {
      "types": "./src/impact.d.ts",
      "default": "./src/impact.js"
    },
    "./app": {
      "types": "./src/app.d.ts",
      "default": "./src/app.js"
    },
    "./db": {
      "types": "./src/db.d.ts",
      "default": "./src/db.js"
    },
    "./map-nodes": {
      "types": "./src/map-nodes.d.ts",
      "default": "./src/map-nodes.js"
    },
    "./map-state": {
      "types": "./src/map-state.d.ts",
      "default": "./src/map-state.js"
    },
    "./impact-cache": {
      "types": "./src/impact-cache.d.ts",
      "default": "./src/impact-cache.js"
    },
    "./green-goods-impact": {
      "types": "./src/green-goods-impact.d.ts",
      "default": "./src/green-goods-impact.js"
    },
    "./public-content": {
      "types": "./src/public-content.d.ts",
      "default": "./src/public-content.js"
    }
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "@greenpill-network/shared": "workspace:*",
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18",
    "postgres": "^3.4.9"
  }
}
